[{"data":1,"prerenderedAt":203},["Reactive",2],{"content-query-suticbjrjj":3},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"director":10,"types":11,"release_date":12,"demo":13,"images":14,"body":15,"_type":198,"_id":199,"_source":200,"_file":201,"_extension":202},"/work/jiangxue-joint-laboratory-luanyin-project","work",false,"","江雪联合实验室銮音项目","江雪之前已经成立和组建了一个虹霓实验室，但由于虹霓主要专注于天演计算、分析等方面的项目和边缘领域，因此将一些辅助性的项目划分给了銮音。銮音的名字取自《说文》中的:人君乘车四马四镳八銮，铃象鸾，鸟声，和则敬也。","RHYME.Q","RESEARCH","2023.12.25","https://gateway.luanyin.jiangxue.org/","/images/pages/tianyan/tianyan-home.png",{"type":16,"children":17,"toc":195},"root",[18,25,29,64,70,75,80,85,90,95,111,121,126,135,140,149,163,186,191],{"type":19,"tag":20,"props":21,"children":22},"element","h1",{"id":8},[23],{"type":24,"value":8},"text",{"type":19,"tag":26,"props":27,"children":28},"page-back",{},[],{"type":19,"tag":30,"props":31,"children":32},"page-img",{},[33],{"type":19,"tag":34,"props":35,"children":38},"div",{"className":36},[37],"slider",[39,41],{"type":24,"value":40},"\n  ",{"type":19,"tag":34,"props":42,"children":45},{"className":43},[44],"slides",[46,48,53,54,58,59,63],{"type":24,"value":47},"\n      ",{"type":19,"tag":49,"props":50,"children":52},"img",{"src":51},"/images/pages/tianyan/ty-0.png",[],{"type":24,"value":47},{"type":19,"tag":49,"props":55,"children":57},{"src":56},"/images/pages/tianyan/ty-1.png",[],{"type":24,"value":47},{"type":19,"tag":49,"props":60,"children":62},{"src":61},"/images/pages/tianyan/ty-2.png",[],{"type":24,"value":40},{"type":19,"tag":65,"props":66,"children":67},"p",{},[68],{"type":24,"value":69},"江雪之前已经成立和组建了一个虹霓实验室，但由于虹霓主要专注于天演计算、分析等方面的项目和边缘领域，因此将一些辅助性的项目划分给了銮音。銮音的名字取自《说文》中的 \"人君乘车四马四镳八銮，铃象鸾，鸟声，和则敬也。\"。",{"type":19,"tag":65,"props":71,"children":72},{},[73],{"type":24,"value":74},"因此，銮音这个名字非常符合江雪的调性，所以很搭配一起使用。而为什么叫实验室，也就是 LAB，这个词并不是为了好看或者听起来很牛逼才这么叫的。",{"type":19,"tag":65,"props":76,"children":77},{},[78],{"type":24,"value":79},"而是说之后，随着天演，也就是虹霓逐渐步入正轨，可以为江雪的各个项目提供支持，并进行各种计算和模拟；主要目的是提供一些佐证资料。",{"type":19,"tag":65,"props":81,"children":82},{},[83],{"type":24,"value":84},"加上 LAB 之后，表明拿得出来的东西都是经过推敲、严谨、无懈可击、完美的！而不是随便做出来的。",{"type":19,"tag":65,"props":86,"children":87},{},[88],{"type":24,"value":89},"目前銮音负责的项目主要是声学方面的研究和应用，主要包括模拟、测算、构建等，也就是说可以通过声音进行环境的模拟和建模，并实时反馈。",{"type":19,"tag":65,"props":91,"children":92},{},[93],{"type":24,"value":94},"通过计算出主要或需要的参数，进行系统的分析和统计的综合架构，主要用于特殊领域的分析和画像。",{"type":19,"tag":65,"props":96,"children":97},{},[98,100,109],{"type":24,"value":99},"最近，剑桥的研究团队和合作者巧妙地利用了上述方式，即虚拟实验室，在这篇论文中被称为 SDLs（Distributed Self-Driving Laboratories，分布式自动驾驶实验室 / 分布式自主实验室）刊登在 ",{"type":19,"tag":101,"props":102,"children":106},"a",{"href":103,"rel":104},"https://www.nature.com/articles/s41467-023-44599-9",[105],"nofollow",[107],{"type":24,"value":108},"Nature Journal",{"type":24,"value":110},"。",{"type":19,"tag":112,"props":113,"children":114},"img-tips",{},[115,119],{"type":19,"tag":49,"props":116,"children":118},{"src":117},"/images/info/1/1.png",[],{"type":24,"value":120},"\n图源 1 | From Platform to Knowledge Graph: Distributed Self-Driving Laboratories\nhttps://como.ceb.cam.ac.uk/media/preprints/c4e-preprint-310.pdf",{"type":19,"tag":65,"props":122,"children":123},{},[124],{"type":24,"value":125},"这和天演虹霓实验室的做法类似，通过大量的计算资源将物理实验室设备进行虚拟仿真，已达到云上开展研究和设计，同时实时共享数据可让其合作者实时观察进度和操作。",{"type":19,"tag":112,"props":127,"children":128},{},[129,133],{"type":19,"tag":49,"props":130,"children":132},{"src":131},"/images/info/1/2.png",[],{"type":24,"value":134},"\n图源 2 | 江雪虹霓实验室：为江雪和其附属团队和项目及其合作者提供计算资源和实验环境的计算平台\nhttps://gateway.hongni-lab.jiangxue.org/",{"type":19,"tag":65,"props":136,"children":137},{},[138],{"type":24,"value":139},"当然江雪的某些研究领域不像是生物、化学、物理那样需要什么样的器材和设备，江雪的主要项目更侧重计算机网络、科学等方面，因此我们只是将计算资源以及网络、环境仿真和模拟等。",{"type":19,"tag":112,"props":141,"children":142},{},[143,147],{"type":19,"tag":49,"props":144,"children":146},{"src":145},"/images/info/1/3.png",[],{"type":24,"value":148},"\n图源 3 | 根据科学家的目标请求触发自主工作流，作为在知识图谱中传播信息。\nhttps://como.ceb.cam.ac.uk/media/preprints/c4e-preprint-310.pdf",{"type":19,"tag":65,"props":150,"children":151},{},[152,154,161],{"type":24,"value":153},"像是图 3 这种直接在关系图里直接通过描述词然后让 ROG Agent 直接执行和调用的，还是很新颖的。江雪目前更多的是通过 Code 模块化的预设命令完成这种操作。感觉很像 ",{"type":19,"tag":101,"props":155,"children":158},{"href":156,"rel":157},"https://obsidian.md/",[105],[159],{"type":24,"value":160},"obsidian",{"type":24,"value":162}," 的知识图谱，通过这种方式呈现的效果感觉比看状态、日志的效果更加直观。",{"type":19,"tag":65,"props":164,"children":165},{},[166,168,175,177,184],{"type":24,"value":167},"目前，虹霓通常的架构基本上都是通过 ",{"type":19,"tag":101,"props":169,"children":172},{"href":170,"rel":171},"https://neo4j.com/",[105],[173],{"type":24,"value":174},"Neo4j",{"type":24,"value":176}," 存储和查询关系比较方便，查询速度也很快，再加上 ",{"type":19,"tag":101,"props":178,"children":181},{"href":179,"rel":180},"https://vertx.io/docs/",[105],[182],{"type":24,"value":183},"Vertx Framework",{"type":24,"value":185}," 非常适合计算数据庞大且需要经常查询的计算结果。 但存在一个问题，就是说这些数据拥有较强的关联性且庞大的数据，存在较高的可攻击性，且任何一个节点的修改，性能上存在较高的资源浪费。",{"type":19,"tag":65,"props":187,"children":188},{},[189],{"type":24,"value":190},"未来也许可能通过 Myung 解决这些问题。",{"type":19,"tag":192,"props":193,"children":194},"page-tips",{},[],{"title":7,"searchDepth":196,"depth":196,"links":197},2,[],"markdown","content:work:jiangxue-joint-laboratory-luanyin-project.md","content","work/jiangxue-joint-laboratory-luanyin-project.md","md",1708477341550]