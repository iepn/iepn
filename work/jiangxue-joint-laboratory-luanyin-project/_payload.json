[{"data":1,"prerenderedAt":862},["Reactive",2],{"equal":3,"content-query-suticbjrjj":733},[4,199,377,559],{"_path":5,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":9,"description":10,"director":11,"types":12,"release_date":13,"demo":14,"images":15,"body":16,"_type":194,"_id":195,"_source":196,"_file":197,"_extension":198},"/work/jiangxue-joint-laboratory-luanyin-project","work",false,"","江雪联合实验室銮音项目","江雪之前已经成立和组建了一个虹霓实验室，但由于虹霓主要专注于天演计算、分析等方面的项目和边缘领域，因此将一些辅助性的项目划分给了銮音。銮音的名字取自《说文》中的:人君乘车四马四镳八銮，铃象鸾，鸟声，和则敬也。","RHYME.Q","RESEARCH","2023.12.25","https://gateway.luanyin.jiangxue.org/","/images/pages/tianyan/tianyan-home.png",{"type":17,"children":18,"toc":191},"root",[19,26,30,65,71,76,81,86,91,96,112,122,127,136,141,150,164,187],{"type":20,"tag":21,"props":22,"children":23},"element","h1",{"id":9},[24],{"type":25,"value":9},"text",{"type":20,"tag":27,"props":28,"children":29},"page-back",{},[],{"type":20,"tag":31,"props":32,"children":33},"page-img",{},[34],{"type":20,"tag":35,"props":36,"children":39},"div",{"className":37},[38],"slider",[40,42],{"type":25,"value":41},"\n  ",{"type":20,"tag":35,"props":43,"children":46},{"className":44},[45],"slides",[47,49,54,55,59,60,64],{"type":25,"value":48},"\n      ",{"type":20,"tag":50,"props":51,"children":53},"img",{"src":52},"/images/pages/tianyan/ty-0.png",[],{"type":25,"value":48},{"type":20,"tag":50,"props":56,"children":58},{"src":57},"/images/pages/tianyan/ty-1.png",[],{"type":25,"value":48},{"type":20,"tag":50,"props":61,"children":63},{"src":62},"/images/pages/tianyan/ty-2.png",[],{"type":25,"value":41},{"type":20,"tag":66,"props":67,"children":68},"p",{},[69],{"type":25,"value":70},"江雪之前已经成立和组建了一个虹霓实验室，但由于虹霓主要专注于天演计算、分析等方面的项目和边缘领域，因此将一些辅助性的项目划分给了銮音。銮音的名字取自《说文》中的 \"人君乘车四马四镳八銮，铃象鸾，鸟声，和则敬也。\"。",{"type":20,"tag":66,"props":72,"children":73},{},[74],{"type":25,"value":75},"因此，銮音这个名字非常符合江雪的调性，所以很搭配一起使用。而为什么叫实验室，也就是 LAB，这个词并不是为了好看或者听起来很牛逼才这么叫的。",{"type":20,"tag":66,"props":77,"children":78},{},[79],{"type":25,"value":80},"而是说之后，随着天演，也就是虹霓逐渐步入正轨，可以为江雪的各个项目提供支持，并进行各种计算和模拟；主要目的是提供一些佐证资料。",{"type":20,"tag":66,"props":82,"children":83},{},[84],{"type":25,"value":85},"加上 LAB 之后，表明拿得出来的东西都是经过推敲、严谨、无懈可击、完美的！而不是随便做出来的。",{"type":20,"tag":66,"props":87,"children":88},{},[89],{"type":25,"value":90},"目前銮音负责的项目主要是声学方面的研究和应用，主要包括模拟、测算、构建等，也就是说可以通过声音进行环境的模拟和建模，并实时反馈。",{"type":20,"tag":66,"props":92,"children":93},{},[94],{"type":25,"value":95},"通过计算出主要或需要的参数，进行系统的分析和统计的综合架构，主要用于特殊领域的分析和画像。",{"type":20,"tag":66,"props":97,"children":98},{},[99,101,110],{"type":25,"value":100},"最近，剑桥的研究团队和合作者巧妙地利用了上述方式，即虚拟实验室，在这篇论文中被称为 SDLs（Distributed Self-Driving Laboratories，分布式自动驾驶实验室 / 分布式自主实验室）刊登在 ",{"type":20,"tag":102,"props":103,"children":107},"a",{"href":104,"rel":105},"https://www.nature.com/articles/s41467-023-44599-9",[106],"nofollow",[108],{"type":25,"value":109},"Nature Journal",{"type":25,"value":111},"。",{"type":20,"tag":113,"props":114,"children":115},"img-tips",{},[116,120],{"type":20,"tag":50,"props":117,"children":119},{"src":118},"/images/info/1/1.png",[],{"type":25,"value":121},"\n图源 1 | From Platform to Knowledge Graph: Distributed Self-Driving Laboratories\nhttps://como.ceb.cam.ac.uk/media/preprints/c4e-preprint-310.pdf",{"type":20,"tag":66,"props":123,"children":124},{},[125],{"type":25,"value":126},"这和天演虹霓实验室的做法类似，通过大量的计算资源将物理实验室设备进行虚拟仿真，已达到云上开展研究和设计，同时实时共享数据可让其合作者实时观察进度和操作。",{"type":20,"tag":113,"props":128,"children":129},{},[130,134],{"type":20,"tag":50,"props":131,"children":133},{"src":132},"/images/info/1/2.png",[],{"type":25,"value":135},"\n图源 2 | 江雪虹霓实验室：为江雪和其附属团队和项目及其合作者提供计算资源和实验环境的计算平台\nhttps://gateway.hongni-lab.jiangxue.org/",{"type":20,"tag":66,"props":137,"children":138},{},[139],{"type":25,"value":140},"当然江雪的某些研究领域不像是生物、化学、物理那样需要什么样的器材和设备，江雪的主要项目更侧重计算机网络、科学等方面，因此我们只是将计算资源以及网络、环境仿真和模拟等。",{"type":20,"tag":113,"props":142,"children":143},{},[144,148],{"type":20,"tag":50,"props":145,"children":147},{"src":146},"/images/info/1/3.png",[],{"type":25,"value":149},"\n图源 3 | 根据科学家的目标请求触发自主工作流，作为在知识图谱中传播信息。\nhttps://como.ceb.cam.ac.uk/media/preprints/c4e-preprint-310.pdf",{"type":20,"tag":66,"props":151,"children":152},{},[153,155,162],{"type":25,"value":154},"像是图 3 这种直接在关系图里直接通过描述词然后让 ROG Agent 直接执行和调用的，还是很新颖的。江雪目前更多的是通过 Code 模块化的预设命令完成这种操作。感觉很像 ",{"type":20,"tag":102,"props":156,"children":159},{"href":157,"rel":158},"https://obsidian.md/",[106],[160],{"type":25,"value":161},"obsidian",{"type":25,"value":163}," 的知识图谱，通过这种方式呈现的效果感觉比看状态、日志的效果更加直观。",{"type":20,"tag":66,"props":165,"children":166},{},[167,169,176,178,185],{"type":25,"value":168},"目前，虹霓通常的架构基本上都是通过 ",{"type":20,"tag":102,"props":170,"children":173},{"href":171,"rel":172},"https://neo4j.com/",[106],[174],{"type":25,"value":175},"Neo4j",{"type":25,"value":177}," 存储和查询关系比较方便，查询速度也很快，再加上 ",{"type":20,"tag":102,"props":179,"children":182},{"href":180,"rel":181},"https://vertx.io/docs/",[106],[183],{"type":25,"value":184},"Vertx Framework",{"type":25,"value":186}," 非常适合计算数据庞大且需要经常查询的计算结果。",{"type":20,"tag":188,"props":189,"children":190},"page-tips",{},[],{"title":8,"searchDepth":192,"depth":192,"links":193},2,[],"markdown","content:work:jiangxue-joint-laboratory-luanyin-project.md","content","work/jiangxue-joint-laboratory-luanyin-project.md","md",{"_path":200,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":201,"description":202,"director":11,"types":12,"release_date":203,"demo":204,"images":205,"body":206,"_type":194,"_id":375,"_source":196,"_file":376,"_extension":198},"/work/jiangxue-tianyan-hongni-computing-platform","江雪虹霓实验室计算平台","在负责过江雪天演舆情项目后，我们发现辅助和周边服务存在较大的不足。因此，在天演舆情中，除了数据、存储、分析和研判等方面的对比外，几乎无法与在资金、人际关系和先发优势等方面具备优势的前辈个体有所差异。","2023.12.12","https://gateway.hongni-lab.jiangxue.org/","/images/pages/tianyan-compute/1.png",{"type":17,"children":207,"toc":373},[208,212,215,237,241,246,251,260,274,279,320,341,346,355,360,365,370],{"type":20,"tag":21,"props":209,"children":210},{"id":201},[211],{"type":25,"value":201},{"type":20,"tag":27,"props":213,"children":214},{},[],{"type":20,"tag":31,"props":216,"children":217},{},[218],{"type":20,"tag":35,"props":219,"children":221},{"className":220},[38],[222,223],{"type":25,"value":41},{"type":20,"tag":35,"props":224,"children":226},{"className":225},[45],[227,228,231,232,236],{"type":25,"value":48},{"type":20,"tag":50,"props":229,"children":230},{"src":205},[],{"type":25,"value":48},{"type":20,"tag":50,"props":233,"children":235},{"src":234},"/images/pages/tianyan-compute/2.png",[],{"type":25,"value":41},{"type":20,"tag":66,"props":238,"children":239},{},[240],{"type":25,"value":202},{"type":20,"tag":66,"props":242,"children":243},{},[244],{"type":25,"value":245},"为此，天演将专注于构建和完善计算资源等周边服务。在这一领域，幸运的是，很少有人涉足，而且技术难度相当大。这需要更多的时间以及更多创新性的思考和方法，以规避计算资源支出方面的问题。",{"type":20,"tag":66,"props":247,"children":248},{},[249],{"type":25,"value":250},"更令人振奋的是，这些方面与江雪天演项目的性质高度契合。通过与周边应用的对接，可以使天演项目在原本已经很优秀的基础上更具特色，并提升相关领域的门槛。",{"type":20,"tag":113,"props":252,"children":253},{},[254,258],{"type":20,"tag":50,"props":255,"children":257},{"src":256},"/images/info/2/1.png",[],{"type":25,"value":259},"\n图源 1 | 江雪天演舆情分析项目：当时在乙方场地直接拍的，看到的第一感觉是落地效果很棒，集成的数据协调和统筹系统显示起来很有电影里的感觉。\nhttps://gateway.tianyan.jiangxue.org/",{"type":20,"tag":66,"props":261,"children":262},{},[263,265,272],{"type":25,"value":264},"有趣的是，在我将 \"江雪虹霓实验室计算平台\" 发布到 Behance 不久后，我收到了一个关于 ",{"type":20,"tag":102,"props":266,"children":269},{"href":267,"rel":268},"https://www.vantagemarkets.com/en/",[106],[270],{"type":25,"value":271},"Vantage",{"type":25,"value":273}," 3D 设计师助理职位的邀请。",{"type":20,"tag":66,"props":275,"children":276},{},[277],{"type":25,"value":278},"和他们的设计师和主管聊了很久，感觉他们对设计的追求和开发的落地效果都有较高的标准。并不是像我一样构思玩设计之后，还需要进一步设计动效、交互等方面的细节。之后还需分割成一个一个的组件方便以后会用得到，有时候真觉得。",{"type":20,"tag":66,"props":280,"children":281},{},[282,284,291,293,300,302,309,311,318],{"type":25,"value":283},"如果一个人只靠设计，或许真的可以完成一个项目的前期运营和开发，而且还很快。目前流行的 ",{"type":20,"tag":102,"props":285,"children":288},{"href":286,"rel":287},"https://webflow.com/",[106],[289],{"type":25,"value":290},"Webflow",{"type":25,"value":292}," 或 ",{"type":20,"tag":102,"props":294,"children":297},{"href":295,"rel":296},"https://www.wix.com/",[106],[298],{"type":25,"value":299},"WIX",{"type":25,"value":301}," (ps: 不要问我怎么知道的，之前看朋友在用 wix ），通常是 前者作为 CMS，之后 Figma 设计、",{"type":20,"tag":102,"props":303,"children":306},{"href":304,"rel":305},"https://www.lottielab.com/",[106],[307],{"type":25,"value":308},"Lottie lab",{"type":25,"value":310}," 或者 ",{"type":20,"tag":102,"props":312,"children":315},{"href":313,"rel":314},"https://lottiefiles.com/",[106],[316],{"type":25,"value":317},"Lottiefiles",{"type":25,"value":319},"  作为动效设计。",{"type":20,"tag":66,"props":321,"children":322},{},[323,325,332,334],{"type":25,"value":324},"像是 Vantage 的设计就用到了 ",{"type":20,"tag":102,"props":326,"children":329},{"href":327,"rel":328},"https://spline.design/",[106],[330],{"type":25,"value":331},"spline",{"type":25,"value":333},"，我承认他是一个好的在线 3D 设计平台(如果不卡的话，那就更好了)；我有注意到沈毅也在做 Web 3D 设计的平台，但性能方面还是受到了 WebGPU 方面的限制。如果你有兴趣被折磨，可以尝试下 WebGPU 的光线追踪 ",{"type":20,"tag":102,"props":335,"children":338},{"href":336,"rel":337},"https://gnikoloff.github.io/webgpu-raytracer/",[106],[339],{"type":25,"value":340},"Demo",{"type":20,"tag":66,"props":342,"children":343},{},[344],{"type":25,"value":345},"总之像这些新的基于 HTML5 Canvas 2D 渲染引擎确实为设计领域增加了不少色彩（我已经不知道多久没有打开我的 Photoshop 了）",{"type":20,"tag":347,"props":348,"children":349},"page-fold",{},[350],{"type":20,"tag":66,"props":351,"children":352},{},[353],{"type":25,"value":354},"真的很馋鹅厂的设计和技术，动效、3D、特效、原画真的好看又华丽。将来如果江雪也能拥有，就更好了。",{"type":20,"tag":66,"props":356,"children":357},{},[358],{"type":25,"value":359},"但这些都不是重点，重点是：",{"type":20,"tag":66,"props":361,"children":362},{},[363],{"type":25,"value":364},"现在。江雪广泛使用由 Three.js 和 GSAP.js 构建的效果。而前的琼楼仅仅是一些基础常用需求的组件，因此在未来可能更加接近于 PAG 的引入和设计流程，从而实现与琼楼的无缝衔接，以缩短动画效果的构思时间和场景构建。",{"type":20,"tag":66,"props":366,"children":367},{},[368],{"type":25,"value":369},"虽然动效、3D、特效、原画这些江雪都没有或者有很大的缺陷，但未来也许会有。",{"type":20,"tag":188,"props":371,"children":372},{},[],{"title":8,"searchDepth":192,"depth":192,"links":374},[],"content:work:jiangxue-tianyan-hongni-computing-platform.md","work/jiangxue-tianyan-hongni-computing-platform.md",{"_path":378,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":379,"description":380,"director":11,"types":12,"release_date":381,"demo":382,"images":383,"body":384,"_type":194,"_id":557,"_source":196,"_file":558,"_extension":198},"/work/jiangxue-tianyan-internet-public-opinion-platform","江雪天演舆情分析项目","在谈及 舆情 之前、我相信有很多人会脸色一变觉得这种类似的分析项目就是普通的数据抓取和分析，甚至是直接看社交平台（含短视频平台）的数据进行反馈。","2023.08.05","https://gateway.tianyan.jiangxue.org/","/images/pages/tianyan-opinion/1.png",{"type":17,"children":385,"toc":555},[386,390,393,425,430,435,440,445,450,455,464,469,474,479,484,493,498,503,511,516,539,547,552],{"type":20,"tag":21,"props":387,"children":388},{"id":379},[389],{"type":25,"value":379},{"type":20,"tag":27,"props":391,"children":392},{},[],{"type":20,"tag":31,"props":394,"children":395},{},[396],{"type":20,"tag":35,"props":397,"children":399},{"className":398},[38],[400,401],{"type":25,"value":41},{"type":20,"tag":35,"props":402,"children":404},{"className":403},[45],[405,406,409,410,414,415,419,420,424],{"type":25,"value":48},{"type":20,"tag":50,"props":407,"children":408},{"src":383},[],{"type":25,"value":48},{"type":20,"tag":50,"props":411,"children":413},{"src":412},"/images/pages/tianyan-opinion/4.png",[],{"type":25,"value":48},{"type":20,"tag":50,"props":416,"children":418},{"src":417},"/images/pages/tianyan-opinion/2.png",[],{"type":25,"value":48},{"type":20,"tag":50,"props":421,"children":423},{"src":422},"/images/pages/tianyan-opinion/3.png",[],{"type":25,"value":41},{"type":20,"tag":66,"props":426,"children":427},{},[428],{"type":25,"value":429},"在谈及 \"舆情\" 之前，我相信很多人会在听到这种类似的分析项目时脸色一变，觉得这只是普通的数据抓取和分析，甚至认为是直接看社交平台（包括短视频平台）的数据反馈。",{"type":20,"tag":66,"props":431,"children":432},{},[433],{"type":25,"value":434},"更有甚者可能会将其与 APT 等一系列解释联系起来，这当然是 \"合理\" 的，因为所有类似冲突或事件都可以由某个 APT 组织去进行 \"引导和策划\"。而目前比较专业的领域和大规模学术级应用，更多的是由 Google 的 GDELT 项目提供支持。",{"type":20,"tag":66,"props":436,"children":437},{},[438],{"type":25,"value":439},"PS：注意这与像 Shodan 一类的资产搜索引擎不同，上述类项目针对的是更加全面的显示数据模拟和综合计算。而此类项目仅仅是针对互联网上的资产进行抓取和分析，当然。",{"type":20,"tag":66,"props":441,"children":442},{},[443],{"type":25,"value":444},"之后像是 Shodan 这类资产搜索引擎是否能关联成资产模拟、资产预判和仿真等，我就不言而喻了，也许有蛋糕可图，我相信他们也会侧重这一方向，比如换个词，叫 \"网络空间测绘\"。",{"type":20,"tag":66,"props":446,"children":447},{},[448],{"type":25,"value":449},"回到舆情中，我们会发现舆情的 English 的解释有公众情绪\\意见(Public sentiment)、公众意见(Public opinion)等，综合可进行舆论导向（Direction Of Public Opinion）、事件的模拟和计算。",{"type":20,"tag":66,"props":451,"children":452},{},[453],{"type":25,"value":454},"而目前能单从含义诠释这种需求的，更多的是流量高度集中的 Google，因此 Google 的 GDELT 项目经常作为社会科学等领域的较权威数据来源。",{"type":20,"tag":113,"props":456,"children":457},{},[458,462],{"type":20,"tag":50,"props":459,"children":461},{"src":460},"/images/info/3/1.png",[],{"type":25,"value":463},"\n图源 1 | 京畿研究院利用 GDELT 分析 1990~2020 年之间的韩中纠纷趋势：A Time Series Analysis of the Dynamics of Korea-China Relations with GDELT Data\n이성우, 민소영. (2022). 사건계수자료(GDELT)를 활용한 한 · 중 양자관계 역학 분석. 경기연구원. http://doi.org/10.18107/japs.2022.29.3.002",{"type":20,"tag":66,"props":465,"children":466},{},[467],{"type":25,"value":468},"而在中文互联网流量大量集中的百度、腾讯、阿里等厂商，分别有自己的一套分析方式。但无法像 GDELT 那样拥有世界大部分国家的数据流向，且充分完整。前者大多是输出结果，且人工修饰较为严重。",{"type":20,"tag":66,"props":470,"children":471},{},[472],{"type":25,"value":473},"但好消息是，自从字节跳动的抖音、bilibili、小红书、微博、快手、百度、微信等大流量聚集的社交、图媒体平台，逐渐让某些热点和历史数据也能成为某个领域的分析资料。因此也促成了很多类似这方面的舆情、数据分析平台的诞生。",{"type":20,"tag":66,"props":475,"children":476},{},[477],{"type":25,"value":478},"可惜的是，样本和衡量因素不多导致无法呈现真实世界生活，更多的是包装出来的效果所进行引导和牵制，产生了互联网世界和现实世界落差过大的奇怪因素。",{"type":20,"tag":66,"props":480,"children":481},{},[482],{"type":25,"value":483},"往往采用这类舆情、大数据分析平台的单位和机构所作出的决策无法满足真实需求，从而诞生矛盾和不当的决策出现。",{"type":20,"tag":113,"props":485,"children":486},{},[487,491],{"type":20,"tag":50,"props":488,"children":490},{"src":489},"/images/info/3/2.png",[],{"type":25,"value":492},"\n图源 2 | IENN Events 2023：Network Cross-Synchronization:Distributed Network Hierarchical Transmission,Jump Network\nhttp://ienn.org/TY.2.2.14314.90563/1",{"type":20,"tag":66,"props":494,"children":495},{},[496],{"type":25,"value":497},"因此，在 IENN 2023 中，我分享了未来天演的规划和架构设计，以及全新的设计体系和底层设计架构。以避免天演出现上述的问题，将侧重点放在了存储和计算中。",{"type":20,"tag":66,"props":499,"children":500},{},[501],{"type":25,"value":502},"如果要对个体间进行分析，最好的方式就是让其还未知道的情况进行分析。从这种单向的方式可以获取到较为高质量的元数据，从而不被非个体和环境进行引导和左右。",{"type":20,"tag":113,"props":504,"children":505},{},[506,510],{"type":20,"tag":50,"props":507,"children":509},{"src":508},"/images/info/3/3.png",[],{"type":25,"value":492},{"type":20,"tag":66,"props":512,"children":513},{},[514],{"type":25,"value":515},"之后，天演主要会兼顾舆情和数据分析的同时，结合空间测绘来进行主动信息分析，提前将事态进行分析和演算的目的。因此，天演之后的格言是：\"DETECT\"、\"PROTECT\" 即侦查、和保护。",{"type":20,"tag":66,"props":517,"children":518},{},[519,521,528,530,537],{"type":25,"value":520},"自从看了 ",{"type":20,"tag":102,"props":522,"children":525},{"href":523,"rel":524},"https://www.raykite.com/",[106],[526],{"type":25,"value":527},"RAYKITE 光起源",{"type":25,"value":529}," 发布会之后，我惊叹于 ",{"type":20,"tag":102,"props":531,"children":534},{"href":532,"rel":533},"https://www.ventuz.com/",[106],[535],{"type":25,"value":536},"Ventuz Tech",{"type":25,"value":538}," 的大规模应用。阿里曾经想通过 Unity 去驱动数据可视化大屏，但落地效果并不是很理想（比较卡顿）但通过 Ventuz 做出来的效果非常 niubility 给力（可能是 Unreal Engine 独天得厚的特性吧） 。",{"type":20,"tag":347,"props":540,"children":541},{},[542],{"type":20,"tag":66,"props":543,"children":544},{},[545],{"type":25,"value":546},"有时候真的挺崩溃的，有 Tencent 这么厉害的势力，基本上让人看不到希望。",{"type":20,"tag":66,"props":548,"children":549},{},[550],{"type":25,"value":551},"所以之后天演也将刨除现在的技术架构，将数据之间的传输和存储独立于基础交换方式，以更好的和 Ventuz 构建数据之间的传递。（主要是设计资源比较花时间）",{"type":20,"tag":188,"props":553,"children":554},{},[],{"title":8,"searchDepth":192,"depth":192,"links":556},[],"content:work:jiangxue-tianyan-internet-public-opinion-platform.md","work/jiangxue-tianyan-internet-public-opinion-platform.md",{"_path":560,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":561,"description":562,"director":11,"types":563,"release_date":564,"demo":565,"images":566,"body":567,"_type":194,"_id":731,"_source":196,"_file":732,"_extension":198},"/work/to-web3-navigation","To Web3","帮朋友设计的一个项目，采用了大量二次元设计元素和呈现方式，主打ACG。然而，时隔一年发现该项目仍然停滞不前，甚至域名都尚未购买。","DESIGN","2023.09.27","#in develop","/images/pages/to-web3/1.png",{"type":17,"children":568,"toc":729},[569,575,578,605,610,615,620,625,630,635,640,645,650,655,660,669,674,679,684,701,706,711,716,721,726],{"type":20,"tag":21,"props":570,"children":572},{"id":571},"to-web3-navigate",[573],{"type":25,"value":574},"To Web3 navigate",{"type":20,"tag":27,"props":576,"children":577},{},[],{"type":20,"tag":31,"props":579,"children":580},{},[581],{"type":20,"tag":35,"props":582,"children":584},{"className":583},[38],[585,586],{"type":25,"value":41},{"type":20,"tag":35,"props":587,"children":589},{"className":588},[45],[590,591,594,595,599,600,604],{"type":25,"value":48},{"type":20,"tag":50,"props":592,"children":593},{"src":566},[],{"type":25,"value":48},{"type":20,"tag":50,"props":596,"children":598},{"src":597},"/images/pages/to-web3/2.png",[],{"type":25,"value":48},{"type":20,"tag":50,"props":601,"children":603},{"src":602},"/images/pages/to-web3/3.png",[],{"type":25,"value":41},{"type":20,"tag":66,"props":606,"children":607},{},[608],{"type":25,"value":609},"帮朋友设计的一个项目，采用了大量二刺螈设计元素和呈现方式，主打一个 ACG。然而，时隔一年发现该项目仍然停滞不前，甚至域名都尚未购买。",{"type":20,"tag":66,"props":611,"children":612},{},[613],{"type":25,"value":614},"因此，在今天即将发布这篇 blogpost 文章之前，我巧妙地促使他购买了一个域名（我也不知道为什么要在博客文章封面前加入项目预览，可能是为了更美观吧）。",{"type":20,"tag":66,"props":616,"children":617},{},[618],{"type":25,"value":619},"有时候真的会感到惋惜，缺乏行动力和执行力真的会导致项目的停滞和持续的不温不火。",{"type":20,"tag":66,"props":621,"children":622},{},[623],{"type":25,"value":624},"还记得去年 TA 的 web3frelance，也是在开年之际而进行设计，于是到了今年依然还在仓库里躺着。",{"type":20,"tag":66,"props":626,"children":627},{},[628],{"type":25,"value":629},"说到 To web3。TA 本质上是一个导航。但又与常见的像是 Wordpress 这种弄出来的导航不同；可以理解为更不一样或者更有风格。",{"type":20,"tag":66,"props":631,"children":632},{},[633],{"type":25,"value":634},"然而，这种方式也有弊端，即显得与其他同类型的 WordPress 导航站或者“自定义设计”的导航站格格不入。因为它的风格太过突出，更多的是传达理念和调性，而不是为了推广其他网站或内容。",{"type":20,"tag":66,"props":636,"children":637},{},[638],{"type":25,"value":639},"导航离不开推广，就像西方世界离不开耶路撒冷一样。",{"type":20,"tag":66,"props":641,"children":642},{},[643],{"type":25,"value":644},"由于导航的性质，可以将微小的流量集中起来，然后进行私域扩展，从而发展客户和引流推广等。",{"type":20,"tag":66,"props":646,"children":647},{},[648],{"type":25,"value":649},"所以与其说是格格不入，更多的是因为设计风格太过突出，导致无法与同类型的用户流量产生“磨合”。",{"type":20,"tag":66,"props":651,"children":652},{},[653],{"type":25,"value":654},"简而言之，风格太重，用户无法理解或没有接触过。他们更需要像那些使用 WordPress 模板的，因为形成了统一性，所以新的风格出现显得不太协调，用户接受度不高。",{"type":20,"tag":66,"props":656,"children":657},{},[658],{"type":25,"value":659},"这就需要运营时要找对需求而并不是广撒网，需要的流量群体质量越高，那么也就需要付出其对应的时间来弥补。",{"type":20,"tag":113,"props":661,"children":662},{},[663,667],{"type":20,"tag":50,"props":664,"children":666},{"src":665},"/images/info/4/1.png",[],{"type":25,"value":668},"\n图源 1 | 利用 Stable Diffusion 生成的虚拟动漫人物(稍加少量修改和装饰) https://github.com/AUTOMATIC1111/stable-diffusion-webui",{"type":20,"tag":66,"props":670,"children":671},{},[672],{"type":25,"value":673},"说到这个设计的出发点其实挺有趣的，因为 TA 是米哈游出来的，所以当时想的是：\"干翻米哈游！\" 的目的去着手弄的。",{"type":20,"tag":66,"props":675,"children":676},{},[677],{"type":25,"value":678},"而这个二刺螈人物是我上一年通过 Stable Diffusion 生成出来的。说实话当时的 AICG 还没有像是现在 2023 年这样发达或快速破圈，更多的是小圈子里讨论和应用。",{"type":20,"tag":66,"props":680,"children":681},{},[682],{"type":25,"value":683},"生成出来的角色手部、裙子和脸有了很多问题所以当时我用数位板进行了稍微地结构性的调整了一下。",{"type":20,"tag":113,"props":685,"children":686},{},[687,699],{"type":20,"tag":688,"props":689,"children":691},"video",{"controls":690},true,[692,693],{"type":25,"value":41},{"type":20,"tag":694,"props":695,"children":698},"source",{"src":696,"type":697},"/images/info/4/2.mp4","video/mp4",[],{"type":25,"value":700},"\n视频 1 | 通过对现实世界歌手声音的提取 AI 二次优化和模拟@江雪銮音实验室 https://music.163.com/song?id=2075128378&userid=1548171212",{"type":20,"tag":66,"props":702,"children":703},{},[704],{"type":25,"value":705},"现在 AICG 已经发展成图片、视频甚至声音、音乐等方面的应用。当然，在设计、艺术领域以及一些小圈子里，有一些对AI创作的抵制声音。",{"type":20,"tag":66,"props":707,"children":708},{},[709],{"type":25,"value":710},"不过我并不是专门从事设计和艺术方面工作的，所以我对 AICG 的看法其实一直很乐观。我想的是会不会衍生新的工作和研究方向出来，也就是通过类似图片隐写等方式，向你 Stable Diffusion 投毒。",{"type":20,"tag":66,"props":712,"children":713},{},[714],{"type":25,"value":715},"加上目前国内外有大量的狂热爱好者，这是一个可观的数量。",{"type":20,"tag":66,"props":717,"children":718},{},[719],{"type":25,"value":720},"还记得当时新能源在汽车领域广泛应用之前，有很多做工控安全的同仁转战新能源汽车安全，去众筹买电车然后一起做测试和研究。",{"type":20,"tag":66,"props":722,"children":723},{},[724],{"type":25,"value":725},"现在都已经成为了一方大佬，依然活跃在安全一线。",{"type":20,"tag":188,"props":727,"children":728},{},[],{"title":8,"searchDepth":192,"depth":192,"links":730},[],"content:work:to-web3-navigation.md","work/to-web3-navigation.md",{"_path":5,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":9,"description":10,"director":11,"types":12,"release_date":13,"demo":14,"images":15,"body":734,"_type":194,"_id":195,"_source":196,"_file":197,"_extension":198},{"type":17,"children":735,"toc":860},[736,740,743,768,772,776,780,784,788,792,802,809,813,820,824,831,841,857],{"type":20,"tag":21,"props":737,"children":738},{"id":9},[739],{"type":25,"value":9},{"type":20,"tag":27,"props":741,"children":742},{},[],{"type":20,"tag":31,"props":744,"children":745},{},[746],{"type":20,"tag":35,"props":747,"children":749},{"className":748},[38],[750,751],{"type":25,"value":41},{"type":20,"tag":35,"props":752,"children":754},{"className":753},[45],[755,756,759,760,763,764,767],{"type":25,"value":48},{"type":20,"tag":50,"props":757,"children":758},{"src":52},[],{"type":25,"value":48},{"type":20,"tag":50,"props":761,"children":762},{"src":57},[],{"type":25,"value":48},{"type":20,"tag":50,"props":765,"children":766},{"src":62},[],{"type":25,"value":41},{"type":20,"tag":66,"props":769,"children":770},{},[771],{"type":25,"value":70},{"type":20,"tag":66,"props":773,"children":774},{},[775],{"type":25,"value":75},{"type":20,"tag":66,"props":777,"children":778},{},[779],{"type":25,"value":80},{"type":20,"tag":66,"props":781,"children":782},{},[783],{"type":25,"value":85},{"type":20,"tag":66,"props":785,"children":786},{},[787],{"type":25,"value":90},{"type":20,"tag":66,"props":789,"children":790},{},[791],{"type":25,"value":95},{"type":20,"tag":66,"props":793,"children":794},{},[795,796,801],{"type":25,"value":100},{"type":20,"tag":102,"props":797,"children":799},{"href":104,"rel":798},[106],[800],{"type":25,"value":109},{"type":25,"value":111},{"type":20,"tag":113,"props":803,"children":804},{},[805,808],{"type":20,"tag":50,"props":806,"children":807},{"src":118},[],{"type":25,"value":121},{"type":20,"tag":66,"props":810,"children":811},{},[812],{"type":25,"value":126},{"type":20,"tag":113,"props":814,"children":815},{},[816,819],{"type":20,"tag":50,"props":817,"children":818},{"src":132},[],{"type":25,"value":135},{"type":20,"tag":66,"props":821,"children":822},{},[823],{"type":25,"value":140},{"type":20,"tag":113,"props":825,"children":826},{},[827,830],{"type":20,"tag":50,"props":828,"children":829},{"src":146},[],{"type":25,"value":149},{"type":20,"tag":66,"props":832,"children":833},{},[834,835,840],{"type":25,"value":154},{"type":20,"tag":102,"props":836,"children":838},{"href":157,"rel":837},[106],[839],{"type":25,"value":161},{"type":25,"value":163},{"type":20,"tag":66,"props":842,"children":843},{},[844,845,850,851,856],{"type":25,"value":168},{"type":20,"tag":102,"props":846,"children":848},{"href":171,"rel":847},[106],[849],{"type":25,"value":175},{"type":25,"value":177},{"type":20,"tag":102,"props":852,"children":854},{"href":180,"rel":853},[106],[855],{"type":25,"value":184},{"type":25,"value":186},{"type":20,"tag":188,"props":858,"children":859},{},[],{"title":8,"searchDepth":192,"depth":192,"links":861},[],1706606380509]