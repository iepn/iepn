[{"data":1,"prerenderedAt":201},["Reactive",2],{"content-query-DfKPG2rPzT":3},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"director":10,"types":11,"release_date":12,"demo":13,"images":14,"body":15,"_type":196,"_id":197,"_source":198,"_file":199,"_extension":200},"/work/to-web3-navigation","work",false,"","To Web3","帮朋友设计的一个项目，采用了大量二次元设计元素和呈现方式，主打ACG。然而，时隔一年发现该项目仍然停滞不前，甚至域名都尚未购买。","RHYME.Q","DESIGN","2023.09.27","#IN DEVELOPMENT","/images/pages/to-web3/1.png",{"type":16,"children":17,"toc":193},"root",[18,27,31,65,71,76,81,86,91,96,101,106,111,116,121,131,136,141,146,164,169,174,179,184,189],{"type":19,"tag":20,"props":21,"children":23},"element","h1",{"id":22},"to-web3-navigate",[24],{"type":25,"value":26},"text","To Web3 navigate",{"type":19,"tag":28,"props":29,"children":30},"page-back",{},[],{"type":19,"tag":32,"props":33,"children":34},"page-img",{},[35],{"type":19,"tag":36,"props":37,"children":40},"div",{"className":38},[39],"slider",[41,43],{"type":25,"value":42},"\n  ",{"type":19,"tag":36,"props":44,"children":47},{"className":45},[46],"slides",[48,50,54,55,59,60,64],{"type":25,"value":49},"\n      ",{"type":19,"tag":51,"props":52,"children":53},"img",{"src":14},[],{"type":25,"value":49},{"type":19,"tag":51,"props":56,"children":58},{"src":57},"/images/pages/to-web3/2.png",[],{"type":25,"value":49},{"type":19,"tag":51,"props":61,"children":63},{"src":62},"/images/pages/to-web3/3.png",[],{"type":25,"value":42},{"type":19,"tag":66,"props":67,"children":68},"p",{},[69],{"type":25,"value":70},"帮朋友设计的一个项目，采用了大量二刺螈设计元素和呈现方式，主打一个 ACG。然而，时隔一年发现该项目仍然停滞不前，甚至域名都尚未购买。",{"type":19,"tag":66,"props":72,"children":73},{},[74],{"type":25,"value":75},"因此，在今天即将发布这篇 blogpost 文章之前，我巧妙地促使他购买了一个域名（我也不知道为什么要在博客文章封面前加入项目预览，可能是为了更美观吧）。",{"type":19,"tag":66,"props":77,"children":78},{},[79],{"type":25,"value":80},"有时候真的会感到惋惜，缺乏行动力和执行力真的会导致项目的停滞和持续的不温不火。",{"type":19,"tag":66,"props":82,"children":83},{},[84],{"type":25,"value":85},"还记得去年 TA 的 web3frelance，也是在开年之际而进行设计，于是到了今年依然还在仓库里躺着。",{"type":19,"tag":66,"props":87,"children":88},{},[89],{"type":25,"value":90},"说到 To web3。TA 本质上是一个导航。但又与常见的像是 Wordpress 这种弄出来的导航不同；可以理解为更不一样或者更有风格。",{"type":19,"tag":66,"props":92,"children":93},{},[94],{"type":25,"value":95},"然而，这种方式也有弊端，即显得与其他同类型的 WordPress 导航站或者“自定义设计”的导航站格格不入。因为它的风格太过突出，更多的是传达理念和调性，而不是为了推广其他网站或内容。",{"type":19,"tag":66,"props":97,"children":98},{},[99],{"type":25,"value":100},"导航离不开推广，就像西方世界离不开耶路撒冷一样。",{"type":19,"tag":66,"props":102,"children":103},{},[104],{"type":25,"value":105},"由于导航的性质，可以将微小的流量集中起来，然后进行私域扩展，从而发展客户和引流推广等。",{"type":19,"tag":66,"props":107,"children":108},{},[109],{"type":25,"value":110},"所以与其说是格格不入，更多的是因为设计风格太过突出，导致无法与同类型的用户流量产生“磨合”。",{"type":19,"tag":66,"props":112,"children":113},{},[114],{"type":25,"value":115},"简而言之，风格太重，用户无法理解或没有接触过。他们更需要像那些使用 WordPress 模板的，因为形成了统一性，所以新的风格出现显得不太协调，用户接受度不高。",{"type":19,"tag":66,"props":117,"children":118},{},[119],{"type":25,"value":120},"这就需要运营时要找对需求而并不是广撒网，需要的流量群体质量越高，那么也就需要付出其对应的时间来弥补。",{"type":19,"tag":122,"props":123,"children":124},"img-tips",{},[125,129],{"type":19,"tag":51,"props":126,"children":128},{"src":127},"/images/info/4/1.png",[],{"type":25,"value":130},"\n图源 1 | 利用 Stable Diffusion 生成的虚拟动漫人物(稍加少量修改和装饰) https://github.com/AUTOMATIC1111/stable-diffusion-webui",{"type":19,"tag":66,"props":132,"children":133},{},[134],{"type":25,"value":135},"说到这个设计的出发点其实挺有趣的，因为 TA 是米哈游出来的，所以当时想的是：\"干翻米哈游！\" 的目的去着手弄的。",{"type":19,"tag":66,"props":137,"children":138},{},[139],{"type":25,"value":140},"而这个二刺螈人物是我上一年通过 Stable Diffusion 生成出来的。说实话当时的 AICG 还没有像是现在 2023 年这样发达或快速破圈，更多的是小圈子里讨论和应用。",{"type":19,"tag":66,"props":142,"children":143},{},[144],{"type":25,"value":145},"生成出来的角色手部、裙子和脸有了很多问题所以当时我用数位板进行了稍微地结构性的调整了一下。",{"type":19,"tag":122,"props":147,"children":148},{},[149,162],{"type":19,"tag":36,"props":150,"children":152},{"style":151},"padding:56.25% 0 0 0;position:relative;",[153],{"type":19,"tag":154,"props":155,"children":161},"iframe",{"src":156,"frameBorder":157,"allow":158,"style":159,"title":160},"https://player.vimeo.com/video/910286322?badge=0&autopause=0&player_id=0&app_id=58479","0","autoplay; fullscreen; picture-in-picture","position:absolute;top:0;left:0;width:100%;height:100%;","現実世界の歌手の声抽出による AI 二次最適化とシミュレーション",[],{"type":25,"value":163},"\n视频 1 | 通过对现实世界歌手声音的提取 AI 二次优化和模拟@江雪銮音实验室 https://music.163.com/song?id=2075128378&userid=1548171212",{"type":19,"tag":66,"props":165,"children":166},{},[167],{"type":25,"value":168},"现在 AICG 已经发展成图片、视频甚至声音、音乐等方面的应用。当然，在设计、艺术领域以及一些小圈子里，有一些对AI创作的抵制声音。",{"type":19,"tag":66,"props":170,"children":171},{},[172],{"type":25,"value":173},"不过我并不是专门从事设计和艺术方面工作的，所以我对 AICG 的看法其实一直很乐观。我想的是会不会衍生新的工作和研究方向出来，也就是通过类似图片隐写等方式，向你 Stable Diffusion 投毒。",{"type":19,"tag":66,"props":175,"children":176},{},[177],{"type":25,"value":178},"加上目前国内外有大量的狂热爱好者，这是一个可观的数量。",{"type":19,"tag":66,"props":180,"children":181},{},[182],{"type":25,"value":183},"还记得当时新能源在汽车领域广泛应用之前，有很多做工控安全的同仁转战新能源汽车安全，去众筹买电车然后一起做测试和研究。",{"type":19,"tag":66,"props":185,"children":186},{},[187],{"type":25,"value":188},"现在都已经成为了一方大佬，依然活跃在安全一线。",{"type":19,"tag":190,"props":191,"children":192},"page-tips",{},[],{"title":7,"searchDepth":194,"depth":194,"links":195},2,[],"markdown","content:work:to-web3-navigation.md","content","work/to-web3-navigation.md","md",1708477341555]