[{"data":1,"prerenderedAt":207},["Reactive",2],{"content-query-ZTIFJVXuNe":3},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"director":10,"types":11,"release_date":12,"demo":13,"images":14,"body":15,"_type":202,"_id":203,"_source":204,"_file":205,"_extension":206},"/work/jiangxue-tianyan-hongni-computing-platform","work",false,"","江雪虹霓实验室计算平台","在负责过江雪天演舆情项目后，我们发现辅助和周边服务存在较大的不足。因此，在天演舆情中，除了数据、存储、分析和研判等方面的对比外，几乎无法与在资金、人际关系和先发优势等方面具备优势的前辈个体有所差异。","RHYME.Q","RESEARCH","2023.12.12","https://gateway.hongni-lab.jiangxue.org/","/images/pages/tianyan-compute/1.png",{"type":16,"children":17,"toc":199},"root",[18,25,29,58,63,68,73,83,99,104,145,166,171,180,185,190,195],{"type":19,"tag":20,"props":21,"children":22},"element","h1",{"id":8},[23],{"type":24,"value":8},"text",{"type":19,"tag":26,"props":27,"children":28},"page-back",{},[],{"type":19,"tag":30,"props":31,"children":32},"page-img",{},[33],{"type":19,"tag":34,"props":35,"children":38},"div",{"className":36},[37],"slider",[39,41],{"type":24,"value":40},"\n  ",{"type":19,"tag":34,"props":42,"children":45},{"className":43},[44],"slides",[46,48,52,53,57],{"type":24,"value":47},"\n      ",{"type":19,"tag":49,"props":50,"children":51},"img",{"src":14},[],{"type":24,"value":47},{"type":19,"tag":49,"props":54,"children":56},{"src":55},"/images/pages/tianyan-compute/2.png",[],{"type":24,"value":40},{"type":19,"tag":59,"props":60,"children":61},"p",{},[62],{"type":24,"value":9},{"type":19,"tag":59,"props":64,"children":65},{},[66],{"type":24,"value":67},"为此，天演将专注于构建和完善计算资源等周边服务。在这一领域，幸运的是，很少有人涉足，而且技术难度相当大。这需要更多的时间以及更多创新性的思考和方法，以规避计算资源支出方面的问题。",{"type":19,"tag":59,"props":69,"children":70},{},[71],{"type":24,"value":72},"更令人振奋的是，这些方面与江雪天演项目的性质高度契合。通过与周边应用的对接，可以使天演项目在原本已经很优秀的基础上更具特色，并提升相关领域的门槛。",{"type":19,"tag":74,"props":75,"children":76},"img-tips",{},[77,81],{"type":19,"tag":49,"props":78,"children":80},{"src":79},"/images/info/2/1.png",[],{"type":24,"value":82},"\n图源 1 | 江雪天演舆情分析项目：当时在乙方场地直接拍的，看到的第一感觉是落地效果很棒，集成的数据协调和统筹系统显示起来很有电影里的感觉。\nhttps://gateway.tianyan.jiangxue.org/",{"type":19,"tag":59,"props":84,"children":85},{},[86,88,97],{"type":24,"value":87},"有趣的是，在我将 \"江雪虹霓实验室计算平台\" 发布到 Behance 不久后，我收到了一个关于 ",{"type":19,"tag":89,"props":90,"children":94},"a",{"href":91,"rel":92},"https://www.vantagemarkets.com/en/",[93],"nofollow",[95],{"type":24,"value":96},"Vantage",{"type":24,"value":98}," 3D 设计师助理职位的邀请。",{"type":19,"tag":59,"props":100,"children":101},{},[102],{"type":24,"value":103},"和他们的设计师和主管聊了很久，感觉他们对设计的追求和开发的落地效果都有较高的标准。并不是像我一样构思玩设计之后，还需要进一步设计动效、交互等方面的细节。之后还需分割成一个一个的组件方便以后会用得到，有时候真觉得。",{"type":19,"tag":59,"props":105,"children":106},{},[107,109,116,118,125,127,134,136,143],{"type":24,"value":108},"如果一个人只靠设计，或许真的可以完成一个项目的前期运营和开发，而且还很快。目前流行的 ",{"type":19,"tag":89,"props":110,"children":113},{"href":111,"rel":112},"https://webflow.com/",[93],[114],{"type":24,"value":115},"Webflow",{"type":24,"value":117}," 或 ",{"type":19,"tag":89,"props":119,"children":122},{"href":120,"rel":121},"https://www.wix.com/",[93],[123],{"type":24,"value":124},"WIX",{"type":24,"value":126}," (ps: 不要问我怎么知道的，之前看朋友在用 wix ），通常是 前者作为 CMS，之后 Figma 设计、",{"type":19,"tag":89,"props":128,"children":131},{"href":129,"rel":130},"https://www.lottielab.com/",[93],[132],{"type":24,"value":133},"Lottie lab",{"type":24,"value":135}," 或者 ",{"type":19,"tag":89,"props":137,"children":140},{"href":138,"rel":139},"https://lottiefiles.com/",[93],[141],{"type":24,"value":142},"Lottiefiles",{"type":24,"value":144},"  作为动效设计。",{"type":19,"tag":59,"props":146,"children":147},{},[148,150,157,159],{"type":24,"value":149},"像是 Vantage 的设计就用到了 ",{"type":19,"tag":89,"props":151,"children":154},{"href":152,"rel":153},"https://spline.design/",[93],[155],{"type":24,"value":156},"spline",{"type":24,"value":158},"，我承认他是一个好的在线 3D 设计平台(如果不卡的话，那就更好了)；我有注意到沈毅也在做 Web 3D 设计的平台，但性能方面还是受到了 WebGPU 方面的限制。如果你有兴趣被折磨，可以尝试下 WebGPU 的光线追踪 ",{"type":19,"tag":89,"props":160,"children":163},{"href":161,"rel":162},"https://gnikoloff.github.io/webgpu-raytracer/",[93],[164],{"type":24,"value":165},"Demo",{"type":19,"tag":59,"props":167,"children":168},{},[169],{"type":24,"value":170},"总之像这些新的基于 HTML5 Canvas 2D 渲染引擎确实为设计领域增加了不少色彩（我已经不知道多久没有打开我的 Photoshop 了）",{"type":19,"tag":172,"props":173,"children":174},"page-fold",{},[175],{"type":19,"tag":59,"props":176,"children":177},{},[178],{"type":24,"value":179},"真的很馋鹅厂的设计和技术，动效、3D、特效、原画真的好看又华丽。将来如果江雪也能拥有，就更好了。",{"type":19,"tag":59,"props":181,"children":182},{},[183],{"type":24,"value":184},"但这些都不是重点，重点是：",{"type":19,"tag":59,"props":186,"children":187},{},[188],{"type":24,"value":189},"现在。江雪广泛使用由 Three.js 和 GSAP.js 构建的效果。而前的琼楼仅仅是一些基础常用需求的组件，因此在未来可能更加接近于 PAG 的引入和设计流程，从而实现与琼楼的无缝衔接，以缩短动画效果的构思时间和场景构建。",{"type":19,"tag":59,"props":191,"children":192},{},[193],{"type":24,"value":194},"虽然动效、3D、特效、原画这些江雪都没有或者有很大的缺陷，但未来也许会有。",{"type":19,"tag":196,"props":197,"children":198},"page-tips",{},[],{"title":7,"searchDepth":200,"depth":200,"links":201},2,[],"markdown","content:work:jiangxue-tianyan-hongni-computing-platform.md","content","work/jiangxue-tianyan-hongni-computing-platform.md","md",1709408582748]