[{"data":1,"prerenderedAt":170},["Reactive",2],{"content-query-ZTIFJVXuNe":3},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":9,"director":10,"types":11,"release_date":12,"demo":13,"images":14,"body":15,"_type":165,"_id":166,"_source":167,"_file":168,"_extension":169},"/work/jiangxue-tianyan-hongni-computing-platform","work",false,"","江雪虹霓实验室计算平台","在负责过江雪天演舆情项目后，我们发现辅助和周边服务存在较大的不足。因此，在天演舆情中，除了数据、存储、分析和研判等方面的对比外，几乎无法与在资金、人际关系和先发优势等方面具备优势的前辈个体有所差异。","RHYME.Q","RESEARCH","2023.12.12","https://gateway.hongni-lab.jiangxue.org/","/images/pages/tianyan-compute/1.png",{"type":16,"children":17,"toc":162},"root",[18,24,30,35,40,46,62,67,108,129,134,143,148,153,158],{"type":19,"tag":20,"props":21,"children":23},"element","page-img",{"img":22,"title":8},"tianyan-compute/1,tianyan-compute/2",[],{"type":19,"tag":25,"props":26,"children":27},"p",{},[28],{"type":29,"value":9},"text",{"type":19,"tag":25,"props":31,"children":32},{},[33],{"type":29,"value":34},"为此，天演将专注于构建和完善计算资源等周边服务。在这一领域，幸运的是，很少有人涉足，而且技术难度相当大。这需要更多的时间以及更多创新性的思考和方法，以规避计算资源支出方面的问题。",{"type":19,"tag":25,"props":36,"children":37},{},[38],{"type":29,"value":39},"更令人振奋的是，这些方面与江雪天演项目的性质高度契合。通过与周边应用的对接，可以使天演项目在原本已经很优秀的基础上更具特色，并提升相关领域的门槛。",{"type":19,"tag":41,"props":42,"children":45},"text-space",{"img":43,"info":44},"2/1","图源 1 | 江雪天演舆情分析项目：当时在乙方场地直接拍的，看到的第一感觉是落地效果很棒，集成的数据协调和统筹系统显示起来很有电影里的感觉。\u003Cbr/>https://gateway.tianyan.jiangxue.org/",[],{"type":19,"tag":25,"props":47,"children":48},{},[49,51,60],{"type":29,"value":50},"有趣的是，在我将 \"江雪虹霓实验室计算平台\" 发布到 Behance 不久后，我收到了一个关于 ",{"type":19,"tag":52,"props":53,"children":57},"a",{"href":54,"rel":55},"https://www.vantagemarkets.com/en/",[56],"nofollow",[58],{"type":29,"value":59},"Vantage",{"type":29,"value":61}," 3D 设计师助理职位的邀请。",{"type":19,"tag":25,"props":63,"children":64},{},[65],{"type":29,"value":66},"和他们的设计师和主管聊了很久，感觉他们对设计的追求和开发的落地效果都有较高的标准。并不是像我一样构思玩设计之后，还需要进一步设计动效、交互等方面的细节。之后还需分割成一个一个的组件方便以后会用得到，有时候真觉得。",{"type":19,"tag":25,"props":68,"children":69},{},[70,72,79,81,88,90,97,99,106],{"type":29,"value":71},"如果一个人只靠设计，或许真的可以完成一个项目的前期运营和开发，而且还很快。目前流行的 ",{"type":19,"tag":52,"props":73,"children":76},{"href":74,"rel":75},"https://webflow.com/",[56],[77],{"type":29,"value":78},"Webflow",{"type":29,"value":80}," 或 ",{"type":19,"tag":52,"props":82,"children":85},{"href":83,"rel":84},"https://www.wix.com/",[56],[86],{"type":29,"value":87},"WIX",{"type":29,"value":89}," (ps: 不要问我怎么知道的，之前看朋友在用 wix ），通常是 前者作为 CMS，之后 Figma 设计、",{"type":19,"tag":52,"props":91,"children":94},{"href":92,"rel":93},"https://www.lottielab.com/",[56],[95],{"type":29,"value":96},"Lottie lab",{"type":29,"value":98}," 或者 ",{"type":19,"tag":52,"props":100,"children":103},{"href":101,"rel":102},"https://lottiefiles.com/",[56],[104],{"type":29,"value":105},"Lottiefiles",{"type":29,"value":107},"  作为动效设计。",{"type":19,"tag":25,"props":109,"children":110},{},[111,113,120,122],{"type":29,"value":112},"像是 Vantage 的设计就用到了 ",{"type":19,"tag":52,"props":114,"children":117},{"href":115,"rel":116},"https://spline.design/",[56],[118],{"type":29,"value":119},"spline",{"type":29,"value":121},"，我承认他是一个好的在线 3D 设计平台(如果不卡的话，那就更好了)；我有注意到沈毅也在做 Web 3D 设计的平台，但性能方面还是受到了 WebGPU 方面的限制。如果你有兴趣被折磨，可以尝试下 WebGPU 的光线追踪 ",{"type":19,"tag":52,"props":123,"children":126},{"href":124,"rel":125},"https://gnikoloff.github.io/webgpu-raytracer/",[56],[127],{"type":29,"value":128},"Demo",{"type":19,"tag":25,"props":130,"children":131},{},[132],{"type":29,"value":133},"总之像这些新的基于 HTML5 Canvas 2D 渲染引擎确实为设计领域增加了不少色彩（我已经不知道多久没有打开我的 Photoshop 了）",{"type":19,"tag":135,"props":136,"children":137},"page-fold",{},[138],{"type":19,"tag":25,"props":139,"children":140},{},[141],{"type":29,"value":142},"真的很馋鹅厂的设计和技术，动效、3D、特效、原画真的好看又华丽。将来如果江雪也能拥有，就更好了。",{"type":19,"tag":25,"props":144,"children":145},{},[146],{"type":29,"value":147},"但这些都不是重点，重点是：",{"type":19,"tag":25,"props":149,"children":150},{},[151],{"type":29,"value":152},"现在。江雪广泛使用由 Three.js 和 GSAP.js 构建的效果。而前的琼楼仅仅是一些基础常用需求的组件，因此在未来可能更加接近于 PAG 的引入和设计流程，从而实现与琼楼的无缝衔接，以缩短动画效果的构思时间和场景构建。",{"type":19,"tag":25,"props":154,"children":155},{},[156],{"type":29,"value":157},"虽然动效、3D、特效、原画这些江雪都没有或者有很大的缺陷，但未来也许会有。",{"type":19,"tag":159,"props":160,"children":161},"page-tips",{},[],{"title":7,"searchDepth":163,"depth":163,"links":164},2,[],"markdown","content:work:jiangxue-tianyan-hongni-computing-platform.md","content","work/jiangxue-tianyan-hongni-computing-platform.md","md",1711150942979]