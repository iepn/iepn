[{"data":1,"prerenderedAt":1231},["Reactive",2],{"equal":3,"content-query-1DxZ1vYQk5":1191},[4,261,436,614,789,971],{"_path":5,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":9,"description":10,"director":11,"types":12,"release_date":13,"demo":14,"images":15,"body":16,"_type":256,"_id":257,"_source":258,"_file":259,"_extension":260},"/work/jiangxue-myung-api-security-project","work",false,"","Myung","我为此设计了一个看起来非常典雅的 Logo，尤其是那个红色印章显得富有文化底蕴。最初，我想将它命名为明，寓意点亮未来的道路。后来，我又想为它赋予一个充满潜力的理念。","RHYME.Q","SECURITY","2024.01.31","#in development","/images/pages/myung/1.png",{"type":17,"children":18,"toc":253},"root",[19,27,31,60,66,71,76,81,86,91,96,101,106,111,127,132,137,142,147,152,162,167,172,181,186,195,200,205,210,215,220,225,230,239,244,249],{"type":20,"tag":21,"props":22,"children":24},"element","h1",{"id":23},"myung",[25],{"type":26,"value":9},"text",{"type":20,"tag":28,"props":29,"children":30},"page-back",{},[],{"type":20,"tag":32,"props":33,"children":34},"page-img",{},[35],{"type":20,"tag":36,"props":37,"children":40},"div",{"className":38},[39],"slider",[41,43],{"type":26,"value":42},"\n  ",{"type":20,"tag":36,"props":44,"children":47},{"className":45},[46],"slides",[48,50,54,55,59],{"type":26,"value":49},"\n      ",{"type":20,"tag":51,"props":52,"children":53},"img",{"src":15},[],{"type":26,"value":49},{"type":20,"tag":51,"props":56,"children":58},{"src":57},"/images/pages/myung/2.png",[],{"type":26,"value":42},{"type":20,"tag":61,"props":62,"children":63},"p",{},[64],{"type":26,"value":65},"我为此设计了一个看起来非常典雅的 Logo，尤其是那个红色印章显得富有文化底蕴。最初，我想将它命名为 \"明\"，寓意点亮未来的道路。后来，我又想为它赋予一个充满潜力的理念。",{"type":20,"tag":61,"props":67,"children":68},{},[69],{"type":26,"value":70},"虽然还没有着手设计 Myung 的官网，但我已经可以想象到一个扇子、然后每个扇叶中有不同画卷和水墨风格的动态效果的美术呈现，一定惊艳无比。",{"type":20,"tag":61,"props":72,"children":73},{},[74],{"type":26,"value":75},"唯一需要担心的就是设计上我需要花多少功夫去弄特效（ Gsap+Three 的配合所呈现的效果肯定很棒），和我能不能实现其 Myung 的核心逻辑（相当于是一个新的数据存储和缓存逻辑）",{"type":20,"tag":61,"props":77,"children":78},{},[79],{"type":26,"value":80},"众所周知，前端已经拥有 SSG（Static Site Generation，静态站点生成）方案，而我希望将这种方案应用到后端服务中，使 API 具有类似 SSG 的功能，即 SDG（Static Data Generation，静态数据生成）。",{"type":20,"tag":61,"props":82,"children":83},{},[84],{"type":26,"value":85},"但是目前我只想到了应对 GET 请求的方案，对于 GET 请求，目前有一个完整的处理思路。",{"type":20,"tag":61,"props":87,"children":88},{},[89],{"type":26,"value":90},"我将首先提供一个支持 Vert.x 的包，可以通过 Maven、Gradle 引入依赖。然后，在构建 API 时，可以在 Gateway、Controller、Routing 或任何涉及 RESTful API 的构建位置引入 Myung。",{"type":20,"tag":61,"props":92,"children":93},{},[94],{"type":26,"value":95},"（或者直接开坑写一个缓存数据框架也是有可能的。感谢 dragove 的新点子。）",{"type":20,"tag":61,"props":97,"children":98},{},[99],{"type":26,"value":100},"届时，Myung 会像沙漏一样，每十分钟获取一次数据库数据（时间可自行配置）。然后，它会拦截并替换来自 Myung 构建的静态 API 数据。",{"type":20,"tag":61,"props":102,"children":103},{},[104],{"type":26,"value":105},"目前的思路和策略还不完整以应对 POST 请求，因为它可能涉及修改、删除、更新等较为复杂的操作，而 GET 请求只涉及查询，因此较为简单。",{"type":20,"tag":61,"props":107,"children":108},{},[109],{"type":26,"value":110},"假设每次 POST 请求都带有密钥或验证口令，如果与后端生成的验证或口令匹配，则可以执行相应的操作。这个口令或验证是实时的，因此需要与前端和后端保持同步（根据时间和数据的约定）。",{"type":20,"tag":61,"props":112,"children":113},{},[114,116,125],{"type":26,"value":115},"数据与时间约定是我在 ",{"type":20,"tag":117,"props":118,"children":122},"a",{"href":119,"rel":120},"https://www.researchgate.net/publication/372484162_Decentralized_Self-Organizing_Networks_Applying_Defense_to_Distributed_Autonomous_Systems",[121],"nofollow",[123],{"type":26,"value":124},"10.13140/RG.2.2.14314.90563/1",{"type":26,"value":126}," 中提出了一个 IDEA，主要针对分布式网络（但也涉及 RESTful API）。",{"type":20,"tag":61,"props":128,"children":129},{},[130],{"type":26,"value":131},"然而，这种方法也存在一些问题，会使整个服务和架构变得臃肿，因为需要单独列出一个服务器用于数据同步。实际上，这个服务也会暴露其接口，稍有心机的攻击者也可以将其作为攻击切入点。",{"type":20,"tag":61,"props":133,"children":134},{},[135],{"type":26,"value":136},"唯一可能的方式是将提交的数据存储在 cookie 中，然后由前端审计引擎根据规则进行分析。",{"type":20,"tag":61,"props":138,"children":139},{},[140],{"type":26,"value":141},"但前端的许多数据都是暴露在外面的，无论是否加密，都会增加攻击成本。这种方法针对低水平的攻击者可能有效，但如果面对高级的攻击者，可能会成为攻击的切入点。",{"type":20,"tag":61,"props":143,"children":144},{},[145],{"type":26,"value":146},"假设在理想状态下，用户提交的 POST 数据预先存储在 cookie 中，然后进行规则和审计，如果数据正确，则直接预渲染在视图中（需要前端支持从 cookie 预加载）。否则，直接拦截。这种反复尝试规则遍历可能导致浏览器当前页面崩溃，因此受害者往往是攻击者。",{"type":20,"tag":61,"props":148,"children":149},{},[150],{"type":26,"value":151},"因此，除非未来有新的 RFC 和传输协议的支持，并经过数年的推动和标准化，否则无法实现绝对的安全操作，更多的是增加攻击成本。",{"type":20,"tag":153,"props":154,"children":155},"img-tips",{},[156,160],{"type":20,"tag":51,"props":157,"children":159},{"src":158},"/images/info/5/3.png",[],{"type":26,"value":161},"\n图源 1 | 就像 MLS 一样在 CCC 那样 2023 年 7 月提出的提案被 Discord、Matrix、Wire 所应用（Matrix真的很安全）。\nhttps://events.ccc.de/congress/2023/hub/en/event/rfc_9420_or_how_to_scale_end-to-end_encryption_with_messaging_layer_security/",{"type":20,"tag":61,"props":163,"children":164},{},[165],{"type":26,"value":166},"或者。目前有一个更加理想的状态去完成 POST 的操作，即用户密钥（Face ID 或 Touch ID）这种方式通常仅在较为严重的用户决策时进行验证（大多是 API 调用次数要钱，因此很节约）",{"type":20,"tag":61,"props":168,"children":169},{},[170],{"type":26,"value":171},"如果未来琼楼搭配 Myung 共同完成这个 IDEA。我想、这可能是目前前端组件库中，为数不多考虑安全性的开源项目。",{"type":20,"tag":153,"props":173,"children":174},{},[175,179],{"type":20,"tag":51,"props":176,"children":178},{"src":177},"/images/info/5/1.jpg",[],{"type":26,"value":180},"\n图源 2 | CVE-2023-22527:RCE (Remote Code Execution) Vulnerability\nhttps://t.me/Oracleimpact/901 | Thank: Nian",{"type":20,"tag":61,"props":182,"children":183},{},[184],{"type":26,"value":185},"恰好在我完成这篇文章时，Linux.cn 停止了运营。说实话，作为资讯类的开源社区文章和内容作为新闻聚合非常好，如果贡献翻译和推广 Linux 技术和生态是其使命，那 Linux.cn 显然已经完成了。",{"type":20,"tag":153,"props":187,"children":188},{},[189,193],{"type":20,"tag":51,"props":190,"children":192},{"src":191},"/images/info/5/2.png",[],{"type":26,"value":194},"\n图源 3 | “Linux 中国” 开源社区，停止运营\nhttps://linux.cn/article-16602-1.html",{"type":20,"tag":61,"props":196,"children":197},{},[198],{"type":26,"value":199},"而 Linux 在印度的完全本地化和商业推广，离不开国际形势和其他方面的文化和影响。在网站运营者在其封面文章中所阐述的：“这带来了巨大的资金压力，尤其是在托管服务器价格高昂的那段时期。”",{"type":20,"tag":61,"props":201,"children":202},{},[203],{"type":26,"value":204},"我认为，如果通过 Discuz! X 来搭建论坛，确实需要大量的服务器压力和精力投入，是属于下线很高但上线很低的这种定位。如果是我，我更倾向于直接使用 Github API 组建前端页面，然后数据等来自 Github。",{"type":20,"tag":61,"props":206,"children":207},{},[208],{"type":26,"value":209},"通过前者来实现，不仅需要考虑云服务支出和维护，以及大量时间去探索其 Discuz 的扩展，设计上和用户体验上可能受限。其次就是安全性，甚至你可以在文章评论区下方看到还有人在测试 XSS。",{"type":20,"tag":61,"props":211,"children":212},{},[213],{"type":26,"value":214},"（至于出发点，可能是 PHP 强大的语言魅力吧）",{"type":20,"tag":61,"props":216,"children":217},{},[218],{"type":26,"value":219},"这样，除了降低后端的压力和经济投入外，即使数据压力增加，也不需要太多资金，而且还可以让贡献值更加透明。",{"type":20,"tag":61,"props":221,"children":222},{},[223],{"type":26,"value":224},"不幸的是，在印度可能无法访问或无法为印度受众提供服务，因此他们选择了自建论坛的方式呈现。",{"type":20,"tag":61,"props":226,"children":227},{},[228],{"type":26,"value":229},"同时，我还注意到他们的微信公众号是以公司名义注册的，这显然是一个商业性质的公司。如果是商业性质的开源项目，贪图利润而投入那是理所当然的。",{"type":20,"tag":231,"props":232,"children":233},"page-info",{},[234],{"type":20,"tag":61,"props":235,"children":236},{},[237],{"type":26,"value":238},"*并没有攻击 Linux.cn 是逐利的意思，而是说公司就是公司，公司的目的就是赚钱的。衡量一个公司的好坏就是提供了多少的就业岗位，每年的利润有多少、交了多少税。其次才是社会贡献等方面综合因素衡量，如果格局大一点还可以引入 ESG（环境、社会与治理,Environmental, social, and corporate governance）作为参考标准。",{"type":20,"tag":61,"props":240,"children":241},{},[242],{"type":26,"value":243},"但如果是新闻资讯和媒体方面的开源社区，又不愿意进行推广、炒作和私域等活动，也没有核心的技术和用户所需的需求，那自然会变得困难。",{"type":20,"tag":61,"props":245,"children":246},{},[247],{"type":26,"value":248},"只有那一两位核心用户和贡献者无偿维护和推广时，没有特殊的技术和文化积淀，经过一段时间后，投入难以得到回报，心理压力就会变得巨大，所以形成了目前的局面。",{"type":20,"tag":250,"props":251,"children":252},"page-tips",{},[],{"title":8,"searchDepth":254,"depth":254,"links":255},2,[],"markdown","content:work:jiangxue-myung-api-security-project.md","content","work/jiangxue-myung-api-security-project.md","md",{"_path":262,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":263,"description":264,"director":11,"types":265,"release_date":266,"demo":267,"images":268,"body":269,"_type":256,"_id":434,"_source":258,"_file":435,"_extension":260},"/work/jiangxue-joint-laboratory-luanyin-project","江雪联合实验室銮音项目","江雪之前已经成立和组建了一个虹霓实验室，但由于虹霓主要专注于天演计算、分析等方面的项目和边缘领域，因此将一些辅助性的项目划分给了銮音。銮音的名字取自《说文》中的:人君乘车四马四镳八銮，铃象鸾，鸟声，和则敬也。","RESEARCH","2023.12.25","https://gateway.luanyin.jiangxue.org/","/images/pages/tianyan/tianyan-home.png",{"type":17,"children":270,"toc":432},[271,275,278,306,311,316,321,326,331,336,350,359,364,373,378,387,401,424,429],{"type":20,"tag":21,"props":272,"children":273},{"id":263},[274],{"type":26,"value":263},{"type":20,"tag":28,"props":276,"children":277},{},[],{"type":20,"tag":32,"props":279,"children":280},{},[281],{"type":20,"tag":36,"props":282,"children":284},{"className":283},[39],[285,286],{"type":26,"value":42},{"type":20,"tag":36,"props":287,"children":289},{"className":288},[46],[290,291,295,296,300,301,305],{"type":26,"value":49},{"type":20,"tag":51,"props":292,"children":294},{"src":293},"/images/pages/tianyan/ty-0.png",[],{"type":26,"value":49},{"type":20,"tag":51,"props":297,"children":299},{"src":298},"/images/pages/tianyan/ty-1.png",[],{"type":26,"value":49},{"type":20,"tag":51,"props":302,"children":304},{"src":303},"/images/pages/tianyan/ty-2.png",[],{"type":26,"value":42},{"type":20,"tag":61,"props":307,"children":308},{},[309],{"type":26,"value":310},"江雪之前已经成立和组建了一个虹霓实验室，但由于虹霓主要专注于天演计算、分析等方面的项目和边缘领域，因此将一些辅助性的项目划分给了銮音。銮音的名字取自《说文》中的 \"人君乘车四马四镳八銮，铃象鸾，鸟声，和则敬也。\"。",{"type":20,"tag":61,"props":312,"children":313},{},[314],{"type":26,"value":315},"因此，銮音这个名字非常符合江雪的调性，所以很搭配一起使用。而为什么叫实验室，也就是 LAB，这个词并不是为了好看或者听起来很牛逼才这么叫的。",{"type":20,"tag":61,"props":317,"children":318},{},[319],{"type":26,"value":320},"而是说之后，随着天演，也就是虹霓逐渐步入正轨，可以为江雪的各个项目提供支持，并进行各种计算和模拟；主要目的是提供一些佐证资料。",{"type":20,"tag":61,"props":322,"children":323},{},[324],{"type":26,"value":325},"加上 LAB 之后，表明拿得出来的东西都是经过推敲、严谨、无懈可击、完美的！而不是随便做出来的。",{"type":20,"tag":61,"props":327,"children":328},{},[329],{"type":26,"value":330},"目前銮音负责的项目主要是声学方面的研究和应用，主要包括模拟、测算、构建等，也就是说可以通过声音进行环境的模拟和建模，并实时反馈。",{"type":20,"tag":61,"props":332,"children":333},{},[334],{"type":26,"value":335},"通过计算出主要或需要的参数，进行系统的分析和统计的综合架构，主要用于特殊领域的分析和画像。",{"type":20,"tag":61,"props":337,"children":338},{},[339,341,348],{"type":26,"value":340},"最近，剑桥的研究团队和合作者巧妙地利用了上述方式，即虚拟实验室，在这篇论文中被称为 SDLs（Distributed Self-Driving Laboratories，分布式自动驾驶实验室 / 分布式自主实验室）刊登在 ",{"type":20,"tag":117,"props":342,"children":345},{"href":343,"rel":344},"https://www.nature.com/articles/s41467-023-44599-9",[121],[346],{"type":26,"value":347},"Nature Journal",{"type":26,"value":349},"。",{"type":20,"tag":153,"props":351,"children":352},{},[353,357],{"type":20,"tag":51,"props":354,"children":356},{"src":355},"/images/info/1/1.png",[],{"type":26,"value":358},"\n图源 1 | From Platform to Knowledge Graph: Distributed Self-Driving Laboratories\nhttps://como.ceb.cam.ac.uk/media/preprints/c4e-preprint-310.pdf",{"type":20,"tag":61,"props":360,"children":361},{},[362],{"type":26,"value":363},"这和天演虹霓实验室的做法类似，通过大量的计算资源将物理实验室设备进行虚拟仿真，已达到云上开展研究和设计，同时实时共享数据可让其合作者实时观察进度和操作。",{"type":20,"tag":153,"props":365,"children":366},{},[367,371],{"type":20,"tag":51,"props":368,"children":370},{"src":369},"/images/info/1/2.png",[],{"type":26,"value":372},"\n图源 2 | 江雪虹霓实验室：为江雪和其附属团队和项目及其合作者提供计算资源和实验环境的计算平台\nhttps://gateway.hongni-lab.jiangxue.org/",{"type":20,"tag":61,"props":374,"children":375},{},[376],{"type":26,"value":377},"当然江雪的某些研究领域不像是生物、化学、物理那样需要什么样的器材和设备，江雪的主要项目更侧重计算机网络、科学等方面，因此我们只是将计算资源以及网络、环境仿真和模拟等。",{"type":20,"tag":153,"props":379,"children":380},{},[381,385],{"type":20,"tag":51,"props":382,"children":384},{"src":383},"/images/info/1/3.png",[],{"type":26,"value":386},"\n图源 3 | 根据科学家的目标请求触发自主工作流，作为在知识图谱中传播信息。\nhttps://como.ceb.cam.ac.uk/media/preprints/c4e-preprint-310.pdf",{"type":20,"tag":61,"props":388,"children":389},{},[390,392,399],{"type":26,"value":391},"像是图 3 这种直接在关系图里直接通过描述词然后让 ROG Agent 直接执行和调用的，还是很新颖的。江雪目前更多的是通过 Code 模块化的预设命令完成这种操作。感觉很像 ",{"type":20,"tag":117,"props":393,"children":396},{"href":394,"rel":395},"https://obsidian.md/",[121],[397],{"type":26,"value":398},"obsidian",{"type":26,"value":400}," 的知识图谱，通过这种方式呈现的效果感觉比看状态、日志的效果更加直观。",{"type":20,"tag":61,"props":402,"children":403},{},[404,406,413,415,422],{"type":26,"value":405},"目前，虹霓通常的架构基本上都是通过 ",{"type":20,"tag":117,"props":407,"children":410},{"href":408,"rel":409},"https://neo4j.com/",[121],[411],{"type":26,"value":412},"Neo4j",{"type":26,"value":414}," 存储和查询关系比较方便，查询速度也很快，再加上 ",{"type":20,"tag":117,"props":416,"children":419},{"href":417,"rel":418},"https://vertx.io/docs/",[121],[420],{"type":26,"value":421},"Vertx Framework",{"type":26,"value":423}," 非常适合计算数据庞大且需要经常查询的计算结果。 但存在一个问题，就是说这些数据拥有较强的关联性且庞大的数据，存在较高的可攻击性，且任何一个节点的修改，性能上存在较高的资源浪费。",{"type":20,"tag":61,"props":425,"children":426},{},[427],{"type":26,"value":428},"未来也许可能通过 Myung 解决这些问题。",{"type":20,"tag":250,"props":430,"children":431},{},[],{"title":8,"searchDepth":254,"depth":254,"links":433},[],"content:work:jiangxue-joint-laboratory-luanyin-project.md","work/jiangxue-joint-laboratory-luanyin-project.md",{"_path":437,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":438,"description":439,"director":11,"types":265,"release_date":440,"demo":441,"images":442,"body":443,"_type":256,"_id":612,"_source":258,"_file":613,"_extension":260},"/work/jiangxue-tianyan-hongni-computing-platform","江雪虹霓实验室计算平台","在负责过江雪天演舆情项目后，我们发现辅助和周边服务存在较大的不足。因此，在天演舆情中，除了数据、存储、分析和研判等方面的对比外，几乎无法与在资金、人际关系和先发优势等方面具备优势的前辈个体有所差异。","2023.12.12","https://gateway.hongni-lab.jiangxue.org/","/images/pages/tianyan-compute/1.png",{"type":17,"children":444,"toc":610},[445,449,452,474,478,483,488,497,511,516,557,578,583,592,597,602,607],{"type":20,"tag":21,"props":446,"children":447},{"id":438},[448],{"type":26,"value":438},{"type":20,"tag":28,"props":450,"children":451},{},[],{"type":20,"tag":32,"props":453,"children":454},{},[455],{"type":20,"tag":36,"props":456,"children":458},{"className":457},[39],[459,460],{"type":26,"value":42},{"type":20,"tag":36,"props":461,"children":463},{"className":462},[46],[464,465,468,469,473],{"type":26,"value":49},{"type":20,"tag":51,"props":466,"children":467},{"src":442},[],{"type":26,"value":49},{"type":20,"tag":51,"props":470,"children":472},{"src":471},"/images/pages/tianyan-compute/2.png",[],{"type":26,"value":42},{"type":20,"tag":61,"props":475,"children":476},{},[477],{"type":26,"value":439},{"type":20,"tag":61,"props":479,"children":480},{},[481],{"type":26,"value":482},"为此，天演将专注于构建和完善计算资源等周边服务。在这一领域，幸运的是，很少有人涉足，而且技术难度相当大。这需要更多的时间以及更多创新性的思考和方法，以规避计算资源支出方面的问题。",{"type":20,"tag":61,"props":484,"children":485},{},[486],{"type":26,"value":487},"更令人振奋的是，这些方面与江雪天演项目的性质高度契合。通过与周边应用的对接，可以使天演项目在原本已经很优秀的基础上更具特色，并提升相关领域的门槛。",{"type":20,"tag":153,"props":489,"children":490},{},[491,495],{"type":20,"tag":51,"props":492,"children":494},{"src":493},"/images/info/2/1.png",[],{"type":26,"value":496},"\n图源 1 | 江雪天演舆情分析项目：当时在乙方场地直接拍的，看到的第一感觉是落地效果很棒，集成的数据协调和统筹系统显示起来很有电影里的感觉。\nhttps://gateway.tianyan.jiangxue.org/",{"type":20,"tag":61,"props":498,"children":499},{},[500,502,509],{"type":26,"value":501},"有趣的是，在我将 \"江雪虹霓实验室计算平台\" 发布到 Behance 不久后，我收到了一个关于 ",{"type":20,"tag":117,"props":503,"children":506},{"href":504,"rel":505},"https://www.vantagemarkets.com/en/",[121],[507],{"type":26,"value":508},"Vantage",{"type":26,"value":510}," 3D 设计师助理职位的邀请。",{"type":20,"tag":61,"props":512,"children":513},{},[514],{"type":26,"value":515},"和他们的设计师和主管聊了很久，感觉他们对设计的追求和开发的落地效果都有较高的标准。并不是像我一样构思玩设计之后，还需要进一步设计动效、交互等方面的细节。之后还需分割成一个一个的组件方便以后会用得到，有时候真觉得。",{"type":20,"tag":61,"props":517,"children":518},{},[519,521,528,530,537,539,546,548,555],{"type":26,"value":520},"如果一个人只靠设计，或许真的可以完成一个项目的前期运营和开发，而且还很快。目前流行的 ",{"type":20,"tag":117,"props":522,"children":525},{"href":523,"rel":524},"https://webflow.com/",[121],[526],{"type":26,"value":527},"Webflow",{"type":26,"value":529}," 或 ",{"type":20,"tag":117,"props":531,"children":534},{"href":532,"rel":533},"https://www.wix.com/",[121],[535],{"type":26,"value":536},"WIX",{"type":26,"value":538}," (ps: 不要问我怎么知道的，之前看朋友在用 wix ），通常是 前者作为 CMS，之后 Figma 设计、",{"type":20,"tag":117,"props":540,"children":543},{"href":541,"rel":542},"https://www.lottielab.com/",[121],[544],{"type":26,"value":545},"Lottie lab",{"type":26,"value":547}," 或者 ",{"type":20,"tag":117,"props":549,"children":552},{"href":550,"rel":551},"https://lottiefiles.com/",[121],[553],{"type":26,"value":554},"Lottiefiles",{"type":26,"value":556},"  作为动效设计。",{"type":20,"tag":61,"props":558,"children":559},{},[560,562,569,571],{"type":26,"value":561},"像是 Vantage 的设计就用到了 ",{"type":20,"tag":117,"props":563,"children":566},{"href":564,"rel":565},"https://spline.design/",[121],[567],{"type":26,"value":568},"spline",{"type":26,"value":570},"，我承认他是一个好的在线 3D 设计平台(如果不卡的话，那就更好了)；我有注意到沈毅也在做 Web 3D 设计的平台，但性能方面还是受到了 WebGPU 方面的限制。如果你有兴趣被折磨，可以尝试下 WebGPU 的光线追踪 ",{"type":20,"tag":117,"props":572,"children":575},{"href":573,"rel":574},"https://gnikoloff.github.io/webgpu-raytracer/",[121],[576],{"type":26,"value":577},"Demo",{"type":20,"tag":61,"props":579,"children":580},{},[581],{"type":26,"value":582},"总之像这些新的基于 HTML5 Canvas 2D 渲染引擎确实为设计领域增加了不少色彩（我已经不知道多久没有打开我的 Photoshop 了）",{"type":20,"tag":584,"props":585,"children":586},"page-fold",{},[587],{"type":20,"tag":61,"props":588,"children":589},{},[590],{"type":26,"value":591},"真的很馋鹅厂的设计和技术，动效、3D、特效、原画真的好看又华丽。将来如果江雪也能拥有，就更好了。",{"type":20,"tag":61,"props":593,"children":594},{},[595],{"type":26,"value":596},"但这些都不是重点，重点是：",{"type":20,"tag":61,"props":598,"children":599},{},[600],{"type":26,"value":601},"现在。江雪广泛使用由 Three.js 和 GSAP.js 构建的效果。而前的琼楼仅仅是一些基础常用需求的组件，因此在未来可能更加接近于 PAG 的引入和设计流程，从而实现与琼楼的无缝衔接，以缩短动画效果的构思时间和场景构建。",{"type":20,"tag":61,"props":603,"children":604},{},[605],{"type":26,"value":606},"虽然动效、3D、特效、原画这些江雪都没有或者有很大的缺陷，但未来也许会有。",{"type":20,"tag":250,"props":608,"children":609},{},[],{"title":8,"searchDepth":254,"depth":254,"links":611},[],"content:work:jiangxue-tianyan-hongni-computing-platform.md","work/jiangxue-tianyan-hongni-computing-platform.md",{"_path":615,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":616,"description":617,"director":11,"types":618,"release_date":619,"demo":620,"images":621,"body":622,"_type":256,"_id":787,"_source":258,"_file":788,"_extension":260},"/work/to-web3-navigation","To Web3","帮朋友设计的一个项目，采用了大量二次元设计元素和呈现方式，主打ACG。然而，时隔一年发现该项目仍然停滞不前，甚至域名都尚未购买。","DESIGN","2023.09.27","#IN DEVELOPMENT","/images/pages/to-web3/1.png",{"type":17,"children":623,"toc":785},[624,630,633,660,665,670,675,680,685,690,695,700,705,710,715,724,729,734,739,757,762,767,772,777,782],{"type":20,"tag":21,"props":625,"children":627},{"id":626},"to-web3-navigate",[628],{"type":26,"value":629},"To Web3 navigate",{"type":20,"tag":28,"props":631,"children":632},{},[],{"type":20,"tag":32,"props":634,"children":635},{},[636],{"type":20,"tag":36,"props":637,"children":639},{"className":638},[39],[640,641],{"type":26,"value":42},{"type":20,"tag":36,"props":642,"children":644},{"className":643},[46],[645,646,649,650,654,655,659],{"type":26,"value":49},{"type":20,"tag":51,"props":647,"children":648},{"src":621},[],{"type":26,"value":49},{"type":20,"tag":51,"props":651,"children":653},{"src":652},"/images/pages/to-web3/2.png",[],{"type":26,"value":49},{"type":20,"tag":51,"props":656,"children":658},{"src":657},"/images/pages/to-web3/3.png",[],{"type":26,"value":42},{"type":20,"tag":61,"props":661,"children":662},{},[663],{"type":26,"value":664},"帮朋友设计的一个项目，采用了大量二刺螈设计元素和呈现方式，主打一个 ACG。然而，时隔一年发现该项目仍然停滞不前，甚至域名都尚未购买。",{"type":20,"tag":61,"props":666,"children":667},{},[668],{"type":26,"value":669},"因此，在今天即将发布这篇 blogpost 文章之前，我巧妙地促使他购买了一个域名（我也不知道为什么要在博客文章封面前加入项目预览，可能是为了更美观吧）。",{"type":20,"tag":61,"props":671,"children":672},{},[673],{"type":26,"value":674},"有时候真的会感到惋惜，缺乏行动力和执行力真的会导致项目的停滞和持续的不温不火。",{"type":20,"tag":61,"props":676,"children":677},{},[678],{"type":26,"value":679},"还记得去年 TA 的 web3frelance，也是在开年之际而进行设计，于是到了今年依然还在仓库里躺着。",{"type":20,"tag":61,"props":681,"children":682},{},[683],{"type":26,"value":684},"说到 To web3。TA 本质上是一个导航。但又与常见的像是 Wordpress 这种弄出来的导航不同；可以理解为更不一样或者更有风格。",{"type":20,"tag":61,"props":686,"children":687},{},[688],{"type":26,"value":689},"然而，这种方式也有弊端，即显得与其他同类型的 WordPress 导航站或者“自定义设计”的导航站格格不入。因为它的风格太过突出，更多的是传达理念和调性，而不是为了推广其他网站或内容。",{"type":20,"tag":61,"props":691,"children":692},{},[693],{"type":26,"value":694},"导航离不开推广，就像西方世界离不开耶路撒冷一样。",{"type":20,"tag":61,"props":696,"children":697},{},[698],{"type":26,"value":699},"由于导航的性质，可以将微小的流量集中起来，然后进行私域扩展，从而发展客户和引流推广等。",{"type":20,"tag":61,"props":701,"children":702},{},[703],{"type":26,"value":704},"所以与其说是格格不入，更多的是因为设计风格太过突出，导致无法与同类型的用户流量产生“磨合”。",{"type":20,"tag":61,"props":706,"children":707},{},[708],{"type":26,"value":709},"简而言之，风格太重，用户无法理解或没有接触过。他们更需要像那些使用 WordPress 模板的，因为形成了统一性，所以新的风格出现显得不太协调，用户接受度不高。",{"type":20,"tag":61,"props":711,"children":712},{},[713],{"type":26,"value":714},"这就需要运营时要找对需求而并不是广撒网，需要的流量群体质量越高，那么也就需要付出其对应的时间来弥补。",{"type":20,"tag":153,"props":716,"children":717},{},[718,722],{"type":20,"tag":51,"props":719,"children":721},{"src":720},"/images/info/4/1.png",[],{"type":26,"value":723},"\n图源 1 | 利用 Stable Diffusion 生成的虚拟动漫人物(稍加少量修改和装饰) https://github.com/AUTOMATIC1111/stable-diffusion-webui",{"type":20,"tag":61,"props":725,"children":726},{},[727],{"type":26,"value":728},"说到这个设计的出发点其实挺有趣的，因为 TA 是米哈游出来的，所以当时想的是：\"干翻米哈游！\" 的目的去着手弄的。",{"type":20,"tag":61,"props":730,"children":731},{},[732],{"type":26,"value":733},"而这个二刺螈人物是我上一年通过 Stable Diffusion 生成出来的。说实话当时的 AICG 还没有像是现在 2023 年这样发达或快速破圈，更多的是小圈子里讨论和应用。",{"type":20,"tag":61,"props":735,"children":736},{},[737],{"type":26,"value":738},"生成出来的角色手部、裙子和脸有了很多问题所以当时我用数位板进行了稍微地结构性的调整了一下。",{"type":20,"tag":153,"props":740,"children":741},{},[742,755],{"type":20,"tag":36,"props":743,"children":745},{"style":744},"padding:56.25% 0 0 0;position:relative;",[746],{"type":20,"tag":747,"props":748,"children":754},"iframe",{"src":749,"frameBorder":750,"allow":751,"style":752,"title":753},"https://player.vimeo.com/video/910286322?badge=0&autopause=0&player_id=0&app_id=58479","0","autoplay; fullscreen; picture-in-picture","position:absolute;top:0;left:0;width:100%;height:100%;","現実世界の歌手の声抽出による AI 二次最適化とシミュレーション",[],{"type":26,"value":756},"\n视频 1 | 通过对现实世界歌手声音的提取 AI 二次优化和模拟@江雪銮音实验室 https://music.163.com/song?id=2075128378&userid=1548171212",{"type":20,"tag":61,"props":758,"children":759},{},[760],{"type":26,"value":761},"现在 AICG 已经发展成图片、视频甚至声音、音乐等方面的应用。当然，在设计、艺术领域以及一些小圈子里，有一些对AI创作的抵制声音。",{"type":20,"tag":61,"props":763,"children":764},{},[765],{"type":26,"value":766},"不过我并不是专门从事设计和艺术方面工作的，所以我对 AICG 的看法其实一直很乐观。我想的是会不会衍生新的工作和研究方向出来，也就是通过类似图片隐写等方式，向你 Stable Diffusion 投毒。",{"type":20,"tag":61,"props":768,"children":769},{},[770],{"type":26,"value":771},"加上目前国内外有大量的狂热爱好者，这是一个可观的数量。",{"type":20,"tag":61,"props":773,"children":774},{},[775],{"type":26,"value":776},"还记得当时新能源在汽车领域广泛应用之前，有很多做工控安全的同仁转战新能源汽车安全，去众筹买电车然后一起做测试和研究。",{"type":20,"tag":61,"props":778,"children":779},{},[780],{"type":26,"value":781},"现在都已经成为了一方大佬，依然活跃在安全一线。",{"type":20,"tag":250,"props":783,"children":784},{},[],{"title":8,"searchDepth":254,"depth":254,"links":786},[],"content:work:to-web3-navigation.md","work/to-web3-navigation.md",{"_path":790,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":791,"description":792,"director":11,"types":265,"release_date":793,"demo":794,"images":795,"body":796,"_type":256,"_id":969,"_source":258,"_file":970,"_extension":260},"/work/jiangxue-tianyan-internet-public-opinion-platform","江雪天演舆情分析项目","在谈及 舆情 之前、我相信有很多人会脸色一变觉得这种类似的分析项目就是普通的数据抓取和分析，甚至是直接看社交平台（含短视频平台）的数据进行反馈。","2023.08.05","https://gateway.tianyan.jiangxue.org/","/images/pages/tianyan-opinion/1.png",{"type":17,"children":797,"toc":967},[798,802,805,837,842,847,852,857,862,867,876,881,886,891,896,905,910,915,923,928,951,959,964],{"type":20,"tag":21,"props":799,"children":800},{"id":791},[801],{"type":26,"value":791},{"type":20,"tag":28,"props":803,"children":804},{},[],{"type":20,"tag":32,"props":806,"children":807},{},[808],{"type":20,"tag":36,"props":809,"children":811},{"className":810},[39],[812,813],{"type":26,"value":42},{"type":20,"tag":36,"props":814,"children":816},{"className":815},[46],[817,818,821,822,826,827,831,832,836],{"type":26,"value":49},{"type":20,"tag":51,"props":819,"children":820},{"src":795},[],{"type":26,"value":49},{"type":20,"tag":51,"props":823,"children":825},{"src":824},"/images/pages/tianyan-opinion/4.png",[],{"type":26,"value":49},{"type":20,"tag":51,"props":828,"children":830},{"src":829},"/images/pages/tianyan-opinion/2.png",[],{"type":26,"value":49},{"type":20,"tag":51,"props":833,"children":835},{"src":834},"/images/pages/tianyan-opinion/3.png",[],{"type":26,"value":42},{"type":20,"tag":61,"props":838,"children":839},{},[840],{"type":26,"value":841},"在谈及 \"舆情\" 之前，我相信很多人会在听到这种类似的分析项目时脸色一变，觉得这只是普通的数据抓取和分析，甚至认为是直接看社交平台（包括短视频平台）的数据反馈。",{"type":20,"tag":61,"props":843,"children":844},{},[845],{"type":26,"value":846},"更有甚者可能会将其与 APT 等一系列解释联系起来，这当然是 \"合理\" 的，因为所有类似冲突或事件都可以由某个 APT 组织去进行 \"引导和策划\"。而目前比较专业的领域和大规模学术级应用，更多的是由 Google 的 GDELT 项目提供支持。",{"type":20,"tag":61,"props":848,"children":849},{},[850],{"type":26,"value":851},"PS：注意这与像 Shodan 一类的资产搜索引擎不同，上述类项目针对的是更加全面的显示数据模拟和综合计算。而此类项目仅仅是针对互联网上的资产进行抓取和分析，当然。",{"type":20,"tag":61,"props":853,"children":854},{},[855],{"type":26,"value":856},"之后像是 Shodan 这类资产搜索引擎是否能关联成资产模拟、资产预判和仿真等，我就不言而喻了，也许有蛋糕可图，我相信他们也会侧重这一方向，比如换个词，叫 \"网络空间测绘\"。",{"type":20,"tag":61,"props":858,"children":859},{},[860],{"type":26,"value":861},"回到舆情中，我们会发现舆情的 English 的解释有公众情绪\\意见(Public sentiment)、公众意见(Public opinion)等，综合可进行舆论导向（Direction Of Public Opinion）、事件的模拟和计算。",{"type":20,"tag":61,"props":863,"children":864},{},[865],{"type":26,"value":866},"而目前能单从含义诠释这种需求的，更多的是流量高度集中的 Google，因此 Google 的 GDELT 项目经常作为社会科学等领域的较权威数据来源。",{"type":20,"tag":153,"props":868,"children":869},{},[870,874],{"type":20,"tag":51,"props":871,"children":873},{"src":872},"/images/info/3/1.png",[],{"type":26,"value":875},"\n图源 1 | 京畿研究院利用 GDELT 分析 1990~2020 年之间的韩中纠纷趋势：A Time Series Analysis of the Dynamics of Korea-China Relations with GDELT Data\n이성우, 민소영. (2022). 사건계수자료(GDELT)를 활용한 한 · 중 양자관계 역학 분석. 경기연구원. http://doi.org/10.18107/japs.2022.29.3.002",{"type":20,"tag":61,"props":877,"children":878},{},[879],{"type":26,"value":880},"而在中文互联网流量大量集中的百度、腾讯、阿里等厂商，分别有自己的一套分析方式。但无法像 GDELT 那样拥有世界大部分国家的数据流向，且充分完整。前者大多是输出结果，且人工修饰较为严重。",{"type":20,"tag":61,"props":882,"children":883},{},[884],{"type":26,"value":885},"但好消息是，自从字节跳动的抖音、bilibili、小红书、微博、快手、百度、微信等大流量聚集的社交、图媒体平台，逐渐让某些热点和历史数据也能成为某个领域的分析资料。因此也促成了很多类似这方面的舆情、数据分析平台的诞生。",{"type":20,"tag":61,"props":887,"children":888},{},[889],{"type":26,"value":890},"可惜的是，样本和衡量因素不多导致无法呈现真实世界生活，更多的是包装出来的效果所进行引导和牵制，产生了互联网世界和现实世界落差过大的奇怪因素。",{"type":20,"tag":61,"props":892,"children":893},{},[894],{"type":26,"value":895},"往往采用这类舆情、大数据分析平台的单位和机构所作出的决策无法满足真实需求，从而诞生矛盾和不当的决策出现。",{"type":20,"tag":153,"props":897,"children":898},{},[899,903],{"type":20,"tag":51,"props":900,"children":902},{"src":901},"/images/info/3/2.png",[],{"type":26,"value":904},"\n图源 2 | IENN Events 2023：Network Cross-Synchronization:Distributed Network Hierarchical Transmission,Jump Network\nhttp://ienn.org/TY.2.2.14314.90563/1",{"type":20,"tag":61,"props":906,"children":907},{},[908],{"type":26,"value":909},"因此，在 IENN 2023 中，我分享了未来天演的规划和架构设计，以及全新的设计体系和底层设计架构。以避免天演出现上述的问题，将侧重点放在了存储和计算中。",{"type":20,"tag":61,"props":911,"children":912},{},[913],{"type":26,"value":914},"如果要对个体间进行分析，最好的方式就是让其还未知道的情况进行分析。从这种单向的方式可以获取到较为高质量的元数据，从而不被非个体和环境进行引导和左右。",{"type":20,"tag":153,"props":916,"children":917},{},[918,922],{"type":20,"tag":51,"props":919,"children":921},{"src":920},"/images/info/3/3.png",[],{"type":26,"value":904},{"type":20,"tag":61,"props":924,"children":925},{},[926],{"type":26,"value":927},"之后，天演主要会兼顾舆情和数据分析的同时，结合空间测绘来进行主动信息分析，提前将事态进行分析和演算的目的。因此，天演之后的格言是：\"DETECT\"、\"PROTECT\" 即侦查、和保护。",{"type":20,"tag":61,"props":929,"children":930},{},[931,933,940,942,949],{"type":26,"value":932},"自从看了 ",{"type":20,"tag":117,"props":934,"children":937},{"href":935,"rel":936},"https://www.raykite.com/",[121],[938],{"type":26,"value":939},"RAYKITE 光起源",{"type":26,"value":941}," 发布会之后，我惊叹于 ",{"type":20,"tag":117,"props":943,"children":946},{"href":944,"rel":945},"https://www.ventuz.com/",[121],[947],{"type":26,"value":948},"Ventuz Tech",{"type":26,"value":950}," 的大规模应用。阿里曾经想通过 Unity 去驱动数据可视化大屏，但落地效果并不是很理想（比较卡顿）但通过 Ventuz 做出来的效果非常 niubility 给力（可能是 Unreal Engine 独天得厚的特性吧） 。",{"type":20,"tag":584,"props":952,"children":953},{},[954],{"type":20,"tag":61,"props":955,"children":956},{},[957],{"type":26,"value":958},"有时候真的挺崩溃的，有 Tencent 这么厉害的势力，基本上让人看不到希望。",{"type":20,"tag":61,"props":960,"children":961},{},[962],{"type":26,"value":963},"所以之后天演也将刨除现在的技术架构，将数据之间的传输和存储独立于基础交换方式，以更好的和 Ventuz 构建数据之间的传递。（主要是设计资源比较花时间）",{"type":20,"tag":250,"props":965,"children":966},{},[],{"title":8,"searchDepth":254,"depth":254,"links":968},[],"content:work:jiangxue-tianyan-internet-public-opinion-platform.md","work/jiangxue-tianyan-internet-public-opinion-platform.md",{"_path":972,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":973,"description":974,"director":975,"types":976,"release_date":977,"demo":978,"images":979,"body":980,"_type":256,"_id":1189,"_source":258,"_file":1190,"_extension":260},"/work/qionglou-component-library","琼楼组件库设计","说实话我与前端的接触并不多，如果说最多的无非是小学时对拥有一台服务器、域名和论坛的盲目追崇。当时的 Xiuno BBS 还火极一时（因为安装很方便，就是那种无脑下一步即可的），之后接触到了 WordPress、 Discuz x!、z-blog、MediaWiki 但都没有我喜欢的。","RHYME.Q, Zloyalty","DEVELOP","2023.04.22","https://qionglou.jiangxue.org/","/images/pages/qionglou/1.png",{"type":17,"children":981,"toc":1187},[982,986,989,1012,1016,1021,1029,1034,1039,1047,1052,1057,1062,1067,1072,1077,1086,1091,1096,1109,1114,1128,1133,1138,1143,1152,1157,1166,1174,1179,1184],{"type":20,"tag":21,"props":983,"children":984},{"id":973},[985],{"type":26,"value":973},{"type":20,"tag":28,"props":987,"children":988},{},[],{"type":20,"tag":32,"props":990,"children":991},{},[992],{"type":20,"tag":36,"props":993,"children":995},{"className":994},[39],[996,997],{"type":26,"value":42},{"type":20,"tag":36,"props":998,"children":1000},{"className":999},[46],[1001,1002,1006,1007,1011],{"type":26,"value":49},{"type":20,"tag":51,"props":1003,"children":1005},{"src":1004},"/images/pages/qionglou/2.png",[],{"type":26,"value":49},{"type":20,"tag":51,"props":1008,"children":1010},{"src":1009},"/images/pages/qionglou/3.png",[],{"type":26,"value":42},{"type":20,"tag":61,"props":1013,"children":1014},{},[1015],{"type":26,"value":974},{"type":20,"tag":61,"props":1017,"children":1018},{},[1019],{"type":26,"value":1020},"甚至好像还误打误撞混进了站长圈，感觉一个一个年龄都好大，还接触到了云服务厂商的代理们（比如什么小鸟云什么的，网站什么的好像都是那一套模板，至今我都不知道有这么多人弄云服务代理）。",{"type":20,"tag":231,"props":1022,"children":1023},{},[1024],{"type":20,"tag":61,"props":1025,"children":1026},{},[1027],{"type":26,"value":1028},"*可惜，Xiuno BBS 在 2020 年 7 月关闭了，留下一句话：\"国内什么时候有真正的开源环境了再见！\"，当时我不太理解，甚至有些疑惑，现在或许我理解了。",{"type":20,"tag":61,"props":1030,"children":1031},{},[1032],{"type":26,"value":1033},"混到站长群（群主是烧饼）之后，就是那个头像是个小孩子的烧饼，当时他好像在开发一个论坛框架，也有人在用。之后在一个云厂商代理的测试页面中看到了 ThinkPHP 的角标。",{"type":20,"tag":61,"props":1035,"children":1036},{},[1037],{"type":26,"value":1038},"（当时感觉很好看，然后我就把这个角标 copy 到了我自己项目中，改了个 Logo 和颜色以及名字。然后你点开那个角标就会看到各种参数信息的样子）",{"type":20,"tag":231,"props":1040,"children":1041},{},[1042],{"type":20,"tag":61,"props":1043,"children":1044},{},[1045],{"type":26,"value":1046},"*那时候 ThinkPHP 的官网还好丑，一股传销、广告推广站的模样。好多年过去了现在官网竟然更新座右铭为：\"大道至简\" 也是蛮有趣的，但和 Laraver 相比感觉后者真的是 Code Art，确实很艺术，但 PHP 的技术栈属实是雅俗共赏。",{"type":20,"tag":61,"props":1048,"children":1049},{},[1050],{"type":26,"value":1051},"后来慢慢长大了，在这个期间折腾过 Raspberry Pi、Linux（几个发行版折腾了个变最终归宿是 Mac，但 Arch 和大蜥蜴是用户体验挺不错的，我也不知道为什么用 ubuntu\\debian 的 apt-get 安装依赖总是有可能把系统删了）",{"type":20,"tag":61,"props":1053,"children":1054},{},[1055],{"type":26,"value":1056},"从 JSP 过渡到 Spring -> Spring Boot（当过度到 Spring Boot 时，感觉确实名不虚传，比单个 Spring 配置要智能得多），之后也尝试体验了 Spring Cloud 以及 HashiCorp 家的 Consul 服务中心（在此之前我确实没见过像是 Nacos 这种完全不用动脑的）",{"type":20,"tag":61,"props":1058,"children":1059},{},[1060],{"type":26,"value":1061},"Hashicorp 家的 Vagrant 很好用（很像是 Docker，但是又不是 Docker，用来搭建虚拟机很舒服）",{"type":20,"tag":61,"props":1063,"children":1064},{},[1065],{"type":26,"value":1066},"之所以想写一个组件库，可能大概是我比较懒，然后有想追求自己设计稿的设计去完成其样式，但当时的 CSS 库感觉比较傻，然后刚好在 Laraver 中看到了 Vue",{"type":20,"tag":61,"props":1068,"children":1069},{},[1070],{"type":26,"value":1071},"（因为 Laraver 中是可以写 Vue Code 的，所以你可想而知 Vue Code+ PHP Code 结合是什么样的）",{"type":20,"tag":61,"props":1073,"children":1074},{},[1075],{"type":26,"value":1076},"所以就去看了 Vue，在此期间也搜刮了下 Node.js，给 expressjs、vue 提交过 pr（很开心都被合并了）",{"type":20,"tag":153,"props":1078,"children":1079},{},[1080,1084],{"type":20,"tag":51,"props":1081,"children":1083},{"src":1082},"/images/info/6/1.jpg",[],{"type":26,"value":1085},"\n图源 1 | 我还收获到了 Vue 的小贴纸，感谢 @lingsi",{"type":20,"tag":61,"props":1087,"children":1088},{},[1089],{"type":26,"value":1090},"（其实这是琼楼的第二版本设计，第一版本的设计太丑了拿不出手）",{"type":20,"tag":61,"props":1092,"children":1093},{},[1094],{"type":26,"value":1095},"在琼楼第二版本中使用到了 Spline 进行设计（可以理解为 Three.js 的可视化版本，原谅我懒的打开 blender 设置一堆环境和场景及材质再导到 Three.js 中），所以你可以在首页里体验到游戏交互（比如 ASWD 移动和空格跳跃、鼠标改动摄像头视角等这些基础的）",{"type":20,"tag":153,"props":1097,"children":1098},{},[1099,1107],{"type":20,"tag":36,"props":1100,"children":1101},{"style":744},[1102],{"type":20,"tag":747,"props":1103,"children":1106},{"src":1104,"frameBorder":750,"allow":751,"style":752,"title":1105},"https://player.vimeo.com/video/910284429?badge=0&autopause=0&player_id=0&app_id=58479","Untitled",[],{"type":26,"value":1108},"\n图源 2 | 通过 Spline 设计的琼楼场景搭建\nhttps://qionglou.jiangxue.org/",{"type":20,"tag":61,"props":1110,"children":1111},{},[1112],{"type":26,"value":1113},"之所以将组件库命名为琼楼，可能更大的一部分取自苏轼的《水调歌头》：\"我欲乘风归去，又恐琼楼玉宇，高处不胜寒。\"",{"type":20,"tag":231,"props":1115,"children":1116},{},[1117],{"type":20,"tag":61,"props":1118,"children":1119},{},[1120,1122],{"type":26,"value":1121},"*诗句大意：我想凭借着风力回到天上去看一看，又担心美玉砌成的楼宇太高了，我经受不住寒冷。\n",{"type":20,"tag":117,"props":1123,"children":1126},{"href":1124,"rel":1125},"https://so.gushiwen.cn/mingju/juv_2440a90a8220.aspx",[121],[1127],{"type":26,"value":1124},{"type":20,"tag":61,"props":1129,"children":1130},{},[1131],{"type":26,"value":1132},"很契合江雪目前的状态，每个项目都很高端且深入基础，但任何一个项目拿出来后都是一个青春的凋谢，历经十年的付出也许在人家看来仅仅是一个笑话。",{"type":20,"tag":61,"props":1134,"children":1135},{},[1136],{"type":26,"value":1137},"所以在这个情况下，琼楼可以作为前端开发基础组件库，以独特的设计和可解耦使用的方式，完成江雪的各样设计和结合 GSAP 动画交互效果的综合性组件库。",{"type":20,"tag":61,"props":1139,"children":1140},{},[1141],{"type":26,"value":1142},"而选择 Vue 的原因可能是其生态看着很雅俗共赏，有较大的空间（也许未来在 Vue 组件库写的差不多的时候，支持下 HTMX）",{"type":20,"tag":153,"props":1144,"children":1145},{},[1146,1150],{"type":20,"tag":51,"props":1147,"children":1149},{"src":1148},"/images/info/6/3.jpg",[],{"type":26,"value":1151},"\n图源 3 | the difference between HTMX and React Server Components.\n@angelo_fallaria",{"type":20,"tag":61,"props":1153,"children":1154},{},[1155],{"type":26,"value":1156},"目前琼楼还处于试错阶段（也就是随时可能会有较大的改变）即现在的组件也许会被推翻重来（本来琼楼官网打算在琼楼写的差不多之后在进行开发的，但还是为了怕遗忘一些组件参数，先用 vitepress 对付了一下，之后再用琼楼的组件去开发官网。）",{"type":20,"tag":153,"props":1158,"children":1159},{},[1160,1164],{"type":20,"tag":51,"props":1161,"children":1163},{"src":1162},"/images/info/6/4.png",[],{"type":26,"value":1165},"\n图源 4 | 琼楼组件库 V3 文档移动端设计稿（基础，未含 Code 演示、Script、Template 分块等功能。ps:等上线的时候肯定是有的）",{"type":20,"tag":231,"props":1167,"children":1168},{},[1169],{"type":20,"tag":61,"props":1170,"children":1171},{},[1172],{"type":26,"value":1173},"*当初在 Zloyalty 还未构建好打包的时候认认真真的把他那个丑死的按钮写成了很好看的样子，结果在下一次重构打包的时候，他那个丑死的按钮样式又把我那个已经初具雏形的按钮组件给夺舍了。这让我意识到了一个问题，就是说好看的他并不一定能用，不好看的也许会经久不衰，所以可能未来琼楼的组件库主打一个只加一个 border: 1px solid #DADADA",{"type":20,"tag":61,"props":1175,"children":1176},{},[1177],{"type":26,"value":1178},"至于后面组件库的主题编辑器、和主题商店，虽然有这个计划也完成了设计，但真正上线可能要看天意。因为设计是设计，设计需要考虑到组件目前发展的程度和实用性和观赏性，所以目前的设计可能在组件库下一次更新的时候，都会被丢弃。",{"type":20,"tag":61,"props":1180,"children":1181},{},[1182],{"type":26,"value":1183},"（感觉用 Rive 画出来的动效比我用 AE 弄得效果都好）",{"type":20,"tag":250,"props":1185,"children":1186},{},[],{"title":8,"searchDepth":254,"depth":254,"links":1188},[],"content:work:qionglou-component-library.md","work/qionglou-component-library.md",{"_path":1192,"_dir":8,"_draft":7,"_partial":7,"_locale":8,"title":1193,"description":1194,"image":1195,"head":1200,"body":1212,"_type":256,"_id":1229,"_source":258,"_file":1230,"_extension":260},"/","RHYME.Q 韵清","Rhyme.Q Blog showcases the expertise of Rhyme.Q, a seasoned professional with a comprehensive background in full-stack development, front-end and back-end technologies, blockchain development, design, and security research.",{"src":1196,"alt":1197,"width":1198,"height":1199},"/assets/showcasing.png","RHYME.Q.",400,300,{"meta":1201},[1202,1204,1207,1209],{"name":1203,"content":11},"keywords",{"name":1205,"content":1206},"robots","index, follow",{"name":1208,"content":11},"author",{"name":1210,"content":1211},"copyright","© 2024 RHYME.Q",{"type":17,"children":1213,"toc":1227},[1214,1218,1224],{"type":20,"tag":1215,"props":1216,"children":1217},"home-con",{},[],{"type":20,"tag":61,"props":1219,"children":1221},{"style":1220},"display: none",[1222],{"type":26,"value":1223},"rhyme.qing",{"type":20,"tag":250,"props":1225,"children":1226},{},[],{"title":8,"searchDepth":254,"depth":254,"links":1228},[],"content:index.md","index.md",1708365390433]