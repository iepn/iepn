[{"data":1,"prerenderedAt":452},["Reactive",2],{"equal":3,"content-query-1DxZ1vYQk5":412},[4,234],{"_path":5,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":9,"description":10,"id":11,"director":12,"types":13,"release_date":14,"demo":15,"images":16,"body":17,"_type":229,"_id":230,"_source":231,"_file":232,"_extension":233},"/work/jiangxue-joint-laboratory-luanyin-project","work",false,"","江雪联合实验室銮音项目","江雪之前已经成立和组建了一个虹霓实验室，但由于虹霓主要专注于天演计算、分析等方面的项目和边缘领域，因此将一些辅助性的项目划分给了銮音。銮音的名字取自《说文》中的:人君乘车四马四镳八銮，铃象鸾，鸟声，和则敬也。","1","RHYME.Q","RESEARCH","2023.12.25","https://gateway.luanyin.jiangxue.org/","/images/pages/tianyan/tianyan-home.png",{"type":18,"children":19,"toc":226},"root",[20,27,31,66,72,77,82,87,92,97,131,147,157,162,171,176,185,199,222],{"type":21,"tag":22,"props":23,"children":24},"element","h1",{"id":9},[25],{"type":26,"value":9},"text",{"type":21,"tag":28,"props":29,"children":30},"page-back",{},[],{"type":21,"tag":32,"props":33,"children":34},"page-img",{},[35],{"type":21,"tag":36,"props":37,"children":40},"div",{"className":38},[39],"slider",[41,43],{"type":26,"value":42},"\n  ",{"type":21,"tag":36,"props":44,"children":47},{"className":45},[46],"slides",[48,50,55,56,60,61,65],{"type":26,"value":49},"\n      ",{"type":21,"tag":51,"props":52,"children":54},"img",{"src":53},"/images/pages/tianyan/ty-0.png",[],{"type":26,"value":49},{"type":21,"tag":51,"props":57,"children":59},{"src":58},"/images/pages/tianyan/ty-1.png",[],{"type":26,"value":49},{"type":21,"tag":51,"props":62,"children":64},{"src":63},"/images/pages/tianyan/ty-2.png",[],{"type":26,"value":42},{"type":21,"tag":67,"props":68,"children":69},"p",{},[70],{"type":26,"value":71},"江雪之前已经成立和组建了一个虹霓实验室，但由于虹霓主要专注于天演计算、分析等方面的项目和边缘领域，因此将一些辅助性的项目划分给了銮音。銮音的名字取自《说文》中的 \"人君乘车四马四镳八銮，铃象鸾，鸟声，和则敬也。\"。",{"type":21,"tag":67,"props":73,"children":74},{},[75],{"type":26,"value":76},"因此，銮音这个名字非常符合江雪的调性，所以很搭配一起使用。而为什么叫实验室，也就是 LAB，这个词并不是为了好看或者听起来很牛逼才这么叫的。",{"type":21,"tag":67,"props":78,"children":79},{},[80],{"type":26,"value":81},"而是说之后，随着天演，也就是虹霓逐渐步入正轨，可以为江雪的各个项目提供支持，并进行各种计算和模拟；主要目的是提供一些佐证资料。",{"type":21,"tag":67,"props":83,"children":84},{},[85],{"type":26,"value":86},"加上 LAB 之后，表明拿得出来的东西都是经过推敲、严谨、无懈可击、完美的！而不是随便做出来的。",{"type":21,"tag":67,"props":88,"children":89},{},[90],{"type":26,"value":91},"目前銮音负责的项目主要是声学方面的研究和应用，主要包括模拟、测算、构建等，也就是说可以通过声音进行环境的模拟和建模，并实时反馈。",{"type":21,"tag":67,"props":93,"children":94},{},[95],{"type":26,"value":96},"通过计算出主要或需要的参数，进行系统的分析和统计的综合架构，主要用于特殊领域的分析和画像。",{"type":21,"tag":98,"props":99,"children":100},"page-fold",{},[101,106,111,116,121,126],{"type":21,"tag":67,"props":102,"children":103},{},[104],{"type":26,"value":105},"读到这里，我敢肯定大多数人都会觉得：\"你们连一个超过 50 平方米的工作空间都没有，怎么称之为实验室的？你们甚至没有申请过什么自然科学基金，以及一些 Open Access 期刊，甚至是主流会议都不邀请你们！\"。",{"type":21,"tag":67,"props":107,"children":108},{},[109],{"type":26,"value":110},"有上面这个心里想法的一定很多，大多数都身处环境不错、地处优越或 \"3A 景区旁（泛指自然条件风光）\"，有着很好的资源，什么超算服务租用手到擒来，在付费的那一刻心里没有任何波动；然后将数据整理整理，EMAIL 发一下。",{"type":21,"tag":67,"props":112,"children":113},{},[114],{"type":26,"value":115},"对方客客气气的说：\"您的观点很新颖，数据严谨，又对 XXX 又很多的帮助\"，之后你挂个什么 XX 基金 \\ 奖金，支付几版的版面费和其他服务，同样在支付的时候不会有任何波动。",{"type":21,"tag":67,"props":117,"children":118},{},[119],{"type":26,"value":120},"如果在某某某群又通知了，邀请函上写着您的名字；但您没有马上动身，而是先申请 XXX 课题组的 XXX 经费；之后风风光光的收到邀请、朋友拍个合照，然后发个朋友圈感慨。",{"type":21,"tag":67,"props":122,"children":123},{},[124],{"type":26,"value":125},"半个月后，您的著作刊登 XXX 刊首版甚至是封面，在各种社交平台、短视频平台疯狂转发。在评论区中：一群环境艰苦工作的地方忙碌了一天或和 \"客户舌战群雄的\" 群音荟萃们纷纷支持、赞同和感到 XX 进步 阿美莉卡又不行了 XXX 不亮 XX 亮的评论再次让您感到努力都是有意义的。",{"type":21,"tag":67,"props":127,"children":128},{},[129],{"type":26,"value":130},"于是您好巧不巧不知道从什么地方或者是什么吐槽群里看到了这个文章并加上了吐槽：\"这人是不是想多了啊，肯定是破防了、自己想的这么多肯定是说的自己或者说自己经历过\"，于是您嘴角一撇，果然不是所有人都和我一样优秀。",{"type":21,"tag":67,"props":132,"children":133},{},[134,136,145],{"type":26,"value":135},"最近，剑桥的研究团队和合作者巧妙地利用了上述方式，即虚拟实验室，在这篇论文中被称为 SDLs（Distributed Self-Driving Laboratories，分布式自动驾驶实验室 / 分布式自主实验室）刊登在 ",{"type":21,"tag":137,"props":138,"children":142},"a",{"href":139,"rel":140},"https://www.nature.com/articles/s41467-023-44599-9",[141],"nofollow",[143],{"type":26,"value":144},"Nature Journal",{"type":26,"value":146},"。",{"type":21,"tag":148,"props":149,"children":150},"img-tips",{},[151,155],{"type":21,"tag":51,"props":152,"children":154},{"src":153},"/images/info/1/1.png",[],{"type":26,"value":156},"\n图源 1 | From Platform to Knowledge Graph: Distributed Self-Driving Laboratories\nhttps://como.ceb.cam.ac.uk/media/preprints/c4e-preprint-310.pdf",{"type":21,"tag":67,"props":158,"children":159},{},[160],{"type":26,"value":161},"这和天演虹霓实验室的做法类似，通过大量的计算资源将物理实验室设备进行虚拟仿真，已达到云上开展研究和设计，同时实时共享数据可让其合作者实时观察进度和操作。",{"type":21,"tag":148,"props":163,"children":164},{},[165,169],{"type":21,"tag":51,"props":166,"children":168},{"src":167},"/images/info/1/2.png",[],{"type":26,"value":170},"\n图源 2 | 江雪虹霓实验室：为江雪和其附属团队和项目及其合作者提供计算资源和实验环境的计算平台\nhttps://gateway.hongni-lab.jiangxue.org/",{"type":21,"tag":67,"props":172,"children":173},{},[174],{"type":26,"value":175},"当然江雪的某些研究领域不像是生物、化学、物理那样需要什么样的器材和设备，江雪的主要项目更侧重计算机网络、科学等方面，因此我们只是将计算资源以及网络、环境仿真和模拟等。",{"type":21,"tag":148,"props":177,"children":178},{},[179,183],{"type":21,"tag":51,"props":180,"children":182},{"src":181},"/images/info/1/3.png",[],{"type":26,"value":184},"\n图源 3 | 根据科学家的目标请求触发自主工作流，作为在知识图谱中传播信息。\nhttps://como.ceb.cam.ac.uk/media/preprints/c4e-preprint-310.pdf",{"type":21,"tag":67,"props":186,"children":187},{},[188,190,197],{"type":26,"value":189},"像是图 3 这种直接在关系图里直接通过描述词然后让 ROG Agent 直接执行和调用的，还是很新颖的。江雪目前更多的是通过 Code 模块化的预设命令完成这种操作。感觉很像 ",{"type":21,"tag":137,"props":191,"children":194},{"href":192,"rel":193},"https://obsidian.md/",[141],[195],{"type":26,"value":196},"obsidian",{"type":26,"value":198}," 的知识图谱，通过这种方式呈现的效果感觉比看状态、日志的效果更加直观。",{"type":21,"tag":67,"props":200,"children":201},{},[202,204,211,213,220],{"type":26,"value":203},"目前，虹霓通常的架构基本上都是通过 ",{"type":21,"tag":137,"props":205,"children":208},{"href":206,"rel":207},"https://neo4j.com/",[141],[209],{"type":26,"value":210},"Neo4j",{"type":26,"value":212}," 存储和查询关系比较方便，查询速度也很快，再加上 ",{"type":21,"tag":137,"props":214,"children":217},{"href":215,"rel":216},"https://vertx.io/docs/",[141],[218],{"type":26,"value":219},"Vertx Framework",{"type":26,"value":221}," 非常适合计算数据庞大且需要经常查询的计算结果。",{"type":21,"tag":223,"props":224,"children":225},"page-tips",{},[],{"title":8,"searchDepth":227,"depth":227,"links":228},2,[],"markdown","content:work:jiangxue-joint-laboratory-luanyin-project.md","content","work/jiangxue-joint-laboratory-luanyin-project.md","md",{"_path":235,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":236,"description":8,"id":237,"director":12,"types":13,"release_date":238,"demo":239,"images":240,"body":241,"_type":229,"_id":410,"_source":231,"_file":411,"_extension":233},"/work/jiangxue-tianyan-hongni-computing-platform","江雪虹霓实验室计算平台","2","2023.12.12","https://gateway.hongni-lab.jiangxue.org/","/images/pages/tianyan-compute/1.png",{"type":18,"children":242,"toc":408},[243,247,250,272,277,282,287,296,310,315,356,377,382,390,395,400,405],{"type":21,"tag":22,"props":244,"children":245},{"id":236},[246],{"type":26,"value":236},{"type":21,"tag":28,"props":248,"children":249},{},[],{"type":21,"tag":32,"props":251,"children":252},{},[253],{"type":21,"tag":36,"props":254,"children":256},{"className":255},[39],[257,258],{"type":26,"value":42},{"type":21,"tag":36,"props":259,"children":261},{"className":260},[46],[262,263,266,267,271],{"type":26,"value":49},{"type":21,"tag":51,"props":264,"children":265},{"src":240},[],{"type":26,"value":49},{"type":21,"tag":51,"props":268,"children":270},{"src":269},"/images/pages/tianyan-compute/2.png",[],{"type":26,"value":42},{"type":21,"tag":67,"props":273,"children":274},{},[275],{"type":26,"value":276},"在负责过江雪天演舆情项目后，我们发现辅助和周边服务存在较大的不足。因此，在天演舆情中，除了数据、存储、分析和研判等方面的对比外，几乎无法与在资金、人际关系和先发优势等方面具备优势的前辈个体有所差异。",{"type":21,"tag":67,"props":278,"children":279},{},[280],{"type":26,"value":281},"为此，天演将专注于构建和完善计算资源等周边服务。在这一领域，幸运的是，很少有人涉足，而且技术难度相当大。这需要更多的时间以及更多创新性的思考和方法，以规避计算资源支出方面的问题。",{"type":21,"tag":67,"props":283,"children":284},{},[285],{"type":26,"value":286},"更令人振奋的是，这些方面与江雪天演项目的性质高度契合。通过与周边应用的对接，可以使天演项目在原本已经很优秀的基础上更具特色，并提升相关领域的门槛。",{"type":21,"tag":148,"props":288,"children":289},{},[290,294],{"type":21,"tag":51,"props":291,"children":293},{"src":292},"/images/info/2/1.png",[],{"type":26,"value":295},"\n图源 1 | 江雪天演舆情分析项目：当时在乙方场地直接拍的，看到的第一感觉是落地效果很棒，集成的数据协调和统筹系统显示起来很有电影里的感觉。\nhttps://gateway.tianyan.jiangxue.org/",{"type":21,"tag":67,"props":297,"children":298},{},[299,301,308],{"type":26,"value":300},"有趣的是，在我将 \"江雪虹霓实验室计算平台\" 发布到 Behance 不久后，我收到了一个关于 ",{"type":21,"tag":137,"props":302,"children":305},{"href":303,"rel":304},"https://www.vantagemarkets.com/en/",[141],[306],{"type":26,"value":307},"Vantage",{"type":26,"value":309}," 3D 设计师助理职位的邀请。",{"type":21,"tag":67,"props":311,"children":312},{},[313],{"type":26,"value":314},"和他们的设计师和主管聊了很久，感觉他们对设计的追求和开发的落地效果都有较高的标准。并不是像我一样构思玩设计之后，还需要进一步设计动效、交互等方面的细节。之后还需分割成一个一个的组件方便以后会用得到，有时候真觉得。",{"type":21,"tag":67,"props":316,"children":317},{},[318,320,327,329,336,338,345,347,354],{"type":26,"value":319},"如果一个人只靠设计，或许真的可以完成一个项目的前期运营和开发，而且还很快。目前流行的 ",{"type":21,"tag":137,"props":321,"children":324},{"href":322,"rel":323},"https://webflow.com/",[141],[325],{"type":26,"value":326},"Webflow",{"type":26,"value":328}," 或 ",{"type":21,"tag":137,"props":330,"children":333},{"href":331,"rel":332},"https://www.wix.com/",[141],[334],{"type":26,"value":335},"WIX",{"type":26,"value":337}," (ps: 不要问我怎么知道的，之前看朋友在用 wix ），通常是 前者作为 CMS，之后 Figma 设计、",{"type":21,"tag":137,"props":339,"children":342},{"href":340,"rel":341},"https://www.lottielab.com/",[141],[343],{"type":26,"value":344},"Lottie lab",{"type":26,"value":346}," 或者 ",{"type":21,"tag":137,"props":348,"children":351},{"href":349,"rel":350},"https://lottiefiles.com/",[141],[352],{"type":26,"value":353},"Lottiefiles",{"type":26,"value":355},"  作为动效设计。",{"type":21,"tag":67,"props":357,"children":358},{},[359,361,368,370],{"type":26,"value":360},"像是 Vantage 的设计就用到了 ",{"type":21,"tag":137,"props":362,"children":365},{"href":363,"rel":364},"https://spline.design/",[141],[366],{"type":26,"value":367},"spline",{"type":26,"value":369},"，我承认他是一个好的在线 3D 设计平台(如果不卡的话，那就更好了)；我有注意到沈毅也在做 Web 3D 设计的平台，但性能方面还是受到了 WebGPU 方面的限制。如果你有兴趣被折磨，可以尝试下 WebGPU 的光线追踪 ",{"type":21,"tag":137,"props":371,"children":374},{"href":372,"rel":373},"https://gnikoloff.github.io/webgpu-raytracer/",[141],[375],{"type":26,"value":376},"Demo",{"type":21,"tag":67,"props":378,"children":379},{},[380],{"type":26,"value":381},"总之像这些新的基于 HTML5 Canvas 2D 渲染引擎确实为设计领域增加了不少色彩（我已经不知道多久没有打开我的 Photoshop 了）",{"type":21,"tag":98,"props":383,"children":384},{},[385],{"type":21,"tag":67,"props":386,"children":387},{},[388],{"type":26,"value":389},"真的很馋鹅厂的设计和技术，动效、3D、特效、原画真的好看又华丽。将来如果江雪也能拥有，就更好了。",{"type":21,"tag":67,"props":391,"children":392},{},[393],{"type":26,"value":394},"但这些都不是重点，重点是",{"type":21,"tag":67,"props":396,"children":397},{},[398],{"type":26,"value":399},"现在。江雪广泛使用由 Three.js 和 GSAP.js 构建的效果。而前的琼楼仅仅是一些基础常用需求的组件，因此在未来可能更加接近于 PAG 的引入和设计流程，从而实现与琼楼的无缝衔接，以缩短动画效果的构思时间和场景构建。",{"type":21,"tag":67,"props":401,"children":402},{},[403],{"type":26,"value":404},"虽然动效、3D、特效、原画这些江雪都没有或者有很大的缺陷，但未来也许会有。",{"type":21,"tag":223,"props":406,"children":407},{},[],{"title":8,"searchDepth":227,"depth":227,"links":409},[],"content:work:jiangxue-tianyan-hongni-computing-platform.md","work/jiangxue-tianyan-hongni-computing-platform.md",{"_path":413,"_dir":8,"_draft":7,"_partial":7,"_locale":8,"title":414,"description":415,"image":416,"head":421,"body":433,"_type":229,"_id":450,"_source":231,"_file":451,"_extension":233},"/","RHYME.Q 韵清","Rhyme.Q Blog showcases the expertise of Rhyme.Q, a seasoned professional with a comprehensive background in full-stack development, front-end and back-end technologies, blockchain development, design, and security research.",{"src":417,"alt":418,"width":419,"height":420},"/assets/showcasing.png","RHYME.Q.",400,300,{"meta":422},[423,425,428,430],{"name":424,"content":12},"keywords",{"name":426,"content":427},"robots","index, follow",{"name":429,"content":12},"author",{"name":431,"content":432},"copyright","© 2024 RHYME.Q",{"type":18,"children":434,"toc":448},[435,439,445],{"type":21,"tag":436,"props":437,"children":438},"home-con",{},[],{"type":21,"tag":67,"props":440,"children":442},{"style":441},"display: none",[443],{"type":26,"value":444},"rhyme.qing",{"type":21,"tag":223,"props":446,"children":447},{},[],{"title":8,"searchDepth":227,"depth":227,"links":449},[],"content:index.md","index.md",1706433279938]