[{"data":1,"prerenderedAt":193},["Reactive",2],{"equal":3,"content-query-1DxZ1vYQk5":153},[4],{"_path":5,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":9,"description":10,"id":11,"director":12,"types":13,"release_date":14,"demo":15,"images":16,"body":17,"_type":148,"_id":149,"_source":150,"_file":151,"_extension":152},"/work/jiangxue-joint-laboratory-luanyin-project","work",false,"","江雪联合实验室銮音项目","江雪銮音实验室是针对声学领域中声呐和地理信息探测等边缘领域所成立的研究团队","1","RHYME.Q","RESEARCH","2023.12.25","https://secgay.test.luanyin.jiangxue.org/","/images/pages/tianyan/tianyan-home.png",{"type":18,"children":19,"toc":145},"root",[20,27,31,66,72,77,82,87,92,97,131,141],{"type":21,"tag":22,"props":23,"children":24},"element","h1",{"id":9},[25],{"type":26,"value":9},"text",{"type":21,"tag":28,"props":29,"children":30},"page-back",{},[],{"type":21,"tag":32,"props":33,"children":34},"page-img",{},[35],{"type":21,"tag":36,"props":37,"children":40},"div",{"className":38},[39],"slider",[41,43],{"type":26,"value":42},"\n  ",{"type":21,"tag":36,"props":44,"children":47},{"className":45},[46],"slides",[48,50,55,56,60,61,65],{"type":26,"value":49},"\n      ",{"type":21,"tag":51,"props":52,"children":54},"img",{"src":53},"/images/pages/tianyan/ty-0.png",[],{"type":26,"value":49},{"type":21,"tag":51,"props":57,"children":59},{"src":58},"/images/pages/tianyan/ty-1.png",[],{"type":26,"value":49},{"type":21,"tag":51,"props":62,"children":64},{"src":63},"/images/pages/tianyan/ty-2.png",[],{"type":26,"value":42},{"type":21,"tag":67,"props":68,"children":69},"p",{},[70],{"type":26,"value":71},"江雪之前已经成立和组建了一个虹霓实验室，但由于虹霓主要专注于天演计算、分析等方面的项目和边缘领域，因此将一些辅助性的项目划分给了銮音。銮音的名字取自《说文》中的 \"人君乘车四马四镳八銮，铃象鸾，鸟声，和则敬也。\"。",{"type":21,"tag":67,"props":73,"children":74},{},[75],{"type":26,"value":76},"因此，銮音这个名字非常符合江雪的调性，所以很搭配一起使用。而为什么叫实验室，也就是 LAB，这个词并不是为了好看或者听起来很牛逼才这么叫的。",{"type":21,"tag":67,"props":78,"children":79},{},[80],{"type":26,"value":81},"而是说之后，随着天演，也就是虹霓逐渐步入正轨，可以为江雪的各个项目提供支持，并进行各种计算和模拟；主要目的是提供一些佐证资料。",{"type":21,"tag":67,"props":83,"children":84},{},[85],{"type":26,"value":86},"加上 LAB 之后，表明拿得出来的东西都是经过推敲、严谨、无懈可击、完美的！而不是随便做出来的。",{"type":21,"tag":67,"props":88,"children":89},{},[90],{"type":26,"value":91},"目前銮音负责的项目主要是声学方面的研究和应用，主要包括模拟、测算、构建等，也就是说可以通过声音进行环境的模拟和建模，并实时反馈。",{"type":21,"tag":67,"props":93,"children":94},{},[95],{"type":26,"value":96},"通过计算出主要或需要的参数，进行系统的分析和统计的综合架构，主要用于特殊领域的分析和画像。",{"type":21,"tag":98,"props":99,"children":100},"page-fold",{},[101,106,111,116,121,126],{"type":21,"tag":67,"props":102,"children":103},{},[104],{"type":26,"value":105},"读到这里，我敢肯定大多数人都会觉得：\"你们连一个超过 50 平方米的工作空间都没有，怎么称之为实验室的？你们甚至没有申请过什么自然科学基金，以及一些 Open Access 期刊，甚至是主流会议都不邀请你们！\"。",{"type":21,"tag":67,"props":107,"children":108},{},[109],{"type":26,"value":110},"有上面这个心里想法的一定很多，大多数都身处环境不错、地处优越或 \"3A 景区旁（泛指自然条件风光）\"，有着很好的资源，什么超算服务租用手到擒来，在付费的那一刻心里没有任何波动；然后将数据整理整理，EMAIL 发一下。",{"type":21,"tag":67,"props":112,"children":113},{},[114],{"type":26,"value":115},"对方客客气气的说：\"您的观点很新颖，数据严谨，又对 XXX 又很多的帮助\"，之后你挂个什么 XX 基金 \\ 奖金，支付几版的版面费和其他服务，同样在支付的时候不会有任何波动。",{"type":21,"tag":67,"props":117,"children":118},{},[119],{"type":26,"value":120},"如果在某某某群又通知了，邀请函上写着您的名字；但您没有马上动身，而是先申请 XXX 课题组的 XXX 经费；之后风风光光的收到邀请、朋友拍个合照，然后发个朋友圈感慨。",{"type":21,"tag":67,"props":122,"children":123},{},[124],{"type":26,"value":125},"半个月后，您的著作刊登 XXX 刊首版甚至是封面，在各种社交平台、短视频平台疯狂转发。评论区中：在环境艰苦工作的地方忙碌了一天或和 \"客户舌战群雄的\" 群音荟萃们纷纷支持、赞同和感到 XX 进步 阿美莉卡又不行了 XXX 不亮 XX 亮的评论再次让您感到努力都是有意义的。",{"type":21,"tag":67,"props":127,"children":128},{},[129],{"type":26,"value":130},"于是您好巧不巧不知道从什么地方或者是什么吐槽群里看到了这个文章并加上了吐槽：\"这人是不是想多了啊，肯定是破防了、自己想的这么多肯定是说的自己或者说自己经历过\"，于是您嘴角一撇，果然不是所有人都和我一样优秀。",{"type":21,"tag":132,"props":133,"children":134},"img-tips",{},[135,139],{"type":21,"tag":51,"props":136,"children":138},{"src":137},"/images/info/1/1.png",[],{"type":26,"value":140},"\n图源 1：From Platform to Knowledge Graph: Distributed Self-Driving Laboratories\nhttps://como.ceb.cam.ac.uk/media/preprints/c4e-preprint-310.pdf",{"type":21,"tag":142,"props":143,"children":144},"page-tips",{},[],{"title":8,"searchDepth":146,"depth":146,"links":147},2,[],"markdown","content:work:jiangxue-joint-laboratory-luanyin-project.md","content","work/jiangxue-joint-laboratory-luanyin-project.md","md",{"_path":154,"_dir":8,"_draft":7,"_partial":7,"_locale":8,"title":155,"description":156,"image":157,"head":162,"body":174,"_type":148,"_id":191,"_source":150,"_file":192,"_extension":152},"/","RHYME.Q 韵清","Rhyme.Q Blog showcases the expertise of Rhyme.Q, a seasoned professional with a comprehensive background in full-stack development, front-end and back-end technologies, blockchain development, design, and security research.",{"src":158,"alt":159,"width":160,"height":161},"/assets/showcasing.png","RHYME.Q.",400,300,{"meta":163},[164,166,169,171],{"name":165,"content":12},"keywords",{"name":167,"content":168},"robots","index, follow",{"name":170,"content":12},"author",{"name":172,"content":173},"copyright","© 2024 RHYME.Q",{"type":18,"children":175,"toc":189},[176,180,186],{"type":21,"tag":177,"props":178,"children":179},"home-con",{},[],{"type":21,"tag":67,"props":181,"children":183},{"style":182},"display: none",[184],{"type":26,"value":185},"rhyme.qing",{"type":21,"tag":142,"props":187,"children":188},{},[],{"title":8,"searchDepth":146,"depth":146,"links":190},[],"content:index.md","index.md",1706110409336]