[{"data":1,"prerenderedAt":142},["Reactive",2],{"equal":3,"content-query-1DxZ1vYQk5":105},[4],{"_path":5,"_dir":6,"_draft":7,"_partial":7,"_locale":8,"title":9,"description":10,"id":11,"director":12,"types":13,"release_date":14,"demo":15,"images":16,"body":17,"_type":100,"_id":101,"_source":102,"_file":103,"_extension":104},"/work/jiangxue-joint-laboratory-luanyin-project","work",false,"","江雪联合实验室銮音项目","江雪銮音实验室是针对声学领域中声呐和地理信息探测等边缘领域所成立的研究团队","1","RHYME.Q","RESEARCH","2023.12.25","https://secgay.test.luanyin.jiangxue.org/","/images/pages/tianyan/tianyan-home.png",{"type":18,"children":19,"toc":97},"root",[20,27,62,68,73,78,83,88,93],{"type":21,"tag":22,"props":23,"children":24},"element","h1",{"id":9},[25],{"type":26,"value":9},"text",{"type":21,"tag":28,"props":29,"children":30},"page-img",{},[31],{"type":21,"tag":32,"props":33,"children":36},"div",{"className":34},[35],"slider",[37,39],{"type":26,"value":38},"\n  ",{"type":21,"tag":32,"props":40,"children":43},{"className":41},[42],"slides",[44,46,51,52,56,57,61],{"type":26,"value":45},"\n      ",{"type":21,"tag":47,"props":48,"children":50},"img",{"src":49},"/images/pages/tianyan/ty-0.png",[],{"type":26,"value":45},{"type":21,"tag":47,"props":53,"children":55},{"src":54},"/images/pages/tianyan/ty-1.png",[],{"type":26,"value":45},{"type":21,"tag":47,"props":58,"children":60},{"src":59},"/images/pages/tianyan/ty-2.png",[],{"type":26,"value":38},{"type":21,"tag":63,"props":64,"children":65},"p",{},[66],{"type":26,"value":67},"江雪之前已经成立和组建了一个虹霓实验室，但因为虹霓主要针对天演计算、分析等方面的项目和边缘领域，就将一些辅助性的项目，划分给了銮音。銮音取自《说文》中的 \"人君乘车四马四镳八銮，铃象鸾，鸟声，和则敬也。\"",{"type":21,"tag":63,"props":69,"children":70},{},[71],{"type":26,"value":72},"因此銮音这个名字非常符合江雪的那种调性，所以很搭配一起使用；而之所以叫实验室，也就是 LAB，这个词并不是说为了好看或者说叫起来很 niubility 才这么叫的。",{"type":21,"tag":63,"props":74,"children":75},{},[76],{"type":26,"value":77},"而是说之后天演也就是虹霓逐渐步入正轨后，可以为江雪各个项目加血，并为其进行各种计算、模拟；以提供一些佐证资料为主要目的。",{"type":21,"tag":63,"props":79,"children":80},{},[81],{"type":26,"value":82},"加上 LAB 之后，表明了拿得出来的东西，都是经过推敲的、严谨的、无懈可击的、完美的！而不是随便做出来的。",{"type":21,"tag":63,"props":84,"children":85},{},[86],{"type":26,"value":87},"銮音目前负责的项目，其实就是声学方面的一些研究和应用，主要是模拟、测算、构建等，也就是说可以通过声音来进行环境的模拟和建模，实时反馈。",{"type":21,"tag":63,"props":89,"children":90},{},[91],{"type":26,"value":92},"并计算出主要或需要的参数，进行系统的分析和统计的综合架构，主要用于特殊领域的分析和画像。",{"type":21,"tag":94,"props":95,"children":96},"page-tips",{},[],{"title":8,"searchDepth":98,"depth":98,"links":99},2,[],"markdown","content:work:jiangxue-joint-laboratory-luanyin-project.md","content","work/jiangxue-joint-laboratory-luanyin-project.md","md",{"_path":106,"_dir":8,"_draft":7,"_partial":7,"_locale":8,"title":107,"description":108,"image":109,"head":114,"body":126,"_type":100,"_id":140,"_source":102,"_file":141,"_extension":104},"/","RHYME.Q 韵清","Rhyme.Q Blog showcases the expertise of Rhyme.Q, a seasoned professional with a comprehensive background in full-stack development, front-end and back-end technologies, blockchain development, design, and security research.",{"src":110,"alt":111,"width":112,"height":113},"/assets/showcasing.png","RHYME.Q.",400,300,{"meta":115},[116,118,121,123],{"name":117,"content":12},"keywords",{"name":119,"content":120},"robots","index, follow",{"name":122,"content":12},"author",{"name":124,"content":125},"copyright","© 2024 RHYME.Q",{"type":18,"children":127,"toc":138},[128,132],{"type":21,"tag":129,"props":130,"children":131},"home-con",{},[],{"type":21,"tag":63,"props":133,"children":135},{"style":134},"display: none",[136],{"type":26,"value":137},"rhyme.qing",{"title":8,"searchDepth":98,"depth":98,"links":139},[],"content:index.md","index.md",1706000556036]