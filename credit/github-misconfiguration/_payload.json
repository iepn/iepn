[{"data":1,"prerenderedAt":163},["Reactive",2],{"content-query-xEjD8Hcqmd":3},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":7,"title":8,"description":7,"platform":9,"director":10,"types":11,"vulnerability":12,"release_date":13,"demo":14,"images":15,"body":16,"_type":158,"_id":159,"_source":160,"_file":161,"_extension":162},"/credit/github-misconfiguration","credit",false,"","GraphQL Misconfiguration in CWE-16 Github API","/images/credit/logo/hackerone.png","RHYME.Q","CREDIT","CWE-16","2023.12.04","https://hackerone.com/iepn","/images/credit/github.png",{"type":17,"children":18,"toc":155},"root",[19,26,33,67,96,101,106,111,116,121,126,131,136,141,146,151],{"type":20,"tag":21,"props":22,"children":25},"element","page-img",{"img":23,"title":24,"url":14},"cwe-github/home","CWE-16 Github API",[],{"type":20,"tag":27,"props":28,"children":29},"p",{},[30],{"type":31,"value":32},"text","这是我第一次提交漏洞获得赏金和周边奖励的漏洞，所以我印象深刻。自我放弃安全路线以来，再一次发现较为知名厂商或平台的安全缺陷，可以当做是我的里程碑，但并不是终点。",{"type":20,"tag":27,"props":34,"children":35},{},[36,38,47,49,56,58,65],{"type":31,"value":37},"我很喜欢 Github 的章鱼猫，我也遇到过身边有好友将章鱼猫当做自己的头像来使用。封面上的章鱼猫来自 ",{"type":20,"tag":39,"props":40,"children":44},"a",{"href":41,"rel":42},"https://octodex.github.com/",[43],"nofollow",[45],{"type":31,"value":46},"GitHub Octocats",{"type":31,"value":48}," 他的设计师是 ",{"type":20,"tag":39,"props":50,"children":53},{"href":51,"rel":52},"https://jeejkang.com/Information",[43],[54],{"type":31,"value":55},"@James Kang",{"type":31,"value":57},"，您可以在 ",{"type":20,"tag":39,"props":59,"children":62},{"href":60,"rel":61},"https://myoctocat.com/",[43],[63],{"type":31,"value":64},"myOctocat",{"type":31,"value":66}," 中创建属于自己的章鱼猫。",{"type":20,"tag":27,"props":68,"children":69},{},[70,72,79,81,86,87,94],{"type":31,"value":71},"在 2011 年中，GitHub 决定是时候升级他们的吉祥物 Octocat 了,所以 Github 邀请了很多设计师对章鱼猫进行创作，如 ",{"type":20,"tag":39,"props":73,"children":76},{"href":74,"rel":75},"https://cameronmcefee.com/work/the-octocat/",[43],[77],{"type":31,"value":78},"Cameron McEfee",{"type":31,"value":80},"、",{"type":20,"tag":39,"props":82,"children":84},{"href":51,"rel":83},[43],[85],{"type":31,"value":55},{"type":31,"value":80},{"type":20,"tag":39,"props":88,"children":91},{"href":89,"rel":90},"https://www.kimestoesta.com/",[43],[92],{"type":31,"value":93},"@KimEstoesta",{"type":31,"value":95}," …… 等",{"type":20,"tag":97,"props":98,"children":100},"text-space",{"info":99},"从笔记本电脑上的贴花和衣服上的图形，到每个酒吧墙上、电线杆和街道标志上贴的贴纸，GitHub 的吉祥物 Octocat 是科技行业最知名的符号之一。@Cameron McEfee",[],{"type":20,"tag":27,"props":102,"children":103},{},[104],{"type":31,"value":105},"其中 James Kang 设计的章鱼猫之一的 Private Investocat 作为 Github Security - GitHub Bug Bounty 的标志性头像。",{"type":20,"tag":97,"props":107,"children":110},{"info":108,"img":109},"我很幸运在他们立项后的 13 年后，获得了它们的实体周边贴纸和胸针。他们的设计师是 @KimEstoesta 和 @Cameron McEfee","7/1",[],{"type":20,"tag":27,"props":112,"children":113},{},[114],{"type":31,"value":115},"同时我还收获到了来自 Github Bug Bounty 的 $200 USD ≈ 1,439 CNY 漏洞赏金，是我在安全道路中，第一次获得如此高昂的现金奖励。",{"type":20,"tag":27,"props":117,"children":118},{},[119],{"type":31,"value":120},"可惜我的定位一直就是团队中的 ACD（辅助）成长缓慢容易给单杀 0_0，一直处于打酱油的状态，有很多方面的技能树需要提升。",{"type":20,"tag":27,"props":122,"children":123},{},[124],{"type":31,"value":125},"自意识到安全是基于开发之下的存在后，我便开始尝试慢慢往开发方面转型，曾经我的老师之前说过：“如果真的有天赋，那不应该将时间投入到应用和框架当中，应该聚焦原理和底层逻辑的设计”。",{"type":20,"tag":27,"props":127,"children":128},{},[129],{"type":31,"value":130},"很明显我属于任何天赋为 0，基础薄弱，一生中无法有较大的成就。在我认识到自身的差距以后，我开始变得不善于与人交谈，退出了所有社区群组，慢慢提升自己。",{"type":20,"tag":27,"props":132,"children":133},{},[134],{"type":31,"value":135},"但等我真正见识到那些在各项比赛中大放异彩的选手后，以及在各类排行榜轻松拿下 10W、30W 奖励赏金的安全专家后，我开始没了当年的自信。",{"type":20,"tag":27,"props":137,"children":138},{},[139],{"type":31,"value":140},"慢慢的我意识到，有时候也许并不需要很好看的界面、很优雅的 Code，很完美的逻辑处理甚至是低的安全性，只需要一个噱头而已，让他们知道你可以就行了，并不需要做的很完美。",{"type":20,"tag":27,"props":142,"children":143},{},[144],{"type":31,"value":145},"我身边有很多例子，在发展到一定程度后，就会产生一种 “工匠精神”，开始意识到之前做的并不好，因此追求更高的标准。",{"type":20,"tag":27,"props":147,"children":148},{},[149],{"type":31,"value":150},"因此我一生中最敬佩的只有两种人，一种是追求这种境界成功的。而另一种是没有追求这种境界的，一直停留在最开始的阶段。",{"type":20,"tag":152,"props":153,"children":154},"page-tips",{},[],{"title":7,"searchDepth":156,"depth":156,"links":157},2,[],"markdown","content:credit:github-misconfiguration.md","content","credit/github-misconfiguration.md","md",1710712221856]