[{"data":1,"prerenderedAt":108},["Reactive",2],{"content-query-6vAmWQLT8p":3,"equal":33},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":5,"title":7,"description":5,"body":8,"_type":28,"_id":29,"_source":30,"_file":31,"_extension":32},"/credit","",false,"Credit",{"type":9,"children":10,"toc":25},"root",[11,16,21],{"type":12,"tag":13,"props":14,"children":15},"element","view-credit",{},[],{"type":12,"tag":17,"props":18,"children":20},"text-space",{"info":19},"* 由于本人并非专业人员，也未从事与安全研究员、渗透测试工程师或提供某种安全服务相关的工作，所以安全仅仅是我的个人兴趣。因此。在 'CREDIT' 卡片中发现的绝大部分漏洞都是歪打正着碰巧发现的。专业安全领域从业者、红队 / 蓝队等专业人士，以及硬件（HW）、CTF 等领域的工作者是我难以想象的高度，因此我无法媲美。在本网站有关安全的文章、CREDIT 以及本网站可能存在较大的书写问题，甚至在某些专业和领域的书面表达上可能质量较低，请谅解。\n\u003Cbr /> \u003Cbr />\n我深知在任何与技术相关的领域中，关注应用、效果以及解决问题是最重要的。任何过于花哨的设计或过多的描述都只是为了掩盖问题的本质。在技术领域中有一句流传的佳话：' 技术领域，菜是原罪 '。因此，我对安全领域的工作者们的工作充满向往。我一直认为编写安全报告是一件很酷的事情，尤其是在处理涉密信息时，这种感觉变得更加强烈（因为涉密信息是普通人难以接触的）。每当我有空闲时间，我都会浏览 Hack the Box Academy，体验专业的安全从业者所需要的课程或工作场景（这让我觉得安全从业者都很酷很帅）。\n\u003Cbr /> \u003Cbr />\n特别是在各种工具的开发中，在通过终端运行时我总能感受到技术上的纯粹美感。无论是交互式环境还是 GUI，与安全领域相关的一切都特别吸引我，它们的设计和代码简直是巧夺天工，是我此生渴望达到的目标。\n\u003Cbr /> \u003Cbr />\n我在 CREDIT 中筛选了我自 2019 年至今所提交且可以公开的漏洞。由于这些漏洞都是我在学生时代或年幼时无知而懵懂操作的结果，因此它们并不具备深度的技术描述或针对特定知识点的说明。如果您是技术或安全领域的从业者，或对相关行业有兴趣的人，很抱歉浪费了您 1~2 分钟的时间，对此我深感抱歉和愧疚。 ",[],{"type":12,"tag":22,"props":23,"children":24},"page-tips",{},[],{"title":5,"searchDepth":26,"depth":26,"links":27},2,[],"markdown","content:credit.md","content","credit.md","md",[34,63,86],{"_path":35,"_dir":36,"_draft":6,"_partial":6,"_locale":5,"title":37,"description":5,"platform":38,"director":39,"types":40,"vulnerability":41,"release_date":42,"demo":43,"images":44,"body":45,"_type":28,"_id":61,"_source":30,"_file":62,"_extension":32},"/credit/github-misconfiguration","credit","GraphQL Misconfiguration in CWE-16 Github API","/images/credit/logo/hackerone.png","RHYME.Q","CREDIT","CWE-16","2023.12.04","https://hackerone.com/iepn","/images/credit/github.png",{"type":9,"children":46,"toc":59},[47,55],{"type":12,"tag":48,"props":49,"children":51},"h1",{"id":50},"cwe-16-github-api",[52],{"type":53,"value":54},"text","CWE-16 Github API",{"type":12,"tag":56,"props":57,"children":58},"page-img",{},[],{"title":5,"searchDepth":26,"depth":26,"links":60},[],"content:credit:github-misconfiguration.md","credit/github-misconfiguration.md",{"_path":64,"_dir":36,"_draft":6,"_partial":6,"_locale":5,"title":65,"description":5,"platform":66,"director":39,"types":40,"vulnerability":67,"release_date":68,"demo":69,"images":70,"body":71,"_type":28,"_id":84,"_source":30,"_file":85,"_extension":32},"/credit/edraw","亿图图示水印导出逻辑漏洞","/images/credit/logo/cnvd.png","CWE-703 | CNVD-2021-24498","2021.05.01","https://www.cnvd.org.cn/flaw/show/3173261","/images/credit/edraw.png",{"type":9,"children":72,"toc":82},[73,79],{"type":12,"tag":48,"props":74,"children":76},{"id":75},"cnvd-2021-24498h",[77],{"type":53,"value":78},"CNVD-2021-24498h",{"type":12,"tag":56,"props":80,"children":81},{},[],{"title":5,"searchDepth":26,"depth":26,"links":83},[],"content:credit:edraw.md","credit/edraw.md",{"_path":87,"_dir":36,"_draft":6,"_partial":6,"_locale":5,"title":88,"description":5,"platform":66,"director":39,"types":40,"vulnerability":89,"release_date":90,"demo":91,"images":92,"body":93,"_type":28,"_id":106,"_source":30,"_file":107,"_extension":32},"/credit/china-telecom","广东电信 IPTV 支付系统存在逻辑缺陷漏洞","CWE-703 | CNVD-2020-10601","2020.02.04","https://www.cnvd.org.cn/flaw/show/1976603","/images/credit/china-telecom.png",{"type":9,"children":94,"toc":104},[95,101],{"type":12,"tag":48,"props":96,"children":98},{"id":97},"cnvd-2020-10601",[99],{"type":53,"value":100},"CNVD-2020-10601",{"type":12,"tag":56,"props":102,"children":103},{},[],{"title":5,"searchDepth":26,"depth":26,"links":105},[],"content:credit:china-telecom.md","credit/china-telecom.md",1710454757767]