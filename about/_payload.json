ag":828,"props":1147,"children":1148},{},[1149,1153],{"type":20,"tag":832,"props":1150,"children":1151},{},[1152],{"type":25,"value":836},{"type":20,"tag":832,"props":1154,"children":1155},{},[1156],{"type":25,"value":1157},"0.1",{"type":20,"tag":843,"props":1159,"children":1160},{"encoding":845},[1161],{"type":25,"value":1162},"\\frac{3}{0.1}",{"type":20,"tag":804,"props":1164,"children":1166},{"className":1165,"ariaHidden":853},[852],[1167],{"type":20,"tag":804,"props":1168,"children":1170},{"className":1169},[858],[1171,1175],{"type":20,"tag":804,"props":1172,"children":1174},{"className":1173,"style":864},[863],[],{"type":20,"tag":804,"props":1176,"children":1178},{"className":1177},[869],[1179,1183,1266],{"type":20,"tag":804,"props":1180,"children":1182},{"className":1181},[874,875],[],{"type":20,"tag":804,"props":1184,"children":1186},{"className":1185},[828],[1187],{"type":20,"tag":804,"props":1188,"children":1190},{"className":1189},[884,885],[1191,1255],{"type":20,"tag":804,"props":1192,"children":1194},{"className":1193},[890],[1195,1250],{"type":20,"tag":804,"props":1196,"children":1198},{"className":1197,"style":896},[895],[1199,1219,1230],{"type":20,"tag":804,"props":1200,"children":1201},{"style":900},[1202,1206],{"type":20,"tag":804,"props":1203,"children":1205},{"className":1204,"style":906},[905],[],{"type":20,"tag":804,"props":1207,"children":1209},{"className":1208},[911,912,913,914],[1210],{"type":20,"tag":804,"props":1211,"children":1213},{"className":1212},[869,914],[1214],{"type":20,"tag":804,"props":1215,"children":1217},{"className":1216},[869,914],[1218],{"type":25,"value":1157},{"type":20,"tag":804,"props":1220,"children":1221},{"style":927},[1222,1226],{"type":20,"tag":804,"props":1223,"children":1225},{"className":1224,"style":906},[905],[],{"type":20,"tag":804,"props":1227,"children":1229},{"className":1228,"style":937},[936],[],{"type":20,"tag":804,"props":1231,"children":1232},{"style":941},[1233,1237],{"type":20,"tag":804,"props":1234,"children":1236},{"className":1235,"style":906},[905],[],{"type":20,"tag":804,"props":1238,"children":1240},{"className":1239},[911,912,913,914],[1241],{"type":20,"tag":804,"props":1242,"children":1244},{"className":1243},[869,914],[1245],{"type":20,"tag":804,"props":1246,"children":1248},{"className":1247},[869,914],[1249],{"type":25,"value":836},{"type":20,"tag":804,"props":1251,"children":1253},{"className":1252},[963],[1254],{"type":25,"value":966},{"type":20,"tag":804,"props":1256,"children":1258},{"className":1257},[890],[1259],{"type":20,"tag":804,"props":1260,"children":1262},{"className":1261,"style":974},[895],[1263],{"type":20,"tag":804,"props":1264,"children":1265},{},[],{"type":20,"tag":804,"props":1267,"children":1269},{"className":1268},[982,875],[],{"type":25,"value":1271}," 交给未来。",{"type":20,"tag":66,"props":1273,"children":1275},{"style":1274},"font-size: small;margin-top:30px;margin-bottom: 30px",[1276],{"type":25,"value":1277},"*上述中的设计、全栈、产品、测试\\安全、运维、区块链等的描述可能或大概存在不严谨，可能缺乏对专业技术、专业领域的相关问题敬畏之心。本人深知技术、逻辑、思维、应用不光只是会用就行，还需考虑环境等不可抗力的各种因素，因此，本文所指作者只会略微理解、略微应用，无法与专业（指专门从事某些方向的专业人士、工程师、学者、老师、培训机构讲师等所掌握的技术本人无法相提并论）或某个圈子、专业领域中的社群（涵盖类似像是微信群、Group、Discord、IRC 频道等类似群组沟通平台\\应用)的会员、成员相提并论。同时上述中的相关专业领域，与其他作者（泛指书籍作者、微信公众号作者、BLOG 作者 等类似署名方式的文章作者）相比，本人无法预之媲美。",{"type":20,"tag":66,"props":1279,"children":1280},{},[1281],{"type":25,"value":1282},"\"正在攻略炼狱难度副本挑战\"",{"type":20,"tag":66,"props":1284,"children":1285},{},[1286],{"type":20,"tag":768,"props":1287,"children":1288},{},[1289],{"type":25,"value":1290},"Lucky Star",{"type":20,"tag":50,"props":1292,"children":1296},{"src":1293,"width":1294,"style":1295},"/images/pages/about/2.png",150,"margin-top: 20px;margin-bottom: 10px;",[],{"type":20,"tag":66,"props":1298,"children":1299},{},[1300],{"type":25,"value":1301},"一生中最幸福的事，就是收获到了 JIANGXUE 江雪的 ORG 域名；没错就是课本中的那句：\"独钓寒江雪\" 的江雪全拼。",{"type":20,"tag":66,"props":1303,"children":1304},{},[1305],{"type":25,"value":1306},"这也是我最喜欢的一首诗，期初，我会觉得江雪好帅又好听，温尔典雅。后来，我只觉得我这一生就跟这首诗类似，精神上受到很大刺激和压抑（现在称之为破防）",{"type":20,"tag":66,"props":1308,"children":1309},{},[1310],{"type":25,"value":1311},"之所以还活着，大概是因为不想让这么帅又这么好听的域名流入他人之手做一些不符合这个意境的事情。",{"type":20,"tag":66,"props":1313,"children":1314},{},[1315],{"type":25,"value":1316},"当然，在我选择了却自己前，我会为它寻找一个和其格调又有和其自身能力绝对与之匹配的有心之人，接手 JIANGXUE。",{"type":20,"tag":66,"props":1318,"children":1319},{},[1320],{"type":25,"value":1321},"为什么是 JIANGXUE.ORG，而不是 .COM / .NET ，是因为江雪的意境，非常符合 ORG 域的独特表达方式，即非营利。",{"type":20,"tag":66,"props":1323,"children":1324},{},[1325],{"type":25,"value":1326},"很多事情营利去做都很难了，更何况是非营利。这就意味这需要参与者高度的认同和一些不明真相吃瓜群众的流量和其荷包里的 $，有了流量和曝光，才能让本就是小众领域的创作，进入大众视野。",{"type":20,"tag":66,"props":1328,"children":1329},{},[1330],{"type":25,"value":1331},"同时也需要承担这样做的后果，并接受来自对江雪只有一面之缘而对其进行点评的反馈。",{"type":20,"tag":66,"props":1333,"children":1334},{},[1335],{"type":25,"value":1336},"需要大量的长时间流量暴露、推广才能形成良好的反馈，因为这个过程会愈发了解这到底是什么东西，而不是盲目的、推崇的、一时起意的反馈。",{"type":20,"tag":66,"props":1338,"children":1339},{},[1340],{"type":25,"value":1341},"这就需要其江雪的核心团队，生活上、家庭中。对金钱的追求和渴望并不是那么急切，但又需要承担一些无法管控\\理解的反馈。",{"type":20,"tag":66,"props":1343,"children":1344},{},[1345],{"type":25,"value":1346},"但又在无报酬、极少报酬的情况下。自发的。完成远高于这个报酬的价值和独具特色的创新能力及巧夺天工构思严谨的产出。",{"type":20,"tag":66,"props":1348,"children":1349},{},[1350],{"type":25,"value":1351},"这就需要其自身家庭的理解和鼓励，和团队之间的互相扶持；经过漫长努力之后，还需担心创意、想法是否被其他有心之人窃取和复制；因此又需更加严谨、紧而有序的流程逻辑才能保护自身的创意和想法不被轻易拿取。",{"type":20,"tag":66,"props":1353,"children":1354},{},[1355],{"type":25,"value":1356},"可这只是阻碍敬畏之人的手段，如果对方是逐利的，那大可拖你大把时间，即使胜算很大，但依然无法挽回其占有率；这就需要比在产品发布前更加努力才能挽回丝毫。",{"type":20,"tag":66,"props":1358,"children":1359},{},[1360],{"type":25,"value":1361},"但又有多少人会在这个过程中，真的会一直支持、陪伴呢。可以往好处想想，或许流言蜚语则会一直陪伴其中。",{"type":20,"tag":66,"props":1363,"children":1364},{},[1365],{"type":25,"value":1366},"所以最简单的方式就是，让江雪不那么主动地走进大众视野，但又依然坐着属于江雪应该做的事。虽然无人问津，衣不饱食，但也可以让本就无趣的一生充满追求。",{"type":20,"tag":66,"props":1368,"children":1369},{},[1370,1372,1378],{"type":25,"value":1371},"如果你恰好是那位，或许你可以与我进行联系：",{"type":20,"tag":102,"props":1373,"children":1375},{"href":1374},"mailto:RHYMEQ@ACM.ORG",[1376],{"type":25,"value":1377},"RHYMEQ@ACM.ORG",{"type":25,"value":111},{"type":20,"tag":66,"props":1380,"children":1381},{},[1382],{"type":25,"value":1383},"希望。你会比我做的更加完美。",{"type":20,"tag":66,"props":1385,"children":1386},{},[1387],{"type":20,"tag":768,"props":1388,"children":1389},{},[1390],{"type":25,"value":1391},"Style",{"type":20,"tag":66,"props":1393,"children":1394},{},[1395],{"type":25,"value":1396},"我深知写博客更多的是记录，而不是传授知识。如果我想要传授知识，我完全可以开设公开课，或者参与某个会议，在视频中讲解特定问题。这样做可以吸引更多的观众。其次，我也明白很少有人会主动发现这个博客，更多的是在他们遇到某个问题并在谷歌搜索时偶然发现的。",{"type":20,"tag":66,"props":1398,"children":1399},{},[1400],{"type":25,"value":1401},"这有很强的目的性，因此，我尽量在博客中避免探讨特定问题。",{"type":20,"tag":66,"props":1403,"children":1404},{},[1405],{"type":25,"value":1406},"所以。我的博客大都不会详细记录技术细节、原理，更多的是在完成某个作品时的经历和感受。说到底，技术、原理、理论和概述大多都是实现某个想法的必要工具之一。",{"type":20,"tag":66,"props":1408,"children":1409},{},[1410],{"type":25,"value":1411},"我深信某项技术、框架、协议、理论的作者或协作者，以及这个项目的受众者及追随者会比我更了解他们所热衷的技术。因此，他们的阐述或者对某个事物的理解程度，会比我只是浏览了几篇文档或者说只使用了几次的经历更为深入。",{"type":20,"tag":66,"props":1413,"children":1414},{},[1415],{"type":25,"value":1416},"而我无需再次解读。同时，我也尽量避免对某项技术的修改或应用，因为大公司对技术的修改和应用更容易引起关注和重视。这也是为了关心那些怀揣向心中目标而来却感到失望而离去的人。",{"type":20,"tag":66,"props":1418,"children":1419},{},[1420],{"type":25,"value":1421},"个人由于偏向等死主义。因此对刷题、竞赛、解谜语等无感，所以也不会出现类似内容。",{"type":20,"tag":1423,"props":1424,"children":1425},"link-to",{},[1426,1449,1471],{"type":20,"tag":1427,"props":1428,"children":1429},"li",{},[1430],{"type":20,"tag":102,"props":1431,"children":1434},{"target":1432,"href":1433},"_blank","https://www.researchgate.net/profile/Rhyme-Qing",[1435],{"type":20,"tag":1436,"props":1437,"children":1442},"svg",{"width":1438,"height":1438,"viewBox":1439,"fill":1440,"xmlns":1441},"32","0 0 448 512","none","http://www.w3.org/2000/svg",[1443],{"type":20,"tag":1444,"props":1445,"children":1448},"path",{"d":1446,"fill":1447},"M224 32C100.288 32 0 132.288 0 256V256C0 379.712 100.288 480 224 480V480C3