s":715,"children":717},{"className":716},[553,554],[],{"type":21,"tag":483,"props":719,"children":721},{"className":720},[507],[722],{"type":21,"tag":483,"props":723,"children":725},{"className":724},[563,564],[726,790],{"type":21,"tag":483,"props":727,"children":729},{"className":728},[569],[730,785],{"type":21,"tag":483,"props":731,"children":733},{"className":732,"style":575},[574],[734,754,765],{"type":21,"tag":483,"props":735,"children":736},{"style":579},[737,741],{"type":21,"tag":483,"props":738,"children":740},{"className":739,"style":585},[584],[],{"type":21,"tag":483,"props":742,"children":744},{"className":743},[590,591,592,593],[745],{"type":21,"tag":483,"props":746,"children":748},{"className":747},[548,593],[749],{"type":21,"tag":483,"props":750,"children":752},{"className":751},[548,593],[753],{"type":26,"value":11},{"type":21,"tag":483,"props":755,"children":756},{"style":606},[757,761],{"type":21,"tag":483,"props":758,"children":760},{"className":759,"style":585},[584],[],{"type":21,"tag":483,"props":762,"children":764},{"className":763,"style":616},[615],[],{"type":21,"tag":483,"props":766,"children":767},{"style":620},[768,772],{"type":21,"tag":483,"props":769,"children":771},{"className":770,"style":585},[584],[],{"type":21,"tag":483,"props":773,"children":775},{"className":774},[590,591,592,593],[776],{"type":21,"tag":483,"props":777,"children":779},{"className":778},[548,593],[780],{"type":21,"tag":483,"props":781,"children":783},{"className":782},[548,593],[784],{"type":26,"value":515},{"type":21,"tag":483,"props":786,"children":788},{"className":787},[642],[789],{"type":26,"value":645},{"type":21,"tag":483,"props":791,"children":793},{"className":792},[569],[794],{"type":21,"tag":483,"props":795,"children":797},{"className":796,"style":653},[574],[798],{"type":21,"tag":483,"props":799,"children":800},{},[],{"type":21,"tag":483,"props":802,"children":804},{"className":803},[661,554],[],{"type":26,"value":806}," 是在无意义的各种事中浪费，另外的 ",{"type":21,"tag":483,"props":808,"children":810},{"className":809},[486],[811,841],{"type":21,"tag":483,"props":812,"children":814},{"className":813},[491],[815],{"type":21,"tag":494,"props":816,"children":817},{"xmlns":496},[818],{"type":21,"tag":499,"props":819,"children":820},{},[821,836],{"type":21,"tag":503,"props":822,"children":823},{},[824],{"type":21,"tag":507,"props":825,"children":826},{},[827,831],{"type":21,"tag":511,"props":828,"children":829},{},[830],{"type":26,"value":515},{"type":21,"tag":511,"props":832,"children":833},{},[834],{"type":26,"value":835},"0.1",{"type":21,"tag":522,"props":837,"children":838},{"encoding":524},[839],{"type":26,"value":840},"\\frac{3}{0.1}",{"type":21,"tag":483,"props":842,"children":844},{"className":843,"ariaHidden":532},[531],[845],{"type":21,"tag":483,"props":846,"children":848},{"className":847},[537],[849,853],{"type":21,"tag":483,"props":850,"children":852},{"className":851,"style":543},[542],[],{"type":21,"tag":483,"props":854,"children":856},{"className":855},[548],[857,861,944],{"type":21,"tag":483,"props":858,"children":860},{"className":859},[553,554],[],{"type":21,"tag":483,"props":862,"children":864},{"className":863},[507],[865],{"type":21,"tag":483,"props":866,"children":868},{"className":867},[563,564],[869,933],{"type":21,"tag":483,"props":870,"children":872},{"className":871},[569],[873,928],{"type":21,"tag":483,"props":874,"children":876},{"className":875,"style":575},[574],[877,897,908],{"type":21,"tag":483,"props":878,"children":879},{"style":579},[880,884],{"type":21,"tag":483,"props":881,"children":883},{"className":882,"style":585},[584],[],{"type":21,"tag":483,"props":885,"children":887},{"className":886},[590,591,592,593],[888],{"type":21,"tag":483,"props":889,"children":891},{"className":890},[548,593],[892],{"type":21,"tag":483,"props":893,"children":895},{"className":894},[548,593],[896],{"type":26,"value":835},{"type":21,"tag":483,"props":898,"children":899},{"style":606},[900,904],{"type":21,"tag":483,"props":901,"children":903},{"className":902,"style":585},[584],[],{"type":21,"tag":483,"props":905,"children":907},{"className":906,"style":616},[615],[],{"type":21,"tag":483,"props":909,"children":910},{"style":620},[911,915],{"type":21,"tag":483,"props":912,"children":914},{"className":913,"style":585},[584],[],{"type":21,"tag":483,"props":916,"children":918},{"className":917},[590,591,592,593],[919],{"type":21,"tag":483,"props":920,"children":922},{"className":921},[548,593],[923],{"type":21,"tag":483,"props":924,"children":926},{"className":925},[548,593],[927],{"type":26,"value":515},{"type":21,"tag":483,"props":929,"children":931},{"className":930},[642],[932],{"type":26,"value":645},{"type":21,"tag":483,"props":934,"children":936},{"className":935},[569],[937],{"type":21,"tag":483,"props":938,"children":940},{"className":939,"style":653},[574],[941],{"type":21,"tag":483,"props":942,"children":943},{},[],{"type":21,"tag":483,"props":945,"children":947},{"className":946},[661,554],[],{"type":26,"value":949}," 交给未来。",{"type":21,"tag":67,"props":951,"children":953},{"style":952},"font-size: small;margin-top:30px;margin-bottom: 30px",[954],{"type":26,"value":955},"*上述中的设计、全栈、产品、测试\\安全、运维、区块链等的描述可能或大概存在不严谨，可能缺乏对专业技术、专业领域的相关问题敬畏之心。本人深知技术、逻辑、思维、应用不光只是会用就行，还需考虑环境等不可抗力的各种因素，因此，本文所指作者只会略微理解、略微应用，无法与专业（指专门从事某些方向的专业人士、工程师、学者、老师、培训机构讲师等所掌握的技术本人无法相提并论）或某个圈子、专业领域中的社群（涵盖类似像是微信群、Group、Discord、IRC 频道等类似群组沟通平台\\应用)的会员、成员相提并论。同时上述中的相关专业领域，与其他作者（泛指书籍作者、微信公众号作者、BLOG 作者 等类似署名方式的文章作者）相比，本人无法预之媲美。",{"type":21,"tag":67,"props":957,"children":958},{},[959],{"type":21,"tag":447,"props":960,"children":961},{},[962],{"type":26,"value":963},"Lucky Star",{"type":21,"tag":51,"props":965,"children":969},{"src":966,"width":967,"style":968},"/images/pages/about/2.png",150,"margin-top: 20px;margin-bottom: 10px;",[],{"type":21,"tag":67,"props":971,"children":972},{},[973],{"type":26,"value":974},"一生中最幸福的事，就是收获到了 JIANGXUE 江雪的 ORG 域名；没错就是课本中的那句：\"独钓寒江雪\" 的江雪全拼。",{"type":21,"tag":67,"props":976,"children":977},{},[978],{"type":26,"value":979},"这也是我最喜欢的一首诗，期初，我会觉得江雪好帅又好听，温尔典雅。后来，我只觉得我这一生就跟这首诗类似，精神上受到很大刺激和压抑（现在称之为破防）",{"type":21,"tag":67,"props":981,"children":982},{},[983],{"type":26,"value":984},"之所以还活着，大概是因为不想让这么帅又这么好听的域名流入他人之手做一些不符合这个意境的事情。",{"type":21,"tag":67,"props":986,"children":987},{},[988],{"type":26,"value":989},"当然，在我选择了却自己前，我会为它寻找一个和其格调又有和其自身能力绝对与之匹配的有心之人，接手 JIANGXUE。",{"type":21,"tag":67,"props":991,"children":992},{},[993],{"type":26,"value":994},"为什么是 JIANGXUE.ORG，而不是 .COM / .NET ，是因为江雪的意境，非常符合 ORG 域的独特表达方式，即非营利。",{"type":21,"tag":67,"props":996,"children":997},{},[998],{"type":26,"value":999},"很多事情营利去做都很难了，更何况是非营利。这就意味这需要参与者高度的认同和一些不明真相吃瓜群众的流量和其荷包里的 $，有了流量和曝光，才能让本就是小众领域的创作，进入大众视野。",{"type":21,"tag":67,"props":1001,"children":1002},{},[1003],{"type":26,"value":1004},"同时也需要承担这样做的后果，并接受来自对江雪只有一面之缘而对其进行点评的反馈。",{"type":21,"tag":67,"props":1006,"children":1007},{},[1008],{"type":26,"value":1009},"需要大量的长时间流量暴露、推广才能形成良好的反馈，因为这个过程会愈发了解这到底是什么东西，而不是盲目的、推崇的、一时起意的反馈。",{"type":21,"tag":67,"props":1011,"children":1012},{},[1013],{"type":26,"value":1014},"这就需要其江雪的核心团队，生活上、家庭中。对金钱的追求和渴望并不是那么急切，但又需要承担一些无法管控\\理解的反馈。",{"type":21,"tag":67,"props":1016,"children":1017},{},[1018],{"type":26,"value":1019},"但又在无报酬、极少报酬的情况下。自发的。完成远高于这个报酬的价值和独具特色的创新能力及巧夺天工构思严谨的产出。",{"type":21,"tag":67,"props":1021,"children":1022},{},[1023],{"type":26,"value":1024},"这就需要其自身家庭的理解和鼓励，和团队之间的互相扶持；经过漫长努力之后，还需担心创意、想法是否被其他有心之人窃取和复制；因此又需更加严谨、紧而有序的流程逻辑才能保护自身的创意和想法不被轻易拿取。",{"type":21,"tag":67,"props":1026,"children":1027},{},[1028],{"type":26,"value":1029},"可这只是阻碍敬畏之人的手段，如果对方是逐利的，那大可拖你大把时间，即使胜算很大，但依然无法挽回其占有率；这就需要比在产品发布前更加努力才能挽回丝毫。",{"type":21,"tag":67,"props":1031,"children":1032},{},[1033],{"type":26,"value":1034},"但又有多少人会在这个过程中，真的会一直支持、陪伴呢。可以往好处想想，或许流言蜚语则会一直陪伴其中。",{"type":21,"tag":67,"props":1036,"children":1037},{},[1038],{"type":26,"value":1039},"所以最简单的方式就是，让江雪不那么主动地走进大众视野，但又依然坐着属于江雪应该做的事。虽然无人问津，衣不饱食，但也可以让本就无趣的一生充满追求。",{"type":21,"tag":67,"props":1041,"children":1042},{},[1043,1045,1051],{"type":26,"value":1044},"如果你恰好是那位，或许你可以与我进行联系：",{"type":21,"tag":137,"props":1046,"children":1048},{"href":1047},"mailto:RHYMEQ@ACM.ORG",[1049],{"type":26,"value":1050},"RHYMEQ@ACM.ORG",{"type":26,"value":146},{"type":21,"tag":67,"props":1053,"children":1054},{},[1055],{"type":26,"value":1056},"希望。你会比我做的更加完美。",{"type":21,"tag":67,"props":1058,"children":1059},{},[1060],{"type":21,"tag":447,"props":1061,"children":1062},{},[1063],{"type":26,"value":1064},"Style",{"type":21,"tag":67,"props":1066,"children":1067},{},[1068],{"type":26,"value":1069},"我深知写博客更多的是记录，而不是传授知识。如果我想要传授知识，我完全可以开设公开课，或者参与某个会议，在视频中讲解特定问题。这样做可以吸引更多的观众。其次，我也明白很少有人会主动发现这个博客，更多的是在他们遇到某个问题并在谷歌搜索时偶然发现的。",{"type":21,"tag":67,"props":1071,"children":1072},{},[1073],{"type":26,"value":1074},"这有很强的目的性，因此，我尽量在博客中避免探讨特定问题。",{"type":21,"tag":67,"props":1076,"children":1077},{},[1078],{"type":26,"value":1079},"因此，我的博客大都不会详细记录技术细节、原理，更多的是在完成某个作品时的经历和感受。说到底，技术、原理、理论和概述大多都是实现某个想法的必要工具之一。",{"type":21,"tag":67,"props":1081,"children":1082},{},[1083],{"type":26,"value":1084},"我深信某项技术、框架、协议、理论的作者或协作者，以及这个项目的受众者及追随者会比我更了解他们所热衷的技术。因此，他们的阐述或者对某个事物的理解程度，会比我只是浏览了几篇文档或者说只使用了几次的经历更为深入。",{"type":21,"tag":67,"props":1086,"children":1087},{},[1088],{"type":26,"value":1089},"而我无需再次解读。同时，我也尽量避免对某项技术的修改或应用，因为大公司对技术的修改和应用更容易引起关注和重视。这也是为了关心那些怀揣向心中目标而来却感到失望而离去的人。",{"type":21,"tag":67,"props":1091,"children":1092},{},[1093],{"type":26,"value":1094},"个人由于偏向等死主义。因此对刷题、竞赛、解谜语等无感，所以也不会出现类似内容。",{"type":21,"tag":1096,"props":1097,"children":1098},"link-to",{},[1099,1122,1144],{"type":21,"tag":1100,"props":1101,"children":1102},"li",{},[1103],{"type":21,"tag":137,"props":1104,"children":1107},{"target":1105,"href":1106},"_blank","https://www.researchgate.net/profile/Rhyme-Qing",[1108],{"type":21,"tag":1109,"props":1110,"children":1115},"svg",{"width":1111,"height":1111,"viewBox":1112,"fill":1113,"xmlns":1114},"32","0 0 448 512","none","http://www.w3.org/2000/svg",[1116],{"type":21,"tag":1117,"props":1118,"children":1121},"path",{"d":1119,"fill