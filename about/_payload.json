78.4 653.8C567.357 641.887 558.821 627.877 553.3 612.6C547.2 595.7 544.2 577.9 544.4 560C544.4 541.5 547.5 524.3 553.5 508.3C565 477.2 588.9 452.3 619.4 439.4C635.7 432.6 653.2 429.2 670.9 429.4C691.9 429.4 710.1 433.4 725.9 441.6C741.111 449.43 754.317 460.653 764.5 474.4C774.6 488.1 781.7 503.7 786.2 521.3C790.5 538.6 792 556.8 790.8 576ZM668.8 480.4C658 480.4 648.9 482.3 641.9 486C634.9 489.7 629.1 494.3 624.7 499.6C620.51 504.717 617.413 510.639 615.6 517C614 522.3 612.9 527.7 612.5 533.2H723C721.4 515.9 715.4 503.1 707.4 494.1C699 485.2 685.5 480.4 668.8 480.4Z","#1345FF",[],{"type":21,"tag":223,"props":1161,"children":1162},{},[],{"title":8,"searchDepth":227,"depth":227,"links":1164},[],"content:about.md","about.md",1706426789723]