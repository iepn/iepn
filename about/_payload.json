[{"data":1,"prerenderedAt":786},["Reactive",2],{"content-query-RizbiHReX6":3},{"_path":4,"_dir":5,"_draft":6,"_partial":6,"_locale":5,"title":7,"description":5,"body":8,"_type":781,"_id":782,"_source":783,"_file":784,"_extension":785},"/about","",false,"Something about me",{"type":9,"children":10,"toc":778},"root",[11,19,23,48,58,63,68,73,78,83,557,563,568,576,582,587,592,597,602,607,612,617,622,627,632,637,642,647,652,666,671,679,684,689,694,699,704,709,774],{"type":12,"tag":13,"props":14,"children":16},"element","h1",{"id":15},"something-about-me",[17],{"type":18,"value":7},"text",{"type":12,"tag":20,"props":21,"children":22},"page-back",{},[],{"type":12,"tag":24,"props":25,"children":26},"page-img",{},[27],{"type":12,"tag":28,"props":29,"children":32},"div",{"className":30},[31],"slider",[33,35],{"type":18,"value":34},"\n  ",{"type":12,"tag":28,"props":36,"children":39},{"className":37},[38],"slides",[40,42,47],{"type":18,"value":41},"\n      ",{"type":12,"tag":43,"props":44,"children":46},"img",{"src":45},"/images/pages/about/1.png",[],{"type":18,"value":34},{"type":12,"tag":49,"props":50,"children":51},"p",{},[52],{"type":12,"tag":53,"props":54,"children":55},"strong",{},[56],{"type":18,"value":57},"一生奉行",{"type":12,"tag":49,"props":59,"children":60},{},[61],{"type":18,"value":62},"UNDERACHIEVER \\ LOSER \\ FAILURE \\ DUD \\ WASHOUT 且坚持不懈的人；患有严重的抑郁症、自闭症、自大\\嫉妒型妄想症。",{"type":12,"tag":49,"props":64,"children":65},{},[66],{"type":18,"value":67},"在失败的人生中，涉及到了设计、全栈、产品、测试\\安全、运维、区块链的方方面面，创造了/设计了/开发了很多人看了都会觉得是毫无价值的东西、项目、技术、框架、组件等。",{"type":12,"tag":49,"props":69,"children":70},{},[71],{"type":18,"value":72},"目前是自由散漫的设计师 、 无法信任的开发者 、技术栈混乱不堪的架构师 、 无人问津的产品设计师 、 三位数浏览量的运营 、 数次爆仓的区块链开发。",{"type":12,"tag":49,"props":74,"children":75},{},[76],{"type":18,"value":77},"无法发现富有大量多角度且不同 BUG 的测试 、使用 PaaS 的运维、只发现并提交逻辑漏洞的在野White-hat。",{"type":12,"tag":49,"props":79,"children":80},{},[81],{"type":18,"value":82},"奉行淡进淡出主义的动效设计师、只会画水墨风的原画。",{"type":12,"tag":49,"props":84,"children":85},