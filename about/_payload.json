"props":384,"children":386},{"className":385},[154,199],[387],{"type":12,"tag":89,"props":388,"children":390},{"className":389},[154,199],[391],{"type":18,"value":121},{"type":12,"tag":89,"props":393,"children":395},{"className":394},[248],[396],{"type":18,"value":251},{"type":12,"tag":89,"props":398,"children":400},{"className":399},[175],[401],{"type":12,"tag":89,"props":402,"children":404},{"className":403,"style":259},[180],[405],{"type":12,"tag":89,"props":406,"children":407},{},[],{"type":12,"tag":89,"props":409,"children":411},{"className":410},[267,160],[],{"type":18,"value":413}," 是在无意义的各种事中浪费，另外的 ",{"type":12,"tag":89,"props":415,"children":417},{"className":416},[92],[418,448],{"type":12,"tag":89,"props":419,"children":421},{"className":420},[97],[422],{"type":12,"tag":100,"props":423,"children":424},{"xmlns":102},[425],{"type":12,"tag":105,"props":426,"children":427},{},[428,443],{"type":12,"tag":109,"props":429,"children":430},{},[431],{"type":12,"tag":113,"props":432,"children":433},{},[434,438],{"type":12,"tag":117,"props":435,"children":436},{},[437],{"type":18,"value":121},{"type":12,"tag":117,"props":439,"children":440},{},[441],{"type":18,"value":442},"0.1",{"type":12,"tag":128,"props":444,"children":445},{"encoding":130},[446],{"type":18,"value":447},"\\frac{3}{0.1}",{"type":12,"tag":89,"props":449,"children":451},{"className":450,"ariaHidden":138},[137],[452],{"type":12,"tag":89,"props":453,"children":455},{"className":454},[143],[456,460],{"type":12,"tag":89,"props":457,"children":459},{"className":458,"style":149},[148],[],{"type":12,"tag":89,"props":461,"children":463},{"className":462},[154],[464,468,551],{"type":12,"tag":89,"props":465,"children":467},{"className":466},[159,160],[],{"type":12,"tag":89,"props":469,"children":471},{"className":470},[113],[472],{"type":12,"tag":89,"props":473,"children":475},{"className":474},[169,170],[476,540],{"type":12,"tag":89,"props":477,"children":479},{"className":478},[175],[480,535],{"type":12,"tag":89,"props":481,"children":483},{"className":482,"style":181},[180],[484,504,515],{"type":12,"tag":89,"props":485,"children":486},{"style":185},[487,491],{"type":12,"tag":89,"props":488,"children":490},{"className":489,"style":191},[190],[],{"type":12,"tag":89,"props":492,"children":494},{"className":493},[196,197,198,199],[495],{"type":12,"tag":89,"props":496,"children":498},{"className":497},[154,199],[499],{"type":12,"tag":89,"props":500,"children":502},{"className":501},[154,199],[503],{"type":18,"value":442},{"type":12,"tag":89,"props":505,"children":506},{"style":212},[507,511],{"type":12,"tag":89,"props":508,"children":510},{"className":509,"style":191},[190],[],{"type":12,"tag":89,"props":512,"children":514},{"className":513,"style":222},[221],[],{"type":12,"tag":89,"props":516,"children":517},{"style":226},[518,522],{"type":12,"tag":89,"props":519,"children":521},{"className":520,"style":191},[190],[],{"type":12,"tag":89,"props":523,"children":525},{"className":524},[196,197,198,199],[526],{"type":12,"tag":89,"props":527,"children":529},{"className":528},[154,199],[530],{"type":12,"tag":89,"props":531,"children":533},{"className":532},[154,199],[534],{"type":18,"value":121},{"type":12,"tag":89,"props":536,"children":538},{"className":537},[248],[539],{"type":18,"value":251},{"type":12,"tag":89,"props":541,"children":543},{"className":542},[175],[544],{"type":12,"tag":89,"props":545,"children":547},{"className":546,"style":259},[180],[548],{"type":12,"tag":89,"props":549,"children":550},{},[],{"type":12,"tag":89,"props":552,"children":554},{"className":553},[267,160],[],{"type":18,"value":556}," 交给未来。",{"type":12,"tag":49,"props":558,"children":560},{"style":559},"font-size: small;margin-top:30px;margin-bottom: 30px",[561],{"type":18,"value":562},"*上述中的设计、全栈、产品、测试\\安全、运维、区块链等的描述可能或大概存在不严谨，可能缺乏对专业技术、专业领域的相关问题敬畏之心。本人深知技术、逻辑、思维、应用不光只是会用就行，还需考虑环境等不可抗力的各种因素，因此，本文所指作者只会略微理解、略微应用，无法与专业（指专门从事某些方向的专业人士、工程师、学者、老师、培训机构讲师等所掌握的技术本人无法相提并论）或某个圈子、专业领域中的社群（涵盖类似像是微信群、Group、Discord、IRC 频道等类似群组沟通平台\\应用)的会员、成员相提并论。同时上述中的相关专业领域，与其他作者（泛指书籍作者、微信公众号作者、BLOG 作者 等类似署名方式的文章作者）相比，本人无法预之媲美。",{"type":12,"tag":49,"props":564,"children":565},{},[566],{"type":18,"value":567},"\"正在攻略炼狱难度副本挑战\"",{"type":12,"tag":49,"props":569,"children":570},{},[571],{"type":12,"tag":53,"props":572,"children":573},{},[574],{"type":18,"value":575},"Lucky Star",{"type":12,"tag":43,"props":577,"children":581},{"src":578,"width":579,"style":580},"/images/pages/about/2.png",150,"margin-top: 20px;margin-bottom: 10px;",[],{"type":12,"tag":49,"props":583,"children":584},{},[585],{"type":18,"value":586},"一生中最幸福的事，就是收获到了 JIANGXUE 江雪的 ORG 域名；没错就是课本中的那句：\"独钓寒江雪\" 的江雪全拼。",{"type":12,"tag":49,"props":588,"children":589},{},[590],{"type":18,"value":591},"这也是我最喜欢的一首诗，期初，我会觉得江雪好帅又好听，温尔典雅。后来，我只觉得我这一生就跟这首诗类似，精神上受到很大刺激和压抑（现在称之为破防）",{"type":12,"tag":49,"props":593,"children":594},{},[595],{"type":18,"value":596},"之所以还活着，大概是因为不想让这么帅又这么好听的域名流入他人之手做一些不符合这个意境的事情。",{"type":12,"tag":49,"props":598,"children":599},{},[600],{"type":18,"value":601},"当然，在我选择了却自己前，我会为它寻找一个和其格调又有和其自身能力绝对与之匹配的有心之人，接手 JIANGXUE。",{"type":12,"tag":49,"props":603,"children":604},{},[605],{"type":18,"value":606},"为什么是 JIANGXUE.ORG，而不是 .COM / .NET ，是因为江雪的意境，非常符合 ORG 域的独特表达方式，即非营利。",{"type":12,"tag":49,"props":608,"children":609},{},[610],{"type":18,"value":611},"很多事情营利去做都很难了，更何况是非营利。这就意味这需要参与者高度的认同和一些不明真相吃瓜群众的流量和其荷包里的 $，有了流量和曝光，才能让本就是小众领域的创作，进入大众视野。",{"type":12,"tag":49,"props":613,"children":614},{},[615],{"type":18,"value":616},"同时也需要承担这样做的后果，并接受来自对江雪只有一面之缘而对其进行点评的反馈。",{"type":12,"tag":49,"props":618,"children":619},{},[620],{"type":18,"value":621},"需要大量的长时间流量暴露、推广才能形成良好的反馈，因为这个过程会愈发了解这到底是什么东西，而不是盲目的、推崇的、一时起意的反馈。",{"type":12,"tag":49,"props":623,"children":624},{},[625],{"type":18,"value":626},"这就需要其江雪的核心团队，生活上、家庭中。对金钱的追求和渴望并不是那么急切，但又需要承担一些无法管控\\理解的反馈。",{"type":12,"tag":49,"props":628,"children":629},{},[630],{"type":18,"value":631},"但又在无报酬、极少报酬的情况下。自发的。完成远高于这个报酬的价值和独具特色的创新能力及巧夺天工构思严谨的产出。",{"type":12,"tag":49,"props":633,"children":634},{},[635],{"type":18,"value":636},"这就需要其自身家庭的理解和鼓励，和团队之间的互相扶持；经过漫长努力之后，还需担心创意、想法是否被其他有心之人窃取和复制；因此又需更加严谨、紧而有序的流程逻辑才能保护自身的创意和想法不被轻易拿取。",{"type":12,"tag":49,"props":638,"children":639},{},[640],{"type":18,"value":641},"可这只是阻碍敬畏之人的手段，如果对方是逐利的，那大可拖你大把时间，即使胜算很大，但依然无法挽回其占有率；这就需要比在产品发布前更加努力才能挽回丝毫。",{"type":12,"tag":49,"props":643,"children":644},{},[645],{"type":18,"value":646},"但又有多少人会在这个过程中，真的会一直支持、陪伴呢。可以往好处想想，或许流言蜚语则会一直陪伴其中。",{"type":12,"tag":49,"props":648,"children":649},{},[650],{"type":18,"value":651},"所以最简单的方式就是，让江雪不那么主动地走进大众视野，但又依然做着属于江雪应该做的事。虽然无人问津，衣不饱食，但也可以让本就无趣的一生充满追求。",{"type":12,"tag":49,"props":653,"children":654},{},[655,657,664],{"type":18,"value":656},"如果你恰好是那位，或许你可以与我进行联系：",{"type":12,"tag":658,"props":659,"children":661},"a",{"href":660},"mailto:RHYMEQ@ACM.ORG",[662],{"type":18,"value":663},"RHYMEQ@ACM.ORG",{"type":18,"value":665},"。",{"type":12,"tag":49,"props":667,"children":668},{},[669],{"type":18,"value":670},"希望。你会比我做的更加完美。",{"type":12,"tag":49,"props":672,"children":673},{},[674],{"type":12,"tag":53,"props":675,"children":676},{},[677],{"type":18,"value":678},"Style",{"type":12,"tag":49,"props":680,"children":681},{},[682],{"type":18,"value":683},"我深知写博客更多的是记录，而不是传授知识。如果我想要传授知识，我完全可以开设公开课，或者参与某个会议，在视频中讲解特定问题。这样做可以吸引更多的观众。其次，我也明白很少有人会主动发现这个博客，更多的是在他们遇到某个问题并在谷歌搜索时偶然发现的。",{"type":12,"tag":49,"props":685,"children":686},{},[687],{"type":18,"value":688},"这有很强的目的性，因此，我尽量在博客中避免探讨特定问题。",{"type":12,"tag":49,"props":690,"children":691},{},[692],{"type":18,"value":693},"所以。我的博客大都不会详细记录技术细节、原理，更多的是在完成某个作品时的经历和感受。说到底，技术、原理、理论和概述大多都是实现某个想法的必要工具之一。",{"type":12,"tag":49,"props":695,"children":696},{},[697],{"type":18,"value":698},"我深信某项技术、框架、协议、理论的作者或协作者，以及这个项目的受众者及追随者会比我更了解他们所热衷的技术。因此，他们的阐述或者对某个事物的理解程度，会比我只是浏览了几篇文档或者说只使用了几次的经历更为深入。",{"type":12,"tag":49,"props":700,"children":701},{},[702],{"type":18,"value":703},"而我无需再次解读。同时，我也尽量避免对某项技术的修改或应用，因为大公司对技术的修改和应用更容易引起关注和重视。这也是为了关心那些怀揣向心中目标而来却感到失望而离去的人。",{"type":12,"tag":49,"props":705,"children":706},{},[707],{"type":18,"value":708},"个人由于偏向等死主义。因此对刷题、竞赛、解谜语等无感，所以也不会出现类似内容。",{"type":12,"tag":710,"props":711,"children":712},"link-to",{},[713,736,758],{"type":12,"tag":714,"props":715,"children":716},"li",{},[717],{"type":12,"tag":658,"props":718,"children":721},{"target":719,"href":720},"_blank","https://www.researchgate.net/profile/Rhyme-Qing",[722],{"type":12,"tag":723,"props":724,"children":729},"svg",{"width":725,"height":725,"viewBox":726,"fill":727,"xmlns":728},"32","0 0 448 512","none","http://www.w3.org/2000/svg",[730],{"type":12,"tag":731,"props":732,"children":735},"path",{"d":733,"fill":734},"M224 32C100.288 32 0 132.288 0 256V256C0 379.712 100.288 480 224 480V480C347.712 480 448 379.712 448 256V256C448 132.288 347.712 32 224 32V32ZM262.2 366.4C255.6 369.4 229 372.4 212.2 352.2C203 341.6 186.9 318.9 170 288.6C161.1 288.6 155.3 288.6 148.6 288V334.4C148.6 357.9 154.6 355.6 174.4 358.3V366.4C167.5 366.1 151.3 365.6 138.8 365.6C125.7 365.6 112.7 366.2 105.2 366.4V358.3C120.7 355.4 127.2 357 127.2 334.4V225C127.2 202.4 120.8 204 105.2 201.1V193C131 194 158.3 192.4 176.1 192.4C207.8 192.4 232 206.8 232 238C232 259.1 215.3 280.2 192.8 285.5C206.4 309.7 222.8 331.1 235 344.4C242.2 352.2 252.2 359.1 262.2 359.1V366.4ZM285.1 231.4C261.8 231.4 252.9 215.7 252.9 199.2V167C252.9 154.8 261.7 136.6 286.9 136.6C312.1 136.6 317.3 154.5 317.3 154.5L306.6 161.7C306.6 161.7 301.1 149.2 286.9 149.2C279 149.2 267.2 156.5 267.2 168.9V195.7C267.2 209.1 273.8 219 285.1 219C299.2 219 306.6 208.1 306.6 192.2H288.7V181.5H319.1C319.1 202 323.8 231.4 285.1 231.4ZM168.6 276.1C159.2 276.1 155 275.8 148.6 275.3V205.6C155 205 163.6 205 171.1 205C194.4 205 208.3 217.2 208.3 239.5C208.3 261.4 193.3 276.1 168.6 276.1Z","#3BEDB3",[],{"type":12,"tag":714,"props":737,"children":738},{},[739],{"type":12,"tag":658,"props":740,"children":742},{"target":719,"href":741},"https://github.com/iepn",[743],{"type":12,"tag":723,"props":744,"children":753},{"height":745,"ariaHidden":138,"viewBox":746,"version"